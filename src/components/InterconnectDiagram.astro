---
/**
 * The signature motif: a schematic of the platform itself.
 *
 * Capabilities enter from the top, resolve through one API spine, and leave as
 * the things a business actually ships. An amber signal travels the traces to
 * say the one thing the brand claims — that these are not separate products.
 *
 * Every node is a capability that exists. Pure inline SVG: no island, no JS,
 * no layout shift. Motion is decorative and collapses to a static schematic
 * under prefers-reduced-motion.
 */
import { useI18n } from '@i18n';

interface Props {
  /** Extra class for the wrapping figure. */
  class?: string;
}

const { class: className } = Astro.props;
const { t, locale } = useI18n(Astro.url.pathname);

/* Geometry note: node widths and centres are chosen so the gaps between boxes
   are even (~17px in, ~16px out) across the 90..510 span of the spine. The
   first pass packed the inputs into uneven pairs (4px / 14px / 4px) and left
   the output boxes overlapping by a pixel.

   Spanish labels run longer than English ones ("palabras clave" vs
   "keywords", "facturación" vs "invoicing") and the `cx` positions above are
   load-bearing — the trace paths below are literal coordinates drawn *to*
   them, so the centres cannot move without redrawing every trace. Instead the
   boxes widen for Spanish only (still short of the next box's centre, so the
   even-gap rhythm holds, just tighter), and `textLength` is a hard backstop
   on the labels that still wouldn't fit even in the wider box — it forces the
   glyphs to the given width instead of letting them overflow, regardless of
   which font actually renders at build time. English never enters either
   path: at `locale === 'en'` the widths and the text markup are byte-for-byte
   what they were before this file knew about Spanish. */
const isEs = locale === 'es';
const inputWidth = isEs ? 100 : 92;
const outputWidth = isEs ? 112 : 104;
const NODE_PADDING = 12;
const inputTextLength = inputWidth - NODE_PADDING;
const outputTextLength = outputWidth - NODE_PADDING;

// Thresholds are set below the shortest label of each set that is known to
// fit its (already-widened) box, so only the genuinely long words compress.
const fitInput = (label: string) =>
  isEs && label.length > 8 ? { textLength: inputTextLength, lengthAdjust: 'spacingAndGlyphs' as const } : {};
const fitOutput = (label: string) =>
  isEs && label.length > 6 ? { textLength: outputTextLength, lengthAdjust: 'spacingAndGlyphs' as const } : {};

const inputs = [
  { label: t('interconnect.input.keywords'), cx: 136, trace: 'M136,92 V130 L170,160 V185' },
  { label: t('interconnect.input.aiContent'), cx: 245, trace: 'M245,92 V185' },
  { label: t('interconnect.input.images'), cx: 354, trace: 'M354,92 V185' },
  { label: t('interconnect.input.indexing'), cx: 463, trace: 'M463,92 V130 L429,160 V185' },
].map((n) => ({ ...n, textProps: fitInput(n.label) }));

const outputs = [
  { label: t('interconnect.output.storefront'), cx: 180, trace: 'M215,215 V240 L180,270 V308' },
  { label: t('interconnect.output.payments'), cx: 300, trace: 'M300,215 V308' },
  { label: t('interconnect.output.invoicing'), cx: 420, trace: 'M385,215 V240 L420,270 V308' },
].map((n) => ({ ...n, textProps: fitOutput(n.label) }));
---

<figure class:list={['motif', className]}>
  <svg
    viewBox="0 0 600 400"
    role="img"
    aria-label={t('interconnect.aria')}
    class="motif__svg"
  >
    <!-- Traces: structure first, so nodes sit above them -->
    {[...inputs, ...outputs].map((n, i) => (
      <>
        <path d={n.trace} class="motif__trace" />
        <path
          d={n.trace}
          class="motif__signal"
          pathLength="100"
          style={`--delay: ${i * 0.32}s`}
        />
      </>
    ))}

    <!-- Input nodes -->
    {inputs.map((n) => (
      <g class="motif__node">
        <rect x={n.cx - inputWidth / 2} y="58" width={inputWidth} height="34" rx="5" />
        <text x={n.cx} y="79" {...n.textProps}>{n.label}</text>
      </g>
    ))}

    <!-- The spine -->
    <g class="motif__spine">
      <rect x="90" y="185" width="420" height="30" rx="6" />
      <path d="M90,200 H510" class="motif__spine-signal" pathLength="100" />
      <text x="300" y="205">1PLATFORM API</text>
    </g>

    <!-- Output nodes -->
    {outputs.map((n) => (
      <g class="motif__node motif__node--out">
        <rect x={n.cx - outputWidth / 2} y="308" width={outputWidth} height="34" rx="5" />
        <text x={n.cx} y="329" {...n.textProps}>{n.label}</text>
      </g>
    ))}
  </svg>
</figure>

<style>
  .motif {
    width: 100%;
    margin: 0;
  }

  .motif__svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  /* ===== Structure ===== */
  .motif__trace {
    fill: none;
    stroke: var(--color-border-strong);
    stroke-width: 1.25;
  }

  .motif__node rect {
    fill: var(--surface);
    stroke: var(--hairline-strong);
    stroke-width: 1;
  }

  .motif__node text {
    fill: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 13px;
    text-anchor: middle;
  }

  .motif__spine rect {
    fill: var(--cobalt);
  }

  .motif__spine text {
    fill: var(--surface);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-anchor: middle;
  }

  /* ===== Signal =====
     Amber is reserved for this: the one thing that moves. */
  .motif__signal {
    fill: none;
    stroke: var(--signal);
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-dasharray: 9 100;
    /* Static schematic by default; the pulse is opt-in below. */
    stroke-dashoffset: 40;
    opacity: 0;
  }

  .motif__spine-signal {
    fill: none;
    stroke: var(--signal);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 14 100;
    stroke-dashoffset: 50;
    opacity: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .motif__signal {
      opacity: 1;
      animation: trace-pulse 2.8s var(--delay, 0s) linear infinite;
    }

    .motif__spine-signal {
      opacity: 0.9;
      animation: spine-pulse 2.8s 0.9s linear infinite;
    }

    @keyframes trace-pulse {
      0%   { stroke-dashoffset: 109; opacity: 0; }
      12%  { opacity: 1; }
      88%  { opacity: 1; }
      100% { stroke-dashoffset: -9; opacity: 0; }
    }

    @keyframes spine-pulse {
      0%   { stroke-dashoffset: 114; opacity: 0; }
      15%  { opacity: 0.9; }
      85%  { opacity: 0.9; }
      100% { stroke-dashoffset: -14; opacity: 0; }
    }
  }

  @media (max-width: 640px) {
    .motif__node text,
    .motif__spine text {
      font-size: 14px;
    }
  }
</style>
