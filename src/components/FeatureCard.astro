---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="feature-card card reveal">
  <div class="feature-card__icon" aria-hidden="true" set:html={icon} />
  <h3>{title}</h3>
  <p>{description}</p>
</div>

<style>
  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .feature-card__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--border-radius-lg);
    background: linear-gradient(135deg, var(--color-accent-glow), rgba(139, 92, 246, 0.1));
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .feature-card h3 {
    color: var(--color-text);
  }

  .feature-card p {
    font-size: var(--text-sm);
  }
</style>
