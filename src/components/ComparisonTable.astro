---
import Check from '@components/Check.astro';

/**
 * Unified vs fragmented, compared by experience rather than by price.
 *
 * The previous version quoted competitor pricing ("around $30/mo", "$120+/mo")
 * that had no source behind it. Those numbers are gone: what is actually true
 * and checkable is what a fragmented stack costs you in effort.
 */
interface Props {
  rows?: { without: string; with_: string }[];
}

const { rows = [
  { without: 'A separate subscription per tool to manage and renew', with_: 'One account, one bill' },
  { without: 'You wire the integrations between them yourself', with_: 'Capabilities already connected' },
  { without: 'Each tool ships its own API, auth and error format', with_: 'One REST API, one token pair' },
  { without: 'Customer and order data split across dashboards', with_: 'One dashboard, one source of truth' },
  { without: 'Invoices reconciled by hand against payments', with_: 'Invoices issued from every transaction' },
  { without: 'Content copy-pasted between tools to publish', with_: 'Content generated and published in place' },
] } = Astro.props;
---

<div class="comparison reveal">
  <div class="comparison__head">
    <p class="eyebrow comparison__col-label">Separate tools</p>
    <p class="eyebrow eyebrow--accent comparison__col-label">1Platform</p>
  </div>

  {rows.map((row) => (
    <div class="comparison__row">
      <div class="comparison__cell">
        <Check yes={false} label="Separate tools:" />
        <span>{row.without}</span>
      </div>
      <div class="comparison__cell comparison__cell--with">
        <Check yes={true} label="1Platform:" />
        <span>{row.with_}</span>
      </div>
    </div>
  ))}
</div>

<style>
  .comparison {
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .comparison__head {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .comparison__col-label {
    padding: var(--space-4) var(--space-6);
    margin: 0;
  }

  .comparison__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--color-border);
  }

  .comparison__cell {
    padding: var(--space-4) var(--space-6);
    font-size: var(--text-sm);
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    color: var(--color-text-secondary);
  }

  /* The right-hand column is the claim: give it the page's surface and ink. */
  .comparison__cell--with {
    background: var(--color-bg);
    color: var(--color-text);
    border-left: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .comparison__head {
      display: none;
    }

    .comparison__row {
      grid-template-columns: 1fr;
    }

    .comparison__cell--with {
      border-left: none;
      border-top: 1px solid var(--color-border);
    }
  }
</style>
