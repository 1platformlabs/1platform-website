---
import Check from '@components/Check.astro';
import { useI18n } from '@i18n';

/**
 * Unified vs fragmented, compared by experience rather than by price.
 *
 * The previous version quoted competitor pricing ("around $30/mo", "$120+/mo")
 * that had no source behind it. Those numbers are gone: what is actually true
 * and checkable is what a fragmented stack costs you in effort.
 */
interface Props {
  rows?: { without: string; with_: string }[];
}

const { t } = useI18n(Astro.url.pathname);

const { rows = [
  { without: t('comparisonTable.row1.without'), with_: t('comparisonTable.row1.with') },
  { without: t('comparisonTable.row2.without'), with_: t('comparisonTable.row2.with') },
  { without: t('comparisonTable.row3.without'), with_: t('comparisonTable.row3.with') },
  { without: t('comparisonTable.row4.without'), with_: t('comparisonTable.row4.with') },
  { without: t('comparisonTable.row5.without'), with_: t('comparisonTable.row5.with') },
  { without: t('comparisonTable.row6.without'), with_: t('comparisonTable.row6.with') },
] } = Astro.props;
---

<div class="comparison reveal">
  <div class="comparison__head">
    <p class="eyebrow comparison__col-label">{t('comparisonTable.eyebrow.without')}</p>
    <p class="eyebrow eyebrow--accent comparison__col-label">{t('comparisonTable.eyebrow.with')}</p>
  </div>

  {rows.map((row) => (
    <div class="comparison__row">
      <div class="comparison__cell">
        <Check yes={false} label={t('comparisonTable.mark.without')} />
        <span>{row.without}</span>
      </div>
      <div class="comparison__cell comparison__cell--with">
        <Check yes={true} label={t('comparisonTable.mark.with')} />
        <span>{row.with_}</span>
      </div>
    </div>
  ))}
</div>

<style>
  .comparison {
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .comparison__head {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .comparison__col-label {
    padding: var(--space-4) var(--space-6);
    margin: 0;
  }

  .comparison__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--color-border);
  }

  .comparison__cell {
    padding: var(--space-4) var(--space-6);
    font-size: var(--text-sm);
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    color: var(--color-text-secondary);
  }

  /* The right-hand column is the claim: give it the page's surface and ink. */
  .comparison__cell--with {
    background: var(--color-bg);
    color: var(--color-text);
    border-left: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .comparison__head {
      display: none;
    }

    .comparison__row {
      grid-template-columns: 1fr;
    }

    .comparison__cell--with {
      border-left: none;
      border-top: 1px solid var(--color-border);
    }
  }
</style>
