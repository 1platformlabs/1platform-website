---
/**
 * "How it works", drawn in the same language as the interconnect motif:
 * nodes on a spine.
 *
 * Numbering is kept because these steps genuinely are a sequence — the order
 * is information the reader needs. Everything else went: the emoji that stood
 * in for icons, and the scroll-driven reveal that held every step at 0.3
 * opacity until it scrolled into view (illegible by default, and theatre).
 *
 * Replaces PipelineAnimation.astro. No JS.
 */
import { useI18n } from '@i18n';

interface Step {
  label: string;
}

interface Props {
  steps?: Step[];
  /** Accessible name for the ordered list. */
  label?: string;
}

const { t } = useI18n(Astro.url.pathname);

// Only the caller-less usage (the home page's bare `<ProcessSpine />`) ever
// renders these — every other page passes its own `steps`/`label`, which live
// in that page's own message module.
const defaultSteps: Step[] = [
  { label: t('processSpine.step.account') },
  { label: t('processSpine.step.pick') },
  { label: t('processSpine.step.domain') },
  { label: t('processSpine.step.content') },
  { label: t('processSpine.step.payments') },
  { label: t('processSpine.step.live') },
];

const { steps = defaultSteps, label = t('processSpine.defaultLabel') } = Astro.props;
---

<ol class="spine" aria-label={label}>
  {steps.map((step, i) => (
    <li class="spine__step">
      <span class="spine__node" aria-hidden="true">{i + 1}</span>
      <span class="spine__label">{step.label}</span>
    </li>
  ))}
</ol>

<style>
  .spine {
    display: grid;
    gap: var(--space-6);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .spine__step {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  /* The node: the same cobalt rounded square the schematic uses. */
  .spine__node {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    border-radius: 5px;
    background: var(--cobalt);
    color: var(--surface);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1;
  }

  .spine__label {
    font-size: var(--text-base);
    color: var(--color-text);
  }

  /* Desktop: lay the steps along a horizontal spine. */
  @media (min-width: 900px) {
    .spine {
      grid-template-columns: repeat(6, 1fr);
      gap: var(--space-4);
    }

    .spine__step {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
      padding-top: var(--space-6);
    }

    /* The spine itself, drawn through the row. */
    .spine__step::before {
      content: '';
      position: absolute;
      top: calc(var(--space-6) + 17px);
      left: 0;
      right: calc(var(--space-4) * -1);
      height: 1px;
      background: var(--color-border-strong);
    }

    .spine__step:last-child::before {
      right: auto;
      width: 34px;
    }

    .spine__node {
      position: relative;
    }

    .spine__label {
      font-size: var(--text-sm);
      color: var(--color-text-secondary);
    }
  }

  /* Mobile: vertical spine through the nodes. */
  @media (max-width: 899px) {
    .spine__step:not(:last-child)::before {
      content: '';
      position: absolute;
      left: 17px;
      top: 34px;
      bottom: calc(var(--space-6) * -1);
      width: 1px;
      background: var(--color-border-strong);
    }
  }
</style>
