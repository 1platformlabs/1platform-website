---
import Logo from '@components/Logo.astro';
import { useI18n } from '@i18n';

const { t, l } = useI18n(Astro.url.pathname);

const columns = [
  {
    title: t('footer.col.solutions'),
    links: [
      { label: t('nav.solutions.onlineStore'), href: l('/solutions/online-store/') },
      { label: t('nav.solutions.website'), href: l('/solutions/website/') },
      { label: t('nav.solutions.content'), href: l('/solutions/content/') },
      { label: t('nav.solutions.whitelabel'), href: l('/solutions/whitelabel/') },
      { label: t('nav.solutions.payments'), href: l('/payments-invoicing/') },
      { label: t('footer.link.forAgencies'), href: l('/for-agencies/') },
      { label: t('footer.link.forDevelopers'), href: l('/for-developers/') },
      { label: t('footer.link.allSolutions'), href: l('/solutions/') },
    ],
  },
  {
    title: t('footer.col.resources'),
    links: [
      { label: t('footer.link.documentation'), href: 'https://developer.1platform.pro/' },
      { label: t('footer.link.apiReference'), href: 'https://developer.1platform.pro/api-docs' },
      { label: t('footer.link.codeExamples'), href: 'https://developer.1platform.pro/' },
      { label: t('nav.blog'), href: l('/blog/') },
      { label: t('footer.link.changelog'), href: l('/changelog/') },
    ],
  },
  {
    title: t('footer.col.company'),
    links: [
      { label: t('footer.link.about'), href: l('/about/') },
      { label: t('footer.link.forDevelopers'), href: l('/for-developers/') },
      { label: t('nav.pricing'), href: l('/pricing/') },
    ],
  },
  {
    title: t('footer.col.legal'),
    links: [
      { label: t('footer.link.terms'), href: l('/terms/') },
      { label: t('footer.link.privacy'), href: l('/privacy/') },
      { label: t('footer.link.cookies'), href: l('/cookies/') },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <!-- Closing CTA -->
    <div class="footer-cta">
      <h2>{t('footer.cta.title')}</h2>
      <p>{t('footer.cta.body')}</p>
      <div class="footer-cta__actions">
        <a href="https://app.1platform.pro/app/?intent=store" class="btn btn--primary">{t('cta.launchStore')}</a>
        <a href="https://developer.1platform.pro/" class="btn btn--ghost">{t('cta.viewDocs')}</a>
      </div>
    </div>

    <hr class="divider" />

    <!-- Links -->
    <div class="footer-links">
      <div class="footer-brand">
        <Logo class="footer-logo" />
        <p>One platform. Every solution.</p>
      </div>

      {columns.map((col) => (
        <div class="footer-col">
          <h3>{col.title}</h3>
          <ul>
            {col.links.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <hr class="divider" />

    <!-- Bottom -->
    <div class="footer-bottom">
      <p>{t('footer.copyright', { year })}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
  }

  /* Left-aligned, like every other opener in the system. */
  .footer-cta {
    max-width: 40rem;
    padding-bottom: var(--space-16);
  }

  .footer-cta h2 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .footer-cta p {
    font-size: var(--text-lg);
    margin-bottom: var(--space-8);
  }

  .footer-cta__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .footer-links {
    display: grid;
    grid-template-columns: 1.5fr repeat(4, 1fr);
    gap: var(--space-8);
    padding-block: var(--space-12);
  }

  .footer-brand {
    padding-right: var(--space-8);
  }

  .footer-logo {
    margin-bottom: var(--space-3);
  }

  .footer-brand p {
    font-size: var(--text-sm);
  }

  .footer-col h3 {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-col a {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .footer-col a:hover {
    color: var(--color-text);
  }

  .footer-bottom {
    padding-top: var(--space-8);
    text-align: center;
  }

  .footer-bottom p {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  @media (max-width: 768px) {
    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-brand {
      grid-column: 1 / -1;
      padding-right: 0;
    }
  }
</style>
