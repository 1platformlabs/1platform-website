---
import Logo from '@components/Logo.astro';

const columns = [
  {
    title: 'Solutions',
    links: [
      { label: 'Online Store', href: '/solutions/online-store/' },
      { label: 'Website Builder', href: '/solutions/website/' },
      { label: 'AI Content', href: '/solutions/content/' },
      { label: 'Whitelabel Dashboard', href: '/solutions/whitelabel/' },
      { label: 'Payments & Invoicing', href: '/payments-invoicing/' },
      { label: 'For Agencies', href: '/for-agencies/' },
      { label: 'For Developers', href: '/for-developers/' },
      { label: 'All Solutions', href: '/solutions/' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Documentation', href: 'https://developer.1platform.pro/' },
      { label: 'API Reference', href: 'https://developer.1platform.pro/api-docs' },
      { label: 'Code Examples', href: 'https://developer.1platform.pro/' },
      { label: 'Blog', href: '/blog/' },
      { label: 'Changelog', href: '/changelog/' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About', href: '/about/' },
      { label: 'For Developers', href: '/for-developers/' },
      { label: 'Pricing', href: '/pricing/' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Terms of Service', href: '/terms/' },
      { label: 'Privacy Policy', href: '/privacy/' },
      { label: 'Cookie Policy', href: '/cookies/' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <!-- Closing CTA -->
    <div class="footer-cta">
      <h2>Stop juggling separate tools</h2>
      <p>Start with one platform. Sell online, issue invoices, and publish content — from one dashboard, one API, one bill.</p>
      <div class="footer-cta__actions">
        <a href="https://app.1platform.pro/app/?intent=store" class="btn btn--primary">Launch Your Store</a>
        <a href="https://developer.1platform.pro/" class="btn btn--ghost">View Documentation</a>
      </div>
    </div>

    <hr class="divider" />

    <!-- Links -->
    <div class="footer-links">
      <div class="footer-brand">
        <Logo class="footer-logo" />
        <p>One platform. Every solution.</p>
      </div>

      {columns.map((col) => (
        <div class="footer-col">
          <h3>{col.title}</h3>
          <ul>
            {col.links.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <hr class="divider" />

    <!-- Bottom -->
    <div class="footer-bottom">
      <p>&copy; {year} 1Platform Labs. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
  }

  /* Left-aligned, like every other opener in the system. */
  .footer-cta {
    max-width: 40rem;
    padding-bottom: var(--space-16);
  }

  .footer-cta h2 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .footer-cta p {
    font-size: var(--text-lg);
    margin-bottom: var(--space-8);
  }

  .footer-cta__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .footer-links {
    display: grid;
    grid-template-columns: 1.5fr repeat(4, 1fr);
    gap: var(--space-8);
    padding-block: var(--space-12);
  }

  .footer-brand {
    padding-right: var(--space-8);
  }

  .footer-logo {
    margin-bottom: var(--space-3);
  }

  .footer-brand p {
    font-size: var(--text-sm);
  }

  .footer-col h3 {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-col a {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .footer-col a:hover {
    color: var(--color-text);
  }

  .footer-bottom {
    padding-top: var(--space-8);
    text-align: center;
  }

  .footer-bottom p {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  @media (max-width: 768px) {
    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-brand {
      grid-column: 1 / -1;
      padding-right: 0;
    }
  }
</style>
