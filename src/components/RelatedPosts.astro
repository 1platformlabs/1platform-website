---
import { getCollection } from 'astro:content';
import BlogPostCard from './BlogPostCard.astro';

import { useI18n } from '@i18n';
const { t } = useI18n(Astro.url.pathname);

interface Props {
  currentSlug: string;
  currentCategory: string;
}

const { currentSlug, currentCategory } = Astro.props;

const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.slug !== currentSlug)
  .sort((a, b) => {
    const aMatch = a.data.category === currentCategory ? 1 : 0;
    const bMatch = b.data.category === currentCategory ? 1 : 0;
    return bMatch - aMatch || b.data.pubDate.getTime() - a.data.pubDate.getTime();
  })
  .slice(0, 3);
---

{related.length > 0 && (
  <section class="related section section--alt" aria-labelledby="related-heading">
    <div class="container">
      <div class="section__rule">
        <h2 class="eyebrow" id="related-heading">{t('related.title')}</h2>
      </div>

      <div class="related__grid">
        {related.map((post) => (
          <BlogPostCard
            variant="card"
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.slug}
            author={post.data.author}
            readingTime={post.data.readingTime}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>
)}

<style>
  /* The inline `style="margin-top"` and the shared .grid-3 went: this is the
     one place on the blog where posts genuinely sit side by side, so it owns
     its own column rule and can drop to two columns before it drops to one. */
  .related__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .related__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .related__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
