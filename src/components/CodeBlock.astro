---
interface Props {
  language?: string;
  title?: string;
  code: string;
}

import { useI18n } from '@i18n';

const { language = 'bash', title, code } = Astro.props;
const { t } = useI18n(Astro.url.pathname);
---

<div class="code-block">
  <div class="code-block__header">
    <span>{title || language}</span>
    <button
      class="code-block__copy"
      aria-label={t('code.copyAria')}
      data-code={code}
      data-idle-label={t('code.copy')}
      data-copied-label={t('code.copied')}
      data-failed-label={t('code.copyFailed')}
    >
      {t('code.copy')}
    </button>
  </div>
  <div class="code-block__body">
    <pre><code class={`language-${language}`}>{code}</code></pre>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.code-block__copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const el = btn as HTMLElement;
        const code = el.dataset.code || '';
        // Labels ride on the element: this script runs in the browser, where
        // the build-time catalogue does not exist.
        const idle = el.dataset.idleLabel || '';
        const restore = () => { setTimeout(() => { btn.textContent = idle; }, 2000); };
        try {
          await navigator.clipboard.writeText(code);
          btn.textContent = el.dataset.copiedLabel || '';
          restore();
        } catch {
          btn.textContent = el.dataset.failedLabel || '';
          restore();
        }
      });
    });
  });
</script>
