---
import InterconnectDiagram from '@components/InterconnectDiagram.astro';
import { useI18n } from '@i18n';

interface IntentChip {
  label: string;
  href: string;
}

interface Props {
  headline: string;
  subheadline: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  /** Mono label sitting above the headline. */
  badge?: string;
  intentChips?: IntentChip[];
  /**
   * Mounts the interconnect motif alongside the copy. Reserved for the home
   * page — the signature stays singular by only appearing where it argues the
   * brand's central claim.
   */
  motif?: boolean;
}

const { t } = useI18n(Astro.url.pathname);

const {
  headline,
  subheadline,
  // Defaults reuse the shell's own CTA keys (`common.ts`) rather than
  // redefining them here — "Get Started Free" has exactly one Spanish
  // translation for the whole site, whichever page falls back to it.
  primaryCta = { label: t('cta.getStarted'), href: 'https://app.1platform.pro/app/' },
  secondaryCta = { label: t('cta.viewDocs'), href: 'https://developer.1platform.pro/' },
  badge,
  intentChips,
  motif = false,
} = Astro.props;
---

<section class:list={['hero', motif && 'hero--motif']}>
  <div class="container hero__inner">
    <div class="hero__copy">
      {badge && <p class="eyebrow hero__eyebrow">{badge}</p>}

      <h1 class="hero__headline">{headline}</h1>

      <p class="hero__sub">{subheadline}</p>

      <div class="hero__actions">
        <a href={primaryCta.href} class="btn btn--primary">{primaryCta.label}</a>
        <a href={secondaryCta.href} class="btn btn--ghost">{secondaryCta.label}</a>
      </div>

      {intentChips && intentChips.length > 0 && (
        <nav class="hero__chips" aria-label={t('hero.chips.aria')}>
          {intentChips.map((chip) => (
            <a href={chip.href} class="hero__chip">{chip.label}</a>
          ))}
        </nav>
      )}
    </div>

    {motif && (
      <div class="hero__motif">
        <InterconnectDiagram />
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--header-height) + var(--space-16));
    padding-bottom: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .hero__inner {
    display: grid;
    gap: var(--space-12);
  }

  /* Copy sits left, not centred — the centred stack is the template posture
     this redesign leaves behind. */
  .hero__copy {
    max-width: 34rem;
  }

  .hero__eyebrow {
    margin-bottom: var(--space-5);
  }

  .hero__headline {
    font-size: var(--text-6xl);
    line-height: 1.04;
    margin-bottom: var(--space-6);
  }

  .hero__sub {
    font-size: var(--text-lg);
    line-height: 1.6;
    margin-bottom: var(--space-8);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .hero__chips {
    margin-top: var(--space-8);
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .hero__chip {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    background: var(--color-bg-alt);
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__chip {
      transition: color var(--duration-fast) ease,
                  border-color var(--duration-fast) ease;
    }
  }

  .hero__chip:hover {
    color: var(--color-accent);
    border-color: var(--color-border-hover);
  }

  .hero__motif {
    display: flex;
    align-items: center;
  }

  /* Asymmetric split: the copy holds the left, the schematic gets room to be
     read. */
  @media (min-width: 900px) {
    .hero--motif .hero__inner {
      grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
      align-items: center;
      gap: var(--space-16);
    }

    .hero--motif .hero__copy {
      max-width: none;
    }
  }

  @media (max-width: 899px) {
    .hero__motif {
      max-width: 32rem;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: calc(var(--header-height) + var(--space-10));
      padding-bottom: var(--space-12);
    }

    .hero__headline {
      font-size: var(--text-5xl);
    }
  }
</style>
