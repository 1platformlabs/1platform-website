---
interface Props {
  headline: string;
  subheadline: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  badge?: string;
}

const {
  headline,
  subheadline,
  primaryCta = { label: 'Get Started Free', href: 'https://app.1platform.pro' },
  secondaryCta = { label: 'View Documentation', href: 'https://developer.1platform.pro/' },
  badge,
} = Astro.props;

const words = headline.split(' ');
---

<section class="hero dot-grid">
  <div class="hero__aurora" aria-hidden="true">
    <div class="hero__blob hero__blob--1"></div>
    <div class="hero__blob hero__blob--2"></div>
    <div class="hero__blob hero__blob--3"></div>
  </div>

  <div class="container hero__content">
    {badge && <span class="badge hero__badge reveal">{badge}</span>}

    <h1 class="hero__headline">
      {words.map((word, i) => (
        <span class="hero__word reveal" data-delay={String(i * 100)}>
          {word}{' '}
        </span>
      ))}
    </h1>

    <p class="hero__sub reveal" data-delay={String(words.length * 100)}>
      {subheadline}
    </p>

    <div class="hero__actions reveal" data-delay={String(words.length * 100 + 200)}>
      <a href={primaryCta.href} class="btn btn--primary">{primaryCta.label}</a>
      <a href={secondaryCta.href} class="btn btn--ghost">{secondaryCta.label}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: calc(var(--header-height) + var(--space-20));
    padding-bottom: var(--space-20);
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .hero__aurora {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.12;
    mix-blend-mode: multiply;
  }

  .hero__blob--1 {
    width: 500px;
    height: 500px;
    background: var(--color-accent);
    top: -10%;
    left: 20%;
  }

  .hero__blob--2 {
    width: 400px;
    height: 400px;
    background: var(--color-purple);
    top: 30%;
    right: 10%;
  }

  .hero__blob--3 {
    width: 350px;
    height: 350px;
    background: var(--color-cyan);
    bottom: -5%;
    left: 40%;
    opacity: 0.08;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__blob--1 {
      animation: float1 30s ease-in-out infinite;
    }

    .hero__blob--2 {
      animation: float2 35s ease-in-out infinite;
    }

    .hero__blob--3 {
      animation: float3 40s ease-in-out infinite;
    }

    @keyframes float1 {
      0%, 100% { transform: translate(0, 0); }
      33% { transform: translate(30px, -20px); }
      66% { transform: translate(-20px, 15px); }
    }

    @keyframes float2 {
      0%, 100% { transform: translate(0, 0); }
      33% { transform: translate(-25px, 20px); }
      66% { transform: translate(15px, -15px); }
    }

    @keyframes float3 {
      0%, 100% { transform: translate(0, 0); }
      33% { transform: translate(20px, 15px); }
      66% { transform: translate(-15px, -20px); }
    }
  }

  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    margin-inline: auto;
  }

  .hero__badge {
    margin-bottom: var(--space-6);
  }

  .hero__headline {
    font-size: var(--text-6xl);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--space-6);
  }

  .hero__word {
    margin-right: 0.3em;
    display: inline-block;
  }

  .hero__sub {
    font-size: var(--text-lg);
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: var(--space-10);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: calc(var(--header-height) + var(--space-12));
      padding-bottom: var(--space-12);
    }

    .hero__blob--1,
    .hero__blob--2,
    .hero__blob--3 {
      width: 250px;
      height: 250px;
    }
  }
</style>
