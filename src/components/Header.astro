---
import Logo from '@components/Logo.astro';

type SubItem = { label: string; href: string; divider?: boolean };
type NavItem = { label: string; href: string; subItems?: SubItem[] };

const solutionsSubItems: SubItem[] = [
  { label: 'Online Store', href: '/solutions/online-store/' },
  { label: 'Website Builder', href: '/solutions/website/' },
  { label: 'AI Content', href: '/solutions/content/' },
  { label: 'Whitelabel Dashboard', href: '/solutions/whitelabel/' },
  { label: 'Payments & Invoicing', href: '/payments-invoicing/' },
  { label: '', href: '', divider: true },
  { label: 'View all solutions', href: '/solutions/' },
];

const navItems: NavItem[] = [
  { label: 'Solutions', href: '/solutions/', subItems: solutionsSubItems },
  { label: 'Features', href: '/features/' },
  { label: 'Pricing', href: '/pricing/' },
  { label: 'Docs', href: 'https://developer.1platform.pro/' },
  { label: 'Blog', href: '/blog/' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="site-header__inner container">
    <Logo class="site-header__logo" />

    <nav class="site-header__nav" aria-label="Main navigation">
      <ul>
        {navItems.map((item, i) => (
          item.subItems ? (
            <li class="has-dropdown" data-nav-dropdown>
              <a
                href={item.href}
                class:list={['nav-link', { 'is-active': currentPath.startsWith(item.href) }]}
              >
                {item.label}
              </a>
              <button
                type="button"
                class="dropdown-toggle"
                aria-expanded="false"
                aria-controls={`nav-dropdown-${i}`}
                aria-label={`Toggle ${item.label} menu`}
                data-dropdown-toggle
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div
                class="dropdown-panel"
                id={`nav-dropdown-${i}`}
                role="menu"
                aria-label={`${item.label} menu`}
                aria-hidden="true"
                data-dropdown-panel
              >
                <ul>
                  {item.subItems.map((sub) => (
                    sub.divider ? (
                      <li class="dropdown-divider" role="separator" aria-hidden="true"></li>
                    ) : (
                      <li>
                        <a href={sub.href} role="menuitem" tabindex="-1">{sub.label}</a>
                      </li>
                    )
                  ))}
                </ul>
              </div>
            </li>
          ) : (
            <li>
              <a
                href={item.href}
                class:list={['nav-link', { 'is-active': currentPath.startsWith(item.href) }]}
              >
                {item.label}
              </a>
            </li>
          )
        ))}
      </ul>
    </nav>

    <div class="site-header__actions">
      <a href="https://app.1platform.pro/app/" class="btn btn--primary btn--sm">
        Get Started Free
      </a>
    </div>

    <button
      class="site-header__menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle navigation menu"
      id="menu-toggle"
    >
      <span class="hamburger" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="mobile-menu__link">{item.label}</a>
            {item.subItems && (
              <ul class="mobile-menu__sublist">
                {item.subItems.map((sub) => (
                  sub.divider ? null : (
                    <li>
                      <a href={sub.href}>{sub.label}</a>
                    </li>
                  )
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
      <a href="https://app.1platform.pro/app/" class="btn btn--primary btn--full">
        Get Started Free
      </a>
    </nav>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    initMobileMenu();
    initNavDropdowns();
  });

  function initMobileMenu() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;

    /** All focusable elements inside the mobile menu + toggle button. */
    function getFocusableElements(): HTMLElement[] {
      const els = menu!.querySelectorAll<HTMLElement>('a, button, [tabindex]:not([tabindex="-1"])');
      return [toggle!, ...Array.from(els)];
    }

    function closeMenu() {
      toggle!.setAttribute('aria-expanded', 'false');
      menu!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      toggle!.focus();
    }

    function openMenu() {
      toggle!.setAttribute('aria-expanded', 'true');
      menu!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      const firstLink = menu!.querySelector<HTMLElement>('a');
      firstLink?.focus();
    }

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      isOpen ? closeMenu() : openMenu();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        if (toggle!.getAttribute('aria-expanded') === 'true') {
          closeMenu();
        }
        return;
      }

      // Focus trap: cycle Tab within mobile menu when open
      if (e.key === 'Tab' && toggle!.getAttribute('aria-expanded') === 'true') {
        const focusable = getFocusableElements();
        if (!focusable.length) return;

        const first = focusable[0];
        const last = focusable[focusable.length - 1];

        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }

  function initNavDropdowns() {
    const dropdowns = document.querySelectorAll<HTMLElement>('[data-nav-dropdown]');
    dropdowns.forEach((dropdown) => {
      const button = dropdown.querySelector<HTMLButtonElement>('[data-dropdown-toggle]');
      const panel = dropdown.querySelector<HTMLElement>('[data-dropdown-panel]');
      if (!button || !panel) return;

      const items = Array.from(panel.querySelectorAll<HTMLAnchorElement>('[role="menuitem"]'));
      let hoverTimeout: number | null = null;

      const isOpen = () => button.getAttribute('aria-expanded') === 'true';

      function open() {
        button!.setAttribute('aria-expanded', 'true');
        panel!.setAttribute('aria-hidden', 'false');
      }

      function close(focusButton = false) {
        button!.setAttribute('aria-expanded', 'false');
        panel!.setAttribute('aria-hidden', 'true');
        if (focusButton) button!.focus();
      }

      button.addEventListener('click', (e) => {
        e.preventDefault();
        isOpen() ? close() : open();
      });

      button.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          open();
          items[0]?.focus();
        } else if (e.key === 'Escape' && isOpen()) {
          e.preventDefault();
          close(true);
        }
      });

      items.forEach((item, i) => {
        item.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            items[(i + 1) % items.length]?.focus();
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            items[(i - 1 + items.length) % items.length]?.focus();
          } else if (e.key === 'Escape') {
            e.preventDefault();
            close(true);
          } else if (e.key === 'Tab') {
            close();
          }
        });
      });

      dropdown.addEventListener('mouseenter', () => {
        if (hoverTimeout) {
          clearTimeout(hoverTimeout);
          hoverTimeout = null;
        }
        open();
      });

      dropdown.addEventListener('mouseleave', () => {
        hoverTimeout = window.setTimeout(() => close(), 150);
      });

      document.addEventListener('click', (e) => {
        if (!isOpen()) return;
        if (!dropdown.contains(e.target as Node)) close();
      });
    });
  }
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--header-height);
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: var(--space-8);
  }

  .site-header__nav ul {
    display: flex;
    gap: var(--space-6);
  }

  .site-header__nav .nav-link {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    padding: var(--space-2) 0;
    position: relative;
  }

  .site-header__nav .nav-link:hover,
  .site-header__nav .nav-link.is-active {
    color: var(--color-text);
  }

  @media (prefers-reduced-motion: no-preference) {
    .site-header__nav .nav-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--color-accent);
      transition: width var(--duration-normal) var(--ease-out-expo);
    }

    .site-header__nav .nav-link:hover::after,
    .site-header__nav .nav-link.is-active::after {
      width: 100%;
    }
  }

  /* Solutions dropdown */
  .has-dropdown {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .dropdown-toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2) 2px;
    color: var(--color-text-secondary);
    display: inline-flex;
    align-items: center;
    line-height: 0;
  }

  .dropdown-toggle:hover,
  .dropdown-toggle[aria-expanded='true'] {
    color: var(--color-text);
  }

  @media (prefers-reduced-motion: no-preference) {
    .dropdown-toggle svg {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }
  }

  .dropdown-toggle[aria-expanded='true'] svg {
    transform: rotate(180deg);
  }

  .dropdown-panel {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 0;
    min-width: 240px;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-card-hover);
    padding: var(--space-2);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .dropdown-panel {
      transition: opacity var(--duration-fast) var(--ease-out-expo),
                  transform var(--duration-fast) var(--ease-out-expo),
                  visibility 0s linear var(--duration-fast);
    }
  }

  .dropdown-panel[aria-hidden='false'] {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition-delay: 0s;
  }

  .dropdown-panel ul {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .dropdown-panel a {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    border-radius: 4px;
    white-space: nowrap;
  }

  .dropdown-panel a::after {
    display: none;
  }

  .dropdown-panel a:hover,
  .dropdown-panel a:focus-visible {
    color: var(--color-text);
    background: var(--color-bg-alt);
  }

  .dropdown-divider {
    height: 1px;
    background: var(--color-border);
    margin: var(--space-2) 0;
  }

  .site-header__menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    min-width: 48px;
    min-height: 48px;
    align-items: center;
    justify-content: center;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 24px;
  }

  .hamburger span {
    display: block;
    height: 2px;
    background: var(--color-text);
    border-radius: 1px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hamburger span {
      transition: transform var(--duration-normal) ease,
                  opacity var(--duration-fast) ease;
    }
  }

  #menu-toggle[aria-expanded='true'] .hamburger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  #menu-toggle[aria-expanded='true'] .hamburger span:nth-child(2) {
    opacity: 0;
  }

  #menu-toggle[aria-expanded='true'] .hamburger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-bg);
    padding: var(--space-8) var(--space-6);
    z-index: 99;
    overflow-y: auto;
  }

  .mobile-menu[aria-hidden='false'] {
    display: block;
  }

  .mobile-menu ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .mobile-menu a {
    display: block;
    padding: var(--space-4);
    font-size: var(--text-lg);
    font-weight: 500;
    border-radius: var(--border-radius);
  }

  .mobile-menu a:hover {
    background: var(--color-bg-alt);
  }

  .mobile-menu .mobile-menu__sublist {
    gap: 0;
    margin-top: var(--space-1);
    margin-left: var(--space-4);
    padding-left: var(--space-3);
    border-left: 1px solid var(--color-border);
  }

  .mobile-menu .mobile-menu__sublist a {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-base);
    font-weight: 400;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .site-header__nav,
    .site-header__actions {
      display: none;
    }

    .site-header__menu-toggle {
      display: flex;
    }

    /* Hide the desktop chevron + panel on mobile; mobile menu shows sublist inline. */
    .dropdown-toggle,
    .dropdown-panel {
      display: none;
    }
  }
</style>
