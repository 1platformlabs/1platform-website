---
import Icon from '@components/Icon.astro';

interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
---

<div class="share">
  <span class="eyebrow share__label">Share</span>
  <div class="share__buttons">
    {/*
      The two marks below stay inline rather than moving into icons.ts: they
      are third-party brand glyphs, solid-filled and drawn to their owners'
      specs, so they cannot be redrawn in the 24x24 1.5-stroke language the
      icon set is. Everything that IS ours comes from Icon.astro.
    */}
    <a
      href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on X (Twitter)"
      class="share__btn"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>
    <a
      href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on LinkedIn"
      class="share__btn"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>
    <button type="button" class="share__btn" aria-label="Copy link" data-copy-url={url}>
      <Icon name="link" size={18} />
    </button>
  </div>
  <span class="share__status" role="status" aria-live="polite"></span>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('[data-copy-url]').forEach((node) => {
      const btn = node instanceof HTMLElement ? node : null;
      if (!btn) return;

      btn.addEventListener('click', async () => {
        const url = btn.dataset.copyUrl || '';
        const status = btn.closest('.share')?.querySelector('.share__status');

        /** Announce the result, rather than only recolouring the button. */
        const announce = (message: string) => {
          if (status) status.textContent = message;
          btn.classList.add('share__btn--copied');
          setTimeout(() => {
            if (status) status.textContent = '';
            btn.classList.remove('share__btn--copied');
          }, 2000);
        };

        try {
          await navigator.clipboard.writeText(url);
          announce('Link copied');
        } catch {
          // Fallback for contexts where Clipboard API is unavailable
          const input = document.createElement('input');
          input.value = url;
          input.style.position = 'fixed';
          input.style.opacity = '0';
          document.body.appendChild(input);
          input.select();
          document.execCommand('copy');
          document.body.removeChild(input);
          announce('Link copied');
        }
      });
    });
  });
</script>

<style>
  .share {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .share__label {
    flex-shrink: 0;
  }

  .share__buttons {
    display: flex;
    gap: var(--space-2);
  }

  .share__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--border-radius);
    border: 1px solid var(--color-border);
    background: var(--color-bg-alt);
    color: var(--color-text-secondary);
    cursor: pointer;
  }

  @media (prefers-reduced-motion: no-preference) {
    .share__btn {
      transition: color var(--duration-fast) ease,
                  border-color var(--duration-fast) ease;
    }
  }

  .share__btn:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
  }

  .share__btn--copied {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .share__status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }
</style>
