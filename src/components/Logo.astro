---import { useI18n } from '@i18n';
const { t, l } = useI18n(Astro.url.pathname);


/**
 * Shared Logo component — single source of truth for 1Platform branding.
 * Used in Header, Footer, and anywhere the brand logo appears.
 *
 * The "1" is set as a node: the same cobalt rounded square the interconnect
 * schematic uses for a capability. The wordmark and the motif are the same
 * drawing at two scales.
 */
interface Props {
  /** Accessible label for the logo link. */
  label?: string;
  /** Additional CSS class for the link. */
  class?: string;
}

const { label, class: className } = Astro.props;
const accessibleLabel = label ?? t('layout.logoLabel');
---

<a href={l('/')} class:list={['logo', className]} aria-label={accessibleLabel}>
  <span class="logo__mark" aria-hidden="true">1</span><span class="logo__text">Platform</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.36em;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    white-space: nowrap;
  }

  .logo__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.32em;
    height: 1.32em;
    border-radius: 0.26em;
    background: var(--cobalt);
    color: var(--surface);
    font-size: 0.82em;
    line-height: 1;
    /* Optical centring: the numeral's flag sits left of its own box. */
    padding-right: 0.04em;
  }

  .logo__text {
    color: var(--color-text);
  }
</style>
