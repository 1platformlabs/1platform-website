---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import CodeBlock from '@components/CodeBlock.astro';
import Card from '@components/Card.astro';
import ComparisonTable from '@components/ComparisonTable.astro';
import Icon from '@components/Icon.astro';
import type { IconName } from '@components/icons';
import { useI18n } from '@i18n';

const { t, l } = useI18n(Astro.url.pathname);

const title = t('compareCustomIntegration.title');
const description = t('compareCustomIntegration.description');

/**
 * The comparison, by what the work actually feels like on each side.
 *
 * The previous version of this page quoted API counts, delivery timescales and
 * a dollar figure for engineering effort, none of which anything on the site
 * could substantiate. What is true and checkable is the shape of the work, so
 * that is what is compared.
 */
const integrationRows = [
  {
    without: t('compareCustomIntegration.row1.without'),
    with_: t('compareCustomIntegration.row1.with'),
  },
  {
    without: t('compareCustomIntegration.row2.without'),
    with_: t('compareCustomIntegration.row2.with'),
  },
  {
    without: t('compareCustomIntegration.row3.without'),
    with_: t('compareCustomIntegration.row3.with'),
  },
  {
    without: t('compareCustomIntegration.row4.without'),
    with_: t('compareCustomIntegration.row4.with'),
  },
  {
    without: t('compareCustomIntegration.row5.without'),
    with_: t('compareCustomIntegration.row5.with'),
  },
  {
    without: t('compareCustomIntegration.row6.without'),
    with_: t('compareCustomIntegration.row6.with'),
  },
];

const costs: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'clock',
    title: t('compareCustomIntegration.costs.item1.title'),
    description: t('compareCustomIntegration.costs.item1.description'),
  },
  {
    icon: 'settings',
    title: t('compareCustomIntegration.costs.item2.title'),
    description: t('compareCustomIntegration.costs.item2.description'),
  },
  {
    icon: 'launch',
    title: t('compareCustomIntegration.costs.item3.title'),
    description: t('compareCustomIntegration.costs.item3.description'),
  },
];

/**
 * Every capability, on one base URL and one auth model.
 *
 * `path` is the literal API route shown in <code> — a technical identifier,
 * not prose, so it is not translated; only the group name and item label are.
 */
const surface: { group: string; items: { path: string; label: string }[] }[] = [
  {
    group: t('compareCustomIntegration.surface.group1.name'),
    items: [
      { path: '/posts/keywords/', label: t('compareCustomIntegration.surface.group1.item1') },
      { path: '/posts/content/', label: t('compareCustomIntegration.surface.group1.item2') },
      { path: '/users/generations/images', label: t('compareCustomIntegration.surface.group1.item3') },
      { path: '/posts/indexing/', label: t('compareCustomIntegration.surface.group1.item4') },
      { path: '/users/websites/{id}/...', label: t('compareCustomIntegration.surface.group1.item5') },
    ],
  },
  {
    group: t('compareCustomIntegration.surface.group2.name'),
    items: [
      { path: '/users/transactions', label: t('compareCustomIntegration.surface.group2.item1') },
      { path: '/businesses/{id}/invoices', label: t('compareCustomIntegration.surface.group2.item2') },
    ],
  },
];

const faqItems = [
  {
    question: t('compareCustomIntegration.faq.item1.question'),
    answer: t('compareCustomIntegration.faq.item1.answer'),
  },
  {
    question: t('compareCustomIntegration.faq.item2.question'),
    answer: t('compareCustomIntegration.faq.item2.answer'),
  },
  {
    question: t('compareCustomIntegration.faq.item3.question'),
    answer: t('compareCustomIntegration.faq.item3.answer'),
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

// Technical demonstration code — not prose, so it is not run through t() in
// either tree.
const apiExample = `curl -X POST https://api.1platform.pro/api/v1/posts/content/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "keyword": "saas landing page best practices",
    "lang": "en",
    "country": "us"
  }'`;
---

<BaseLayout title={title} description={description} jsonLd={faqJsonLd}>
  <Hero
    badge={t('compareCustomIntegration.hero.badge')}
    headline={t('compareCustomIntegration.hero.headline')}
    subheadline={t('compareCustomIntegration.hero.subheadline')}
    primaryCta={{ label: t('cta.getStarted'), href: 'https://app.1platform.pro/app/' }}
    secondaryCta={{ label: t('compareCustomIntegration.hero.secondaryCta'), href: l('/pricing/') }}
  />

  <!-- The comparison, by shape of work rather than by invented counts -->
  <section class="section">
    <div class="container">
      <Breadcrumb
        items={[
          { label: t('breadcrumb.home'), href: l('/') },
          { label: t('compareCustomIntegration.breadcrumb.compare') },
          { label: t('compareCustomIntegration.breadcrumb.current') },
        ]}
      />

      <div class="section__rule">
        <p class="eyebrow">{t('compareCustomIntegration.compare.eyebrow')}</p>
      </div>
      <h2 class="section__lead">{t('compareCustomIntegration.compare.lead')}</h2>

      <ComparisonTable rows={integrationRows} />
    </div>
  </section>

  <!-- What "building it yourself" actually costs, stated honestly -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">{t('compareCustomIntegration.costs.eyebrow')}</p>
      </div>

      <div class="costs">
        {costs.map((cost) => (
          <Card
            variant="bare"
            icon={cost.icon}
            title={cost.title}
            description={cost.description}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- One surface: the call, and the map of everything reachable from it -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split__copy">
          <p class="eyebrow">{t('compareCustomIntegration.integrate.eyebrow')}</p>
          <h2>{t('compareCustomIntegration.integrate.heading')}</h2>
          <p>
            {t('compareCustomIntegration.integrate.body')}
          </p>
          <a href="https://developer.1platform.pro/" class="link-cue">
            {t('compareCustomIntegration.integrate.linkCue')}
            <Icon name="arrow-right" size={15} />
          </a>
        </div>

        <div class="split__demo">
          <CodeBlock
            language="bash"
            title={t('compareCustomIntegration.integrate.codeTitle')}
            code={apiExample}
          />
        </div>
      </div>

      <div class="surface">
        <p class="surface__note">
          {t('compareCustomIntegration.surface.noteBefore')}
          <code>https://api.1platform.pro/api/v1</code>.
        </p>

        <div class="surface__groups">
          {surface.map((group) => (
            <div>
              <h3 class="surface__group">{group.group}</h3>
              <ul class="surface__list">
                {group.items.map((item) => (
                  <li class="surface__row">
                    <code class="surface__path">{item.path}</code>
                    <span class="surface__label">{item.label}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Questions -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">{t('compareCustomIntegration.faq.eyebrow')}</p>
      </div>

      <div class="qa">
        {faqItems.map((item) => (
          <div class="qa__item">
            <h2 class="qa__q">{item.question}</h2>
            <p class="qa__a">{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sideways links; the closing CTA lives in the footer on every page -->
  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">{t('compareCustomIntegration.more.eyebrow')}</p>
      </div>

      <div class="more">
        <Card
          headingLevel={2}
          title={t('compareCustomIntegration.more.card1.title')}
          description={t('compareCustomIntegration.more.card1.description')}
          href={l('/compare/1platform-vs-ai-writing-tools/')}
        />
        <Card
          headingLevel={2}
          title={t('compareCustomIntegration.more.card2.title')}
          description={t('compareCustomIntegration.more.card2.description')}
          href={l('/compare/1platform-vs-wp-auto-pro/')}
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-10);
  }

  /* ===== Cost of building it yourself ===== */
  .costs {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-10) var(--space-12);
  }

  /* ===== Split: copy + code ===== */
  .split {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
    gap: var(--space-12);
    align-items: center;
  }

  .split__copy h2 {
    margin-block: var(--space-4);
  }

  .split__copy p {
    margin-bottom: var(--space-6);
  }

  /* Long code lines would otherwise widen the whole grid past the viewport. */
  .split__demo {
    min-width: 0;
  }

  .link-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .link-cue:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* ===== The API surface, as an index rather than as code comments ===== */
  .surface {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .surface__note {
    font-size: var(--text-sm);
    margin-bottom: var(--space-8);
  }

  .surface__note code {
    font-size: var(--text-xs);
    color: var(--color-text);
    background: var(--color-bg-muted);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .surface__groups {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-10);
  }

  .surface__group {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .surface__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-4);
    align-items: baseline;
    padding-block: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .surface__list > .surface__row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .surface__path {
    font-size: var(--text-xs);
    color: var(--color-accent);
    overflow-wrap: anywhere;
  }

  .surface__label {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  /* ===== Questions ===== */
  .qa {
    display: grid;
    max-width: 46rem;
  }

  .qa__item {
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .qa__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .qa__q {
    font-size: var(--text-lg);
    font-weight: 500;
    margin-bottom: var(--space-3);
  }

  .qa__a {
    font-size: var(--text-sm);
    line-height: 1.7;
    margin: 0;
  }

  /* ===== More comparisons ===== */
  .more {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 900px) {
    .split {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .costs {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    /* Path + label side by side inside two columns is too tight below this. */
    .surface__groups {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .more {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .surface__row {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
