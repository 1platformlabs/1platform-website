---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import Icon from '@components/Icon.astro';
import ProcessSpine from '@components/ProcessSpine.astro';
import CodeBlock from '@components/CodeBlock.astro';
import type { IconName } from '@components/icons';
import { useI18n } from '@i18n';

const { t, l } = useI18n(Astro.url.pathname);

const title = t('solutions-whitelabel.title');
const description = t('solutions-whitelabel.description');

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: t('nav.solutions.whitelabel'),
    provider: { '@type': 'Organization', name: '1Platform Labs', url: 'https://1platform.pro' },
    description,
    url: new URL(l('/solutions/whitelabel/'), Astro.site).toString(),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t('breadcrumb.home'), item: new URL(l('/'), Astro.site).toString() },
      { '@type': 'ListItem', position: 2, name: t('nav.solutions'), item: new URL(l('/solutions/'), Astro.site).toString() },
      { '@type': 'ListItem', position: 3, name: t('solutions-whitelabel.breadcrumb.whitelabel') },
    ],
  },
];

/**
 * What the bootstrap response actually resolves, as a spec rather than four
 * feature tiles.
 *
 * The last row used to assert production readiness by gesturing at an
 * unnamed, uncountable set of existing customers — traction a reader has no
 * way to check. It now states the one thing that is verifiable: the 1Platform
 * dashboard is itself a consumer of this contract.
 */
const spec = [
  {
    term: t('solutions-whitelabel.spec.branding.term'),
    detail: t('solutions-whitelabel.spec.branding.detail'),
  },
  {
    term: t('solutions-whitelabel.spec.localization.term'),
    detail: t('solutions-whitelabel.spec.localization.detail'),
  },
  {
    term: t('solutions-whitelabel.spec.kpis.term'),
    detail: t('solutions-whitelabel.spec.kpis.detail'),
  },
  {
    term: t('solutions-whitelabel.spec.contract.term'),
    detail: t('solutions-whitelabel.spec.contract.detail'),
  },
];

const whitelabelSteps = [
  { label: t('solutions-whitelabel.step.configureTenant') },
  { label: t('solutions-whitelabel.step.setBranding') },
  { label: t('solutions-whitelabel.step.bootstrap') },
  { label: t('solutions-whitelabel.step.launch') },
];

const related: { icon: IconName; title: string; description: string; href: string }[] = [
  {
    icon: 'code',
    title: t('solutions-whitelabel.related.developers.title'),
    description: t('solutions-whitelabel.related.developers.desc'),
    href: l('/for-developers/'),
  },
  {
    icon: 'users',
    title: t('solutions-whitelabel.related.agencies.title'),
    description: t('solutions-whitelabel.related.agencies.desc'),
    href: l('/for-agencies/'),
  },
  {
    icon: 'card',
    title: t('nav.solutions.payments'),
    description: t('solutions-whitelabel.related.payments.desc'),
    href: l('/payments-invoicing/'),
  },
];
---

<BaseLayout title={title} description={description} ogImage="/og/solution-whitelabel.png" jsonLd={jsonLd}>
  <div class="page-top">
    <div class="container">
      <Breadcrumb items={[
        { label: t('breadcrumb.home'), href: l('/') },
        { label: t('nav.solutions'), href: l('/solutions/') },
        { label: t('solutions-whitelabel.breadcrumb.whitelabel') },
      ]} />
    </div>
  </div>

  <Hero
    headline={t('solutions-whitelabel.hero.headline')}
    subheadline={t('solutions-whitelabel.hero.subheadline')}
    badge={t('nav.solutions.whitelabel')}
    primaryCta={{ label: t('solutions-whitelabel.hero.cta.primary'), href: l('/contact/?topic=whitelabel') }}
    secondaryCta={{ label: t('solutions-whitelabel.hero.cta.secondary'), href: 'https://developer.1platform.pro/' }}
  />

  <!-- The subject of the page is one request, so it opens with the request -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split__copy reveal">
          <p class="eyebrow">{t('solutions-whitelabel.bootstrap.eyebrow')}</p>
          <h2>{t('solutions-whitelabel.bootstrap.title')}</h2>
          <p>
            {t('solutions-whitelabel.bootstrap.desc')}
          </p>
          <a href="https://developer.1platform.pro/" class="link-cue">
            {t('solutions-whitelabel.bootstrap.linkCue')}
            <Icon name="arrow-right" size={15} />
          </a>
        </div>

        <div class="split__demo">
          <CodeBlock
            language="bash"
            title={t('solutions-whitelabel.bootstrap.codeTitle')}
            code={`curl -X GET https://api.1platform.pro/api/v1/dashboard/bootstrap \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN"`}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- What the response resolves, read as a spec -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">{t('solutions-whitelabel.whatYouGet.eyebrow')}</p>
      </div>
      <h2 class="section__lead">{t('solutions-whitelabel.whatYouGet.lead')}</h2>

      <dl class="spec">
        {spec.map((row) => (
          <div class="spec__row">
            <dt class="spec__term">{row.term}</dt>
            <dd class="spec__detail">{row.detail}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">{t('solutions-whitelabel.howItWorks.eyebrow')}</p>
      </div>
      <h2 class="section__lead">
        {t('solutions-whitelabel.howItWorks.lead')}
      </h2>
      <ProcessSpine steps={whitelabelSteps} label={t('solutions-whitelabel.howItWorks.aria')} />
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">{t('solutions-whitelabel.related.eyebrow')}</p>
      </div>
      <h2 class="section__lead">{t('solutions-whitelabel.related.lead')}</h2>
      <div class="related">
        {related.map((item) => (
          <Card
            icon={item.icon}
            title={item.title}
            description={item.description}
            href={item.href}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Page-specific next step. The general closing CTA lives in the footer. -->
  <section class="section">
    <div class="container">
      <div class="next reveal">
        <div>
          <p class="eyebrow">{t('solutions-whitelabel.next.eyebrow')}</p>
          <h2 class="next__title">{t('solutions-whitelabel.next.title')}</h2>
          <p class="next__desc">
            {t('solutions-whitelabel.next.desc')}
          </p>
        </div>
        <div class="next__actions">
          <a href={l('/contact/?topic=whitelabel')} class="btn btn--primary">{t('solutions-whitelabel.hero.cta.primary')}</a>
          <a href="https://developer.1platform.pro/" class="btn btn--ghost">{t('solutions-whitelabel.hero.cta.secondary')}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* The hero carries its own header offset, so it is neutralised below the
     breadcrumb strip to avoid stacking two header heights of space. */
  .page-top {
    padding-top: calc(var(--header-height) + var(--space-8));
  }

  .page-top + :global(.hero) {
    padding-top: var(--space-6);
  }

  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-10);
  }

  /* ===== Split: the claim and the request that backs it ===== */
  .split {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
    gap: var(--space-12);
    align-items: center;
  }

  .split__copy h2 {
    margin-block: var(--space-4);
  }

  .split__copy p {
    margin: 0;
  }

  /* Long code lines would otherwise widen the whole page. */
  .split__demo {
    min-width: 0;
  }

  /* ===== Spec list: mono term, prose detail, on hairlines ===== */
  .spec {
    margin: 0;
    max-width: 60rem;
  }

  .spec__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: var(--space-8);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .spec__row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .spec__term {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
  }

  .spec__detail {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
    min-width: 0;
  }

  /* ===== Related ===== */
  .related {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .link-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    min-height: 44px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .link-cue:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* ===== Closing band ===== */
  .next {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .next__title {
    font-size: var(--text-3xl);
    margin-block: var(--space-4);
  }

  .next__desc {
    max-width: 34rem;
    margin: 0;
  }

  .next__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .split {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .related {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .spec__row {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .related {
      grid-template-columns: 1fr;
    }
  }
</style>
