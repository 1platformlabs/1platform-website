---
import BaseLayout from '@layouts/BaseLayout.astro';
import Icon from '@components/Icon.astro';
import { useI18n } from '@i18n';
import type { IconName } from '@components/icons';

const { t, l } = useI18n(Astro.url.pathname);

const title = t('notFound.title');
const description = t('notFound.description');

const destinations: { icon: IconName; label: string; detail: string; href: string }[] = [
  { icon: 'home', label: t('breadcrumb.home'), detail: t('notFound.destination.home.detail'), href: l('/') },
  { icon: 'layers', label: t('nav.solutions'), detail: t('notFound.destination.solutions.detail'), href: l('/solutions/') },
  { icon: 'logs', label: t('nav.docs'), detail: t('notFound.destination.docs.detail'), href: 'https://developer.1platform.pro/' },
  { icon: 'content', label: t('nav.blog'), detail: t('notFound.destination.blog.detail'), href: l('/blog/') },
];
---

<!--
  No language alternates, deliberately.

  The origin never serves this file as its error document — ErrorDocument lives
  in an .htaccess the deploy excludes on purpose — so there is no Spanish twin
  to declare, and the English "alternate" would have pointed at /404/, which
  does not resolve either (the file is served at /404.html, if at all). A page
  nobody can navigate to should not be making claims to a crawler about what
  exists in which language.
-->
<BaseLayout title={title} description={description} alternates={{}}>
  <section class="error">
    <div class="container error__inner">
      <div class="error__copy">
        <p class="eyebrow error__status">{t('notFound.status')}</p>
        <h1 class="error__headline">{t('notFound.headline')}</h1>
        <p class="error__message">{t('notFound.message')}</p>
        <a href={l('/')} class="btn btn--primary error__cta">{t('notFound.cta')}</a>
      </div>

      <nav class="error__nav" aria-labelledby="error-nav-title">
        <h2 class="eyebrow" id="error-nav-title">{t('notFound.tryTheseHeading')}</h2>
        <ul class="destinations">
          {destinations.map((destination) => (
            <li>
              <a href={destination.href} class="destination">
                <span class="destination__icon"><Icon name={destination.icon} size={20} /></span>
                <span class="destination__body">
                  <span class="destination__label">{destination.label}</span>
                  <span class="destination__detail">{destination.detail}</span>
                </span>
                <span class="destination__cue" aria-hidden="true">
                  <Icon name="arrow-right" size={16} />
                </span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .error {
    display: flex;
    align-items: center;
    min-height: calc(100vh - var(--header-height));
    padding-block: var(--space-20);
  }

  /* Two columns: the explanation, then the way out. The old page stacked a
     giant gradient numeral over a centred row of pills on a dot grid. */
  .error__inner {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: var(--space-16);
    align-items: start;
  }

  /* The status code belongs to the same mono register as the rest of the
     system's labels — it is data, not decoration. */
  .error__status {
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
    display: block;
  }

  .error__headline {
    font-size: var(--text-5xl);
    line-height: 1.06;
    margin: var(--space-8) 0 var(--space-5);
  }

  .error__message {
    color: var(--color-text-secondary);
    max-width: 34rem;
    margin: 0 0 var(--space-8);
  }

  .error__cta {
    min-height: 44px;
  }

  .destinations {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0 0;
  }

  .destination {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-4);
    min-height: 44px;
    padding-block: var(--space-5);
    border-top: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .destinations li:last-child .destination {
    border-bottom: 1px solid var(--color-border);
  }

  .destination__icon {
    display: inline-flex;
    color: var(--color-accent);
  }

  .destination__body {
    display: grid;
    gap: 2px;
  }

  .destination__label {
    font-weight: 600;
  }

  .destination__detail {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .destination__cue {
    display: inline-flex;
    color: var(--color-text-tertiary);
  }

  .destination:hover .destination__label {
    color: var(--color-accent);
  }

  .destination:hover .destination__cue {
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .destination__cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .destination:hover .destination__cue :global(svg) {
      transform: translateX(3px);
    }
  }

  @media (max-width: 900px) {
    .error {
      min-height: 0;
      padding-block: var(--space-16);
    }

    .error__inner {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }
  }
</style>
