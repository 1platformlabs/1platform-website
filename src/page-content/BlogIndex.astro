---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import BlogPostCard from '@components/BlogPostCard.astro';
import Icon from '@components/Icon.astro';
import { useI18n } from '@i18n';
import { bareSlug, getLocalized } from '@i18n/collections';

const { t, l, locale } = useI18n(Astro.url.pathname);

// Filtered by locale: an unfiltered read here is what would have put English
// posts on the Spanish index.
const posts = await getLocalized('blog', locale);

/**
 * Category routes exist and were reachable from nothing. Counts are derived
 * from the collection, so the rail can never disagree with the archive.
 * Labels come from the catalogue — the same six were copied into four files.
 */
const categories = [...new Set(posts.map((post) => post.data.category))]
  .map((slug) => ({
    slug,
    label: t(`blog.category.${slug}`),
    count: posts.filter((post) => post.data.category === slug).length,
  }))
  .sort((a, b) => b.count - a.count || a.label.localeCompare(b.label));

const [lead, ...archive] = posts;
---

<BaseLayout title={t('blog.title')} description={t('blog.description')}>
  <section class="section">
    <div class="container">
      <Breadcrumb items={[
        { label: t('breadcrumb.home'), href: l('/') },
        { label: t('blog.h1') },
      ]} />

      <header class="masthead">
        <p class="eyebrow">{t('blog.eyebrow')}</p>
        <h1>{t('blog.h1')}</h1>
        <p class="masthead__lede">{t('blog.lede')}</p>
        <a href={l('/rss.xml')} class="masthead__feed">
          <Icon name="rss" size={15} />
          {t('blog.subscribe')}
        </a>
      </header>

      {categories.length > 0 && (
        <nav class="topics" aria-label={t('blog.topicsAria')}>
          <span class="eyebrow topics__label">{t('blog.topics')}</span>
          <ul class="topics__list">
            {categories.map((category) => (
              <li>
                <a href={l(`/blog/category/${category.slug}/`)} class="topics__link">
                  {category.label}
                  <span class="topics__count">{category.count}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      {lead && (
        <div class="lead-slot">
          <div class="section__rule">
            <h2 class="eyebrow">{t('blog.latest')}</h2>
          </div>
          <BlogPostCard
            variant="lead"
            title={lead.data.title}
            description={lead.data.description}
            pubDate={lead.data.pubDate}
            category={lead.data.category}
            slug={bareSlug(lead.slug)}
            author={lead.data.author}
            readingTime={lead.data.readingTime}
            class="reveal"
          />
        </div>
      )}

      {archive.length > 0 && (
        <div class="archive">
          <div class="section__rule">
            <h2 class="eyebrow">{t('blog.archive')}</h2>
          </div>
          <div class="archive__list">
            {archive.map((post) => (
              <BlogPostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                category={post.data.category}
                slug={bareSlug(post.slug)}
                author={post.data.author}
                readingTime={post.data.readingTime}
                class="reveal"
              />
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .masthead {
    max-width: 40rem;
    margin-bottom: var(--space-10);
  }

  .masthead h1 {
    margin-top: var(--space-4);
    margin-bottom: var(--space-5);
  }

  .masthead__lede {
    font-size: var(--text-lg);
    line-height: 1.6;
  }

  .masthead__feed {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 44px;
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  /* Topics sit on their own hairline band: navigation, not decoration. */
  .topics {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-4) var(--space-6);
    padding-block: var(--space-5);
    border-block: 1px solid var(--color-border);
    margin-bottom: var(--space-16);
  }

  .topics__label {
    flex-shrink: 0;
  }

  .topics__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-5);
  }

  .topics__link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    min-height: 44px;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .topics__link:hover {
    color: var(--color-accent);
  }

  .topics__count {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-variant-numeric: tabular-nums;
  }

  .lead-slot {
    margin-bottom: var(--space-16);
  }

  .archive__list {
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .topics {
      margin-bottom: var(--space-10);
    }

    .lead-slot {
      margin-bottom: var(--space-10);
    }
  }
</style>
