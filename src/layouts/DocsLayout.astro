---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    section: string;
  };
}

const { frontmatter } = Astro.props;

const sidebarSections = [
  {
    title: 'Getting Started',
    items: [
      { label: 'Introduction', href: '/docs/getting-started/' },
      { label: 'Authentication', href: '/docs/authentication/' },
    ],
  },
  {
    title: 'API Reference',
    items: [
      { label: 'API Reference', href: '/docs/api-reference/' },
      { label: 'Code Examples', href: '/docs/code-examples/' },
    ],
  },
  {
    title: 'Advanced',
    items: [
      { label: 'Webhooks', href: '/docs/webhooks/' },
      { label: 'Error Handling', href: '/docs/errors/' },
    ],
  },
];

const techArticleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: frontmatter.title,
  description: frontmatter.description,
  publisher: {
    '@type': 'Organization',
    name: '1Platform',
  },
};
---

<BaseLayout
  title={`${frontmatter.title} | 1Platform Docs`}
  description={frontmatter.description}
  jsonLd={techArticleJsonLd}
>
  <div class="docs section">
    <div class="docs__container">
      <aside class="docs__sidebar">
        <nav aria-label="Documentation">
          {sidebarSections.map((section) => (
            <div class="docs__nav-section">
              <h3>{section.title}</h3>
              <ul>
                {section.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[{ 'is-active': Astro.url.pathname.includes(item.href) }]}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <article class="docs__content">
        <Breadcrumb items={[
          { label: 'Home', href: '/' },
          { label: 'Docs', href: '/docs/' },
          { label: frontmatter.title },
        ]} />

        <h1>{frontmatter.title}</h1>
        <div class="prose">
          <slot />
        </div>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .docs__container {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-6);
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .docs__sidebar {
    position: sticky;
    top: calc(var(--header-height) + var(--space-8));
    padding-right: var(--space-6);
    border-right: 1px solid var(--color-border);
  }

  .docs__nav-section {
    margin-bottom: var(--space-6);
  }

  .docs__nav-section h3 {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-3);
  }

  .docs__nav-section ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .docs__nav-section a {
    display: block;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--border-radius);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .docs__nav-section a:hover {
    color: var(--color-text);
    background: var(--color-bg-alt);
  }

  .docs__nav-section a.is-active {
    color: var(--color-accent);
    background: var(--color-accent-glow);
  }

  .docs__content h1 {
    margin-top: var(--space-6);
    margin-bottom: var(--space-8);
  }

  @media (max-width: 768px) {
    .docs__container {
      grid-template-columns: 1fr;
    }

    .docs__sidebar {
      position: static;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      padding-right: 0;
      padding-bottom: var(--space-6);
    }
  }
</style>
