---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import Icon from '@components/Icon.astro';
import ComparisonTable from '@components/ComparisonTable.astro';
import type { IconName } from '@components/icons';

const title = 'About 1Platform Labs — One Platform for Online Business';
const description = 'Learn about 1Platform Labs and our mission to make online stores, websites, payments, AI content, and a developer-grade API available from a single platform.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: title,
  description,
  url: 'https://1platform.pro/about/',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'About' },
    ],
  },
};

/**
 * What a fragmented stack costs, stated as experience rather than as an
 * invented dollar figure. Each row is the same claim the old two-column
 * "problem card" made — now rendered by the shared comparison, so the ticks
 * come from Check.astro instead of escaped entity glyphs.
 */
const fragmentation = [
  {
    without: 'A separate service to subscribe to, log into and renew',
    with_: 'One platform, one token pair, one dashboard',
  },
  {
    without: 'Data exported and re-imported by hand between tools',
    with_: 'Data moves between capabilities automatically',
  },
  {
    without: 'A different API, auth model and error format to learn per tool',
    with_: 'One REST API with a single reference',
  },
  {
    without: 'Billing and cost tracking scattered across vendors',
    with_: 'A single bill for everything you use',
  },
  {
    without: 'No single view of how the business is actually doing',
    with_: 'End-to-end visibility in one place',
  },
];

/**
 * The capability set, grouped rather than tiled. Seventeen identical icon
 * cards in a 3-up grid said nothing about how the capabilities relate; the
 * grouping does.
 */
const capabilityGroups: { group: string; items: { label: string; icon: IconName }[] }[] = [
  {
    group: 'Content & SEO',
    items: [
      { label: 'AI Content', icon: 'content' },
      { label: 'Keywords', icon: 'keyword' },
      { label: 'Images', icon: 'image' },
      { label: 'Comments', icon: 'message' },
      { label: 'Legal Pages', icon: 'shield' },
      { label: 'CMS Publishing', icon: 'cms' },
      { label: 'Indexing', icon: 'indexing' },
      { label: 'Link Building', icon: 'link' },
      { label: 'Search Console', icon: 'globe-check' },
    ],
  },
  {
    group: 'Commerce',
    items: [
      { label: 'Payments', icon: 'card' },
      { label: 'Invoicing', icon: 'invoice' },
    ],
  },
  {
    group: 'Site & audience',
    items: [
      { label: 'Website Management', icon: 'monitor' },
      { label: 'Profiles', icon: 'user' },
      { label: 'Analytics', icon: 'chart' },
      { label: 'Ad Revenue', icon: 'wallet' },
    ],
  },
  {
    group: 'Developer platform',
    items: [
      { label: 'AI Agents', icon: 'agent' },
      { label: 'Activity Logs', icon: 'logs' },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="container crumbs">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'About' },
    ]} />
  </div>

  <Hero
    headline="About 1Platform Labs"
    subheadline="We build one platform for selling, growing and integrating online — instead of stitching separate services together and calling it a stack."
    badge="Company"
    primaryCta={{ label: 'Get Started Free', href: 'https://app.1platform.pro/app/' }}
    secondaryCta={{ label: 'View Solutions', href: '/solutions/' }}
  />

  <!-- Mission: a labelled rail against the prose, not a centred column -->
  <section class="section">
    <div class="container">
      <div class="rail reveal">
        <div class="rail__label">
          <p class="eyebrow">Our mission</p>
        </div>
        <div class="rail__body">
          <h2 class="rail__lead">One Platform. Every Solution.</h2>
          <p>
            1Platform Labs was founded on a simple observation: businesses spend more time
            managing their tools than using them. Running a modern online business usually
            means juggling a storefront, a payment processor, an invoicing system, a website
            builder, a content platform and a separate developer API — each with its own
            login, billing, data format and learning curve.
          </p>
          <p>
            We set out to build something different. A single platform that brings online
            stores, websites, AI content, whitelabel dashboards, payments, electronic
            invoicing and a developer-grade REST API into one connected system. From the
            first product you sell to the last invoice you issue, every capability works
            through the same API.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- The problem, compared by experience -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">The fragmentation tax</p>
      </div>
      <h2 class="section__lead">What a fragmented stack actually costs you</h2>
      <p class="section__note">
        Every disconnected tool in the stack takes time and attention. Data gets lost between
        services, workflows break at the integration points, and teams spend their days
        moving records by hand instead of doing the work.
      </p>
      <ComparisonTable rows={fragmentation} />
    </div>
  </section>

  <!-- What we build, grouped -->
  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">What we build</p>
      </div>
      <h2 class="section__lead">Every capability, reachable through one API</h2>

      <div class="capabilities reveal">
        {capabilityGroups.map((group) => (
          <div class="capabilities__group">
            <h3 class="capabilities__title">{group.group}</h3>
            <ul class="capabilities__list">
              {group.items.map((item) => (
                <li class="capabilities__item">
                  <span class="capabilities__icon"><Icon name={item.icon} size={18} /></span>
                  {item.label}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <p class="capabilities__docs">
        <a href="https://developer.1platform.pro/" class="link-cue">
          See how they are exposed in the API
          <Icon name="arrow-right" size={15} />
        </a>
      </p>
    </div>
  </section>

  <!-- Team -->
  <section class="section section--alt">
    <div class="container">
      <div class="rail reveal">
        <div class="rail__label">
          <p class="eyebrow">Our team</p>
        </div>
        <div class="rail__body">
          <h2 class="rail__lead">Built by engineers, for engineers</h2>
          <p>
            1Platform Labs is a team of engineers, designers and operators who got tired of
            the fragmentation problem. We build the platform we always wished existed:
            developer-first, API-native, and relentlessly focused on removing complexity
            rather than adding surface.
          </p>
          <p>
            We are committed to building tools that are accessible, affordable and powerful
            enough for any scale of operation.
          </p>
          <dl class="facts">
            <div class="facts__row">
              <dt>Based in</dt>
              <dd>Guatemala</dd>
            </div>
            <div class="facts__row">
              <dt>Serving</dt>
              <dd>Clients worldwide</dd>
            </div>
            <div class="facts__row">
              <dt>Languages</dt>
              <dd>Spanish · English</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>
  <!-- The closing CTA lives in the footer, on every page — see Footer.astro. -->
</BaseLayout>

<style>
  /* Breadcrumbs clear the fixed header; the hero then drops its own top
     offset so the two don't stack into a canyon of whitespace. */
  .crumbs {
    padding-top: calc(var(--header-height) + var(--space-8));
  }

  .crumbs + :global(.hero) {
    padding-top: var(--space-6);
  }

  /* ===== Labelled rail ===== */
  .rail {
    display: grid;
    grid-template-columns: minmax(0, 3fr) minmax(0, 8fr);
    gap: var(--space-12);
  }

  .rail__label {
    position: sticky;
    top: calc(var(--header-height) + var(--space-8));
    align-self: start;
    padding-top: var(--space-2);
  }

  .rail__body {
    max-width: 40rem;
  }

  .rail__lead {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-6);
  }

  .rail__body p {
    margin-bottom: var(--space-5);
    line-height: 1.75;
  }

  .rail__body p:last-of-type {
    margin-bottom: 0;
  }

  /* ===== Section openers ===== */
  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-6);
  }

  .section__note {
    max-width: 42rem;
    margin-bottom: var(--space-10);
  }

  /* ===== Capability index ===== */
  .capabilities {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-10) var(--space-8);
    align-items: start;
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .capabilities__title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .capabilities__list {
    display: grid;
    gap: var(--space-3);
  }

  .capabilities__item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .capabilities__icon {
    display: inline-flex;
    color: var(--color-accent);
  }

  .capabilities__docs {
    margin-top: var(--space-8);
  }

  .link-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .link-cue:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* ===== Facts ===== */
  .facts {
    margin-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .facts__row {
    display: grid;
    grid-template-columns: 10rem minmax(0, 1fr);
    gap: var(--space-4);
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .facts dt {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    align-self: center;
  }

  .facts dd {
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .capabilities {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .rail {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    .rail__label {
      position: static;
      padding-top: 0;
    }

    .facts__row {
      grid-template-columns: 8rem minmax(0, 1fr);
    }
  }

  @media (max-width: 480px) {
    .capabilities {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
