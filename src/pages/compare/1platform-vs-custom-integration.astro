---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import CodeBlock from '@components/CodeBlock.astro';
import Card from '@components/Card.astro';
import ComparisonTable from '@components/ComparisonTable.astro';
import Icon from '@components/Icon.astro';
import type { IconName } from '@components/icons';

const title = '1Platform vs. Building Your Own Integration | 1Platform';
const description =
  'Compare 1Platform with wiring up your own integration. One API, one auth model, one bill — instead of a separate service, SDK, and invoice for every capability.';

/**
 * The comparison, by what the work actually feels like on each side.
 *
 * The previous version of this page quoted API counts, delivery timescales and
 * a dollar figure for engineering effort, none of which anything on the site
 * could substantiate. What is true and checkable is the shape of the work, so
 * that is what is compared.
 */
const integrationRows = [
  {
    without: 'A separate service to choose, integrate and monitor for each capability',
    with_: 'One API surface covering every capability',
  },
  {
    without: 'A different auth scheme and token model per vendor',
    with_: 'One two-token model across every endpoint',
  },
  {
    without: 'A separate account, plan and renewal per vendor',
    with_: 'One account, one bill',
  },
  {
    without: 'A different error format and documentation set to learn per vendor',
    with_: 'One response envelope, one reference',
  },
  {
    without: 'Every upstream API change becomes your migration',
    with_: 'The contract you code against stays stable',
  },
  {
    without: 'Integration work stands between you and your first feature',
    with_: 'The first call ships the capability',
  },
];

const costs: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'clock',
    title: 'Development time',
    description:
      'Wiring up a store, payments, invoicing, content and a developer API yourself means learning a different vendor for each one — every documentation set, every authentication method, every error model — before any of it serves a customer.',
  },
  {
    icon: 'settings',
    title: 'Ongoing maintenance',
    description:
      'APIs change. Endpoints are deprecated, rate limits move, response formats are revised. With your own integrations, every upstream change becomes your problem. With 1Platform, the API contract stays stable while those changes are absorbed behind it.',
  },
  {
    icon: 'launch',
    title: 'Opportunity cost',
    description:
      'Every hour spent wiring services together is an hour not spent on your core product. 1Platform lets your team work on what differentiates the business while the platform holds the infrastructure layer.',
  },
];

/** Every capability, on one base URL and one auth model. */
const surface: { group: string; items: { path: string; label: string }[] }[] = [
  {
    group: 'Content & SEO',
    items: [
      { path: '/posts/keywords/', label: 'Keyword extraction' },
      { path: '/posts/content/', label: 'Article generation + CMS publish' },
      { path: '/users/generations/images', label: 'AI image generation' },
      { path: '/posts/indexing/', label: 'Submit URLs for indexing' },
      { path: '/users/websites/{id}/...', label: 'Link building + Search Console' },
    ],
  },
  {
    group: 'Money',
    items: [
      { path: '/users/transactions', label: 'Online payment processing' },
      { path: '/businesses/{id}/invoices', label: 'Electronic invoicing' },
    ],
  },
];

const faqItems = [
  {
    question: 'What does 1Platform save me compared with building the integration myself?',
    answer:
      'The integration layer itself. Building across the services 1Platform replaces — store, payments, invoicing, AI content, website, and developer APIs — means a separate integration, auth model, error model and bill for each one, plus the maintenance that follows. With 1Platform you integrate once and every service is already reachable through the same contract.',
  },
  {
    question: 'What happens if one of the underlying services changes?',
    answer:
      '1Platform handles all upstream service changes internally. Your integration stays stable because you only interact with the 1Platform API. When an upstream API is updated, the 1Platform team adapts the integration so you never have to.',
  },
  {
    question: 'Can I start with one service and add more later?',
    answer:
      'Yes. 1Platform is modular by design. Start with content generation today, add keyword research next, enable publishing when you are ready. Same API key, same auth, same billing. No new integrations required.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const apiExample = `curl -X POST https://api.1platform.pro/api/v1/posts/content/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "keyword": "saas landing page best practices",
    "lang": "en",
    "country": "us"
  }'`;
---

<BaseLayout title={title} description={description} jsonLd={faqJsonLd}>
  <Hero
    badge="Compare"
    headline="1Platform vs. building your own"
    subheadline="You can integrate a separate service for the store, the payments, the invoicing, the content and the publishing — and then maintain all of them. Or you can integrate once."
    primaryCta={{ label: 'Get Started Free', href: 'https://app.1platform.pro/app/' }}
    secondaryCta={{ label: 'See Pricing', href: '/pricing/' }}
  />

  <!-- The comparison, by shape of work rather than by invented counts -->
  <section class="section">
    <div class="container">
      <Breadcrumb
        items={[
          { label: 'Home', href: '/' },
          { label: 'Compare', href: '/compare/' },
          { label: '1Platform vs. Building Your Own' },
        ]}
      />

      <div class="section__rule">
        <p class="eyebrow">Two ways to get there</p>
      </div>
      <h2 class="section__lead">The same capabilities. A different amount of your work.</h2>

      <ComparisonTable rows={integrationRows} />
    </div>
  </section>

  <!-- What "building it yourself" actually costs, stated honestly -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">The real cost of building it yourself</p>
      </div>

      <div class="costs">
        {costs.map((cost) => (
          <Card
            variant="bare"
            icon={cost.icon}
            title={cost.title}
            description={cost.description}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- One surface: the call, and the map of everything reachable from it -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split__copy">
          <p class="eyebrow">One surface</p>
          <h2>Same base URL, same auth, same envelope</h2>
          <p>
            Every capability sits behind one integration. Swapping from generating content to
            issuing an invoice is a different path — not a different vendor, SDK, token or
            bill.
          </p>
          <a href="https://developer.1platform.pro/" class="link-cue">
            Read the API docs
            <Icon name="arrow-right" size={15} />
          </a>
        </div>

        <div class="split__demo">
          <CodeBlock
            language="bash"
            title="Generate an article"
            code={apiExample}
          />
        </div>
      </div>

      <div class="surface">
        <p class="surface__note">
          The same token pair reaches every path below, all on
          <code>https://api.1platform.pro/api/v1</code>.
        </p>

        <div class="surface__groups">
          {surface.map((group) => (
            <div>
              <h3 class="surface__group">{group.group}</h3>
              <ul class="surface__list">
                {group.items.map((item) => (
                  <li class="surface__row">
                    <code class="surface__path">{item.path}</code>
                    <span class="surface__label">{item.label}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Questions -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Questions</p>
      </div>

      <div class="qa">
        {faqItems.map((item) => (
          <div class="qa__item">
            <h2 class="qa__q">{item.question}</h2>
            <p class="qa__a">{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sideways links; the closing CTA lives in the footer on every page -->
  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">More comparisons</p>
      </div>

      <div class="more">
        <Card
          headingLevel={2}
          title="1Platform vs. AI writing tools"
          description="Where a writing tool stops, and what the rest of the content pipeline has to cover."
          href="/compare/1platform-vs-ai-writing-tools/"
        />
        <Card
          headingLevel={2}
          title="1Platform vs. WordPress content plugins"
          description="Where an automated content plugin ends and a framework-agnostic platform begins."
          href="/compare/1platform-vs-wp-auto-pro/"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-10);
  }

  /* ===== Cost of building it yourself ===== */
  .costs {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-10) var(--space-12);
  }

  /* ===== Split: copy + code ===== */
  .split {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
    gap: var(--space-12);
    align-items: center;
  }

  .split__copy h2 {
    margin-block: var(--space-4);
  }

  .split__copy p {
    margin-bottom: var(--space-6);
  }

  /* Long code lines would otherwise widen the whole grid past the viewport. */
  .split__demo {
    min-width: 0;
  }

  .link-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .link-cue:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* ===== The API surface, as an index rather than as code comments ===== */
  .surface {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .surface__note {
    font-size: var(--text-sm);
    margin-bottom: var(--space-8);
  }

  .surface__note code {
    font-size: var(--text-xs);
    color: var(--color-text);
    background: var(--color-bg-muted);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .surface__groups {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-10);
  }

  .surface__group {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .surface__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-4);
    align-items: baseline;
    padding-block: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .surface__list > .surface__row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .surface__path {
    font-size: var(--text-xs);
    color: var(--color-accent);
    overflow-wrap: anywhere;
  }

  .surface__label {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  /* ===== Questions ===== */
  .qa {
    display: grid;
    max-width: 46rem;
  }

  .qa__item {
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .qa__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .qa__q {
    font-size: var(--text-lg);
    font-weight: 500;
    margin-bottom: var(--space-3);
  }

  .qa__a {
    font-size: var(--text-sm);
    line-height: 1.7;
    margin: 0;
  }

  /* ===== More comparisons ===== */
  .more {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 900px) {
    .split {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .costs {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    /* Path + label side by side inside two columns is too tight below this. */
    .surface__groups {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .more {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .surface__row {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
