---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import CodeBlock from '@components/CodeBlock.astro';
import Card from '@components/Card.astro';
import Check from '@components/Check.astro';
import Icon from '@components/Icon.astro';
import type { IconName } from '@components/icons';

/**
 * This page compares 1Platform with the *category* of automated WordPress
 * content plugins, never with a named product. The route is unchanged so no
 * link breaks, but every mention — copy, headings, metadata and structured
 * data — describes the category.
 */
const title = '1Platform vs. WordPress Content Plugins: Platform vs. Plugin | 1Platform';
const description =
  'Compare 1Platform with automated WordPress content plugins. See why an API-first platform with a full pipeline, payments, invoicing, and link building goes further than a plugin that lives inside one CMS.';

const comparison: {
  group: string;
  note: string;
  rows: { capability: string; plugin: boolean }[];
}[] = [
  {
    group: 'Where they overlap',
    note: 'Both automate content work, and both can be driven programmatically.',
    rows: [
      { capability: 'API access', plugin: true },
      { capability: 'Multi-site support', plugin: true },
      { capability: 'Async processing', plugin: true },
    ],
  },
  {
    group: 'Where they diverge',
    note: 'A plugin runs inside one CMS; a platform sits in front of all of them.',
    rows: [
      { capability: 'Full automation pipeline', plugin: false },
      { capability: 'Payment processing', plugin: false },
      { capability: 'Electronic invoicing', plugin: false },
      { capability: 'Link building', plugin: false },
      { capability: 'Framework agnostic', plugin: false },
    ],
  },
];

const differentiators: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'indexing',
    title: 'Beyond content generation',
    description:
      'Automated content plugins focus on one job: creating WordPress content. 1Platform runs the whole pipeline — keyword research, AI content generation, image sourcing, CMS publishing, search engine indexing, link building, payment processing and electronic invoicing — connected through a single API.',
  },
  {
    icon: 'code',
    title: 'No vendor lock-in',
    description:
      'A plugin ties your automation to the WordPress ecosystem. 1Platform is a REST API that works with any stack: React, Vue, Astro, mobile apps, custom backends. Change framework without rewriting your automation logic.',
  },
  {
    icon: 'card',
    title: 'Built-in monetization',
    description:
      'Payment processing and electronic invoicing are part of the platform. Monetize the content pipeline without adding a payment gateway and a billing system to the stack — content creation through to revenue collection stays in one place.',
  },
];

const faqItems = [
  {
    question: 'Can I migrate from a WordPress content plugin to 1Platform?',
    answer:
      'Yes. 1Platform is API-first, so you can integrate it into an existing WordPress site or any other framework. Replace your plugin calls with 1Platform API endpoints and gain access to the full automation pipeline, including payments, invoicing, and link building.',
  },
  {
    question: 'Does 1Platform work only with WordPress?',
    answer:
      '1Platform is completely framework agnostic. It works with WordPress, Next.js, Astro, Nuxt, custom backends, mobile apps, and any platform that can make HTTP requests. Your stack, your choice.',
  },
  {
    question: 'How does 1Platform handle multi-site content?',
    answer:
      'With 1Platform, a single API account manages content across unlimited sites. Each site can have its own configuration, publishing schedule, and analytics. No separate plugin installation or licence per site.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const apiExample = `curl -X POST https://api.1platform.pro/api/v1/posts/content/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "keyword": "best project management tools",
    "lang": "en",
    "country": "us"
  }'`;
---

<BaseLayout title={title} description={description} jsonLd={faqJsonLd}>
  <Hero
    badge="Compare"
    headline="1Platform vs. WordPress content plugins"
    subheadline="A content plugin automates writing inside one CMS. An API-first platform runs the pipeline around it — research, publishing, indexing, and getting paid — from any stack you like."
    primaryCta={{ label: 'View API Docs', href: 'https://developer.1platform.pro/' }}
    secondaryCta={{ label: 'See Pricing', href: '/pricing/' }}
  />

  <!-- Feature comparison, split into what they share and what they don't -->
  <section class="section">
    <div class="container">
      <Breadcrumb
        items={[
          { label: 'Home', href: '/' },
          { label: 'Compare' },
          { label: '1Platform vs. WordPress Content Plugins' },
        ]}
      />

      <div class="section__rule">
        <p class="eyebrow">Feature by feature</p>
      </div>
      <h2 class="section__lead">The same starting point, a different ceiling.</h2>

      <div class="matrix-wrap">
        <table class="matrix">
          <caption class="sr-only">
            Capabilities covered by 1Platform compared with automated WordPress content
            plugins, split into shared capabilities and points of divergence.
          </caption>
          <thead>
            <tr>
              <th scope="col">Capability</th>
              <th scope="col" class="matrix__mark-col matrix__mark-col--us">1Platform</th>
              <th scope="col" class="matrix__mark-col">Content plugin</th>
            </tr>
          </thead>
          {comparison.map((group) => (
            <tbody>
              <tr class="matrix__group">
                <th scope="rowgroup" colspan="3">
                  {group.group}
                  <span class="matrix__note">{group.note}</span>
                </th>
              </tr>
              {group.rows.map((row) => (
                <tr>
                  <th scope="row">{row.capability}</th>
                  <td class="matrix__mark-col"><Check yes={true} /></td>
                  <td class="matrix__mark-col"><Check yes={row.plugin} /></td>
                </tr>
              ))}
            </tbody>
          ))}
        </table>
      </div>

      <p class="matrix__caveat">
        Compared against automated WordPress content plugins as a category — individual
        plugins differ in what they cover.
      </p>
    </div>
  </section>

  <!-- Why the difference matters, as an editorial list rather than a card grid -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Key differentiators</p>
      </div>

      <ul class="reasons">
        {differentiators.map((item) => (
          <li class="reasons__item reveal">
            <span class="reasons__icon"><Icon name={item.icon} size={20} /></span>
            <div>
              <h3 class="reasons__title">{item.title}</h3>
              <p class="reasons__desc">{item.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- One call, any stack -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split__copy">
          <p class="eyebrow">Integrate</p>
          <h2>One call, from whatever you build in</h2>
          <p>
            A single request generates optimized content, ready to publish anywhere. No
            install, no per-site licence, no CMS to be inside of — just an HTTP call your
            stack already knows how to make.
          </p>
          <a href="https://developer.1platform.pro/" class="link-cue">
            Read the API docs
            <Icon name="arrow-right" size={15} />
          </a>
        </div>

        <div class="split__demo">
          <CodeBlock
            language="bash"
            title="Generate content"
            code={apiExample}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Questions -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Questions</p>
      </div>

      <div class="qa">
        {faqItems.map((item) => (
          <div class="qa__item">
            <h2 class="qa__q">{item.question}</h2>
            <p class="qa__a">{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sideways links; the closing CTA lives in the footer on every page -->
  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">More comparisons</p>
      </div>

      <div class="more">
        <Card
          headingLevel={2}
          title="1Platform vs. AI writing tools"
          description="Where a writing tool stops, and what the rest of the content pipeline has to cover."
          href="/compare/1platform-vs-ai-writing-tools/"
        />
        <Card
          headingLevel={2}
          title="1Platform vs. building your own integration"
          description="What it takes to wire the same capabilities together yourself, and what stays your problem afterwards."
          href="/compare/1platform-vs-custom-integration/"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-10);
  }

  /* ===== Capability matrix =====
     A real table: the row and column headers are what make the marks readable
     to a screen reader, so they stay semantic rather than becoming divs. */
  .matrix-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    background: var(--color-bg-alt);
  }

  .matrix {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  .matrix th,
  .matrix td {
    padding: var(--space-4) var(--space-6);
    text-align: left;
    vertical-align: middle;
  }

  .matrix thead th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }

  /* The claim column reads in the accent; the other stays ink. */
  .matrix__mark-col--us {
    color: var(--color-accent);
  }

  .matrix tbody th,
  .matrix tbody td {
    border-top: 1px solid var(--color-border);
  }

  /* Group label, plus the one line that says what the group means. */
  .matrix__group th {
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--color-text);
    background: var(--color-bg-muted);
    padding-block: var(--space-3);
  }

  .matrix__note {
    display: block;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    margin-top: var(--space-1);
  }

  .matrix tbody th[scope='row'] {
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .matrix__mark-col {
    width: 1%;
    white-space: nowrap;
  }

  .matrix__caveat {
    max-width: 40rem;
    margin-top: var(--space-4);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  /* ===== Reasons: a bordered editorial list ===== */
  .reasons {
    display: grid;
    max-width: 52rem;
  }

  .reasons__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .reasons__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .reasons__icon {
    display: inline-flex;
    color: var(--color-accent);
    padding-top: 2px;
  }

  .reasons__title {
    margin-bottom: var(--space-2);
  }

  .reasons__desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    margin: 0;
  }

  /* ===== Split: copy + code ===== */
  .split {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
    gap: var(--space-12);
    align-items: center;
  }

  .split__copy h2 {
    margin-block: var(--space-4);
  }

  .split__copy p {
    margin-bottom: var(--space-6);
  }

  /* Long code lines would otherwise widen the whole grid past the viewport. */
  .split__demo {
    min-width: 0;
  }

  .link-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .link-cue:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* ===== Questions ===== */
  .qa {
    display: grid;
    max-width: 46rem;
  }

  .qa__item {
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .qa__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .qa__q {
    font-size: var(--text-lg);
    font-weight: 500;
    margin-bottom: var(--space-3);
  }

  .qa__a {
    font-size: var(--text-sm);
    line-height: 1.7;
    margin: 0;
  }

  /* ===== More comparisons ===== */
  .more {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 900px) {
    .split {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .more {
      grid-template-columns: 1fr;
    }

    .matrix th,
    .matrix td {
      padding: var(--space-3) var(--space-4);
    }
  }
</style>
