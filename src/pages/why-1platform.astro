---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import MetricCounter from '@components/MetricCounter.astro';

const title = 'Why 1Platform — Replace 18+ Tools With One Platform';
const description = 'Discover why 1Platform replaces fragmented SEO tools, content generators, publishing plugins, and separate payment integrations with a single unified platform.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: 'https://1platform.pro/why-1platform/',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Why 1Platform' },
    ],
  },
};

const pillars = [
  {
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    title: 'Unified Integration',
    description: 'Replace 18+ separate tools with one platform. Single account, single API key, single auth system, single billing — consistent response format across all solutions.',
    bullets: [
      'One API key replaces 18+ separate integrations',
      'Consistent JSON envelope responses across all endpoints',
      'Single billing account with credits-based usage',
      'All services interconnect: content feeds publishing, which triggers indexing',
    ],
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
    title: 'AI-Native Pipeline',
    description: 'Every step powered by AI — not just content generation. AI keyword analysis, AI content writing, AI image generation, AI website descriptions. Async job-based architecture designed for production scale.',
    bullets: [
      'AI keyword extraction with volume and intent analysis',
      'AI content generation with async job pipeline',
      'AI image generation and stock sourcing',
      'Multiple providers abstracted behind one unified API',
    ],
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: 'Developer Experience',
    description: 'Clean REST API with consistent patterns. Comprehensive documentation with code examples in Python, JavaScript, and cURL. Dual-token auth system for security.',
    bullets: [
      'Standard JSON envelope: { success, data, msg }',
      'Dual-token auth: App token + User token',
      'Rate limiting per category (health, auth, read, write, keywords, content)',
      'Interactive API docs at developer.1platform.pro',
    ],
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: 'Production-Ready',
    description: 'Async job processing for long-running operations. Credits-based billing so you pay for what you use. Multi-website management from one account.',
    bullets: [
      'Async content generation with job polling',
      'Credits-based billing — pay only for what you use',
      'Multi-website management from one account',
      'Webhook notifications for payment status updates',
    ],
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><circle cx="19" cy="5" r="2"/><circle cx="5" cy="5" r="2"/><circle cx="19" cy="19" r="2"/><circle cx="5" cy="19" r="2"/><line x1="12" y1="9" x2="12" y2="3"/><line x1="14.5" y1="10" x2="17.5" y2="6.5"/><line x1="9.5" y1="10" x2="6.5" y2="6.5"/><line x1="14.5" y1="14" x2="17.5" y2="17.5"/><line x1="9.5" y1="14" x2="6.5" y2="17.5"/></svg>`,
    title: 'Interconnected Ecosystem',
    description: 'All services work together. Extract keywords, generate an article, publish to CMS, submit for indexing, build backlinks, accept payments, generate invoice — all from one API.',
    bullets: [
      'Keywords feed content generation automatically',
      'Generated content publishes directly to your CMS',
      'Published content triggers indexing submission',
      'Payments generate certified electronic invoices',
      'One API, one account, one billing relationship',
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Why 1Platform' },
  ]} />

  <Hero
    headline="Why 1Platform?"
    subheadline="Replace fragmented SEO tools, content generators, publishing plugins, and separate payment integrations with one unified platform."
    badge="The Unified Advantage"
    primaryCta={{ label: 'Get Started Free', href: 'https://app.1platform.pro' }}
    secondaryCta={{ label: 'View Solutions', href: '/solutions/' }}
  />

  <!-- Pillars -->
  {pillars.map((pillar, index) => (
    <section class:list={['section', { 'section--alt': index % 2 === 1 }]}>
      <div class="container">
        <div class="pillar reveal">
          <div class="pillar__icon" set:html={pillar.icon} />
          <div class="pillar__content">
            <h2>{pillar.title}</h2>
            <p class="pillar__desc">{pillar.description}</p>
            <ul class="pillar__list">
              {pillar.bullets.map((bullet) => (
                <li>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Metrics -->
  <section class="section section--alt">
    <div class="container">
      <div class="metrics__header reveal">
        <h2>1Platform by the Numbers</h2>
        <p>One platform replacing an entire stack of disconnected tools.</p>
      </div>
      <div class="grid-4 metrics__grid">
        <MetricCounter value={10000} suffix="+" label="Articles Generated" />
        <MetricCounter value={18} suffix="+" label="Integrated Services" />
        <MetricCounter value={1} label="Unified API" />
        <MetricCounter value={2} label="Supported Languages" />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container cta-section reveal">
      <h2>Ready to Simplify Your Stack?</h2>
      <p>Automate your entire SEO pipeline — from keyword research to published, indexed, monetized content. Get started in minutes.</p>
      <div class="cta-section__actions">
        <a href="https://app.1platform.pro" class="btn btn--primary">Get Started Free</a>
        <a href="/docs/" class="btn btn--ghost">View API Docs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pillar {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-8);
    align-items: start;
    max-width: var(--max-width-narrow);
    margin-inline: auto;
  }

  .pillar__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: var(--border-radius-lg);
    background: var(--color-accent-glow);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .pillar__content h2 {
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .pillar__desc {
    margin-bottom: var(--space-6);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .pillar__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pillar__list li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text-secondary);
  }

  .pillar__list li svg {
    flex-shrink: 0;
  }

  .metrics__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .metrics__header h2 {
    margin-bottom: var(--space-4);
  }

  .metrics__grid {
    max-width: 900px;
    margin-inline: auto;
  }

  .cta-section {
    text-align: center;
    max-width: var(--max-width-narrow);
    margin-inline: auto;
  }

  .cta-section h2 {
    margin-bottom: var(--space-4);
  }

  .cta-section > p {
    margin-bottom: var(--space-8);
    color: var(--color-text-secondary);
  }

  .cta-section__actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .pillar {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .pillar__icon {
      margin-inline: auto;
    }

    .pillar__list {
      text-align: left;
    }
  }
</style>
