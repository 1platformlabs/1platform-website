---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import Icon from '@components/Icon.astro';
import CodeBlock from '@components/CodeBlock.astro';
import type { IconName } from '@components/icons';

const title = 'Features — Store, Payments, Content & Developer Platform | 1Platform';
const description = 'Every feature 1Platform offers: online store, payments, electronic invoicing, AI content, distribution, and a developer-grade API — all unified.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Features',
  description,
  url: 'https://1platform.pro/features/',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Features' },
    ],
  },
};

/** The page is long and anchored — give the reader a real table of contents. */
const contents: { label: string; href: string }[] = [
  { label: 'Ecommerce essentials', href: '#ecommerce' },
  { label: 'Content engine', href: '#content' },
  { label: 'Distribution & growth', href: '#distribution' },
  { label: 'Developer platform', href: '#developer' },
];

/** The monetization core — the four that have to work on day one. */
const commerce: { icon: IconName; title: string; description: string; href: string }[] = [
  {
    icon: 'cart',
    title: 'Online Store',
    description: 'Catalog, cart, and checkout — ready to publish on your own domain. No plugins, no patchwork.',
    href: '/solutions/online-store/',
  },
  {
    icon: 'card',
    title: 'Payment Processing',
    description: 'Accept card payments via API. Hosted checkout URLs, real-time webhooks, automatic balance crediting.',
    href: '/payments-invoicing/',
  },
  {
    icon: 'invoice',
    title: 'Electronic Invoicing',
    description: 'Generate compliant electronic invoices automatically from every transaction. PDF + XML output.',
    href: '/payments-invoicing/',
  },
  {
    icon: 'globe',
    title: 'Domain Management',
    description: 'Register, transfer, renew. Manage DNS records and nameservers — all programmatically.',
    href: '/solutions/website/',
  },
];

const contentEngine: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'content',
    title: 'AI Content Generation',
    description: 'Generate long-form SEO-optimized articles from a single keyword. Async pipeline, multi-language.',
  },
  {
    icon: 'image',
    title: 'AI Image Generation',
    description: 'Unique AI visuals or stock library access — commercial license included, web-optimized formats.',
  },
  {
    icon: 'message',
    title: 'AI Comments',
    description: 'Generate contextual comments for blog posts and articles. Natural language that matches your voice.',
  },
  {
    icon: 'user',
    title: 'Author Profiles',
    description: 'Create and manage author profiles with bios, avatars, and metadata for multi-author publishing.',
  },
  {
    icon: 'shield',
    title: 'Legal Pages',
    description: 'Generate privacy policies, terms of service, and cookie notices tailored to your business.',
  },
];

/**
 * Distribution genuinely runs in order — research, publish, get crawled, earn
 * links — so it is drawn as a sequence rather than as four peer cards.
 */
const distribution: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'keyword',
    title: 'Keyword Intelligence',
    description: 'Extract keywords with volume, intent, and difficulty from any URL or topic.',
  },
  {
    icon: 'cms',
    title: 'CMS Publishing',
    description: 'Publish directly to WordPress and other CMS platforms. Schedule, categorize, manage media via API.',
  },
  {
    icon: 'indexing',
    title: 'Indexing Automation',
    description: 'Submit URLs to search engines for faster crawling. Batch processing and status tracking.',
  },
  {
    icon: 'link',
    title: 'Link Building',
    description: 'Integrated marketplace for guest posts and backlinks — build authority programmatically.',
  },
];

const developer: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'code',
    title: 'REST API',
    description: 'Dual-token auth, async jobs, predictable JSON envelopes. Interactive docs at developer.1platform.pro.',
  },
  {
    icon: 'webhook',
    title: 'Webhooks',
    description: 'HMAC-signed lifecycle events, allowed-domain registration, and one-call secret rotation.',
  },
  {
    icon: 'dashboard',
    title: 'Whitelabel Dashboard',
    description: 'Bootstrap a fully branded dashboard in one API call — branding, theme, layout, i18n, KPIs.',
  },
  {
    icon: 'logs',
    title: 'Activity Logs',
    description: 'Every API call logged with method, endpoint, status, latency. Register client-side events.',
  },
  {
    icon: 'agent',
    title: 'AI Agents',
    description: 'Autonomous agents from templates or via wizard. Scheduled runs, human-in-the-loop approvals.',
  },
  {
    icon: 'chart',
    title: 'Analytics',
    description: 'Connect analytics, provision properties, retrieve traffic metrics — all through one API.',
  },
];

const codePayments = `curl -X POST https://api.1platform.pro/api/v1/users/transactions \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "amount": 25.00,
    "description": "Order #1042"
  }'`;

const codeContent = `curl -X POST https://api.1platform.pro/api/v1/posts/content/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "keyword": "sustainable gardening tips",
    "lang": "en",
    "country": "us"
  }'`;

const codeIndexing = `curl -X POST https://api.1platform.pro/api/v1/posts/indexing/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "url": "https://myblog.com/sustainable-gardening-tips"
  }'`;

const codeWhitelabel = `curl -X GET https://api.1platform.pro/api/v1/dashboard/bootstrap \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN"`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Hero
    headline="Every capability, and the call that runs it"
    subheadline="Store, payments, electronic invoicing, content, distribution, and the developer platform — each one documented, already connected to the others, and reachable from the same API."
    primaryCta={{ label: 'Launch Your Store', href: 'https://app.1platform.pro/app/?intent=store' }}
    secondaryCta={{ label: 'For Developers — View API', href: 'https://developer.1platform.pro/' }}
    badge="Store · Payments · Content · API"
  />

  <div class="section crumbs">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Features' },
      ]} />

      <nav class="contents" aria-label="On this page">
        {contents.map((entry, i) => (
          <a href={entry.href} class="contents__link">
            <span class="contents__ord" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            {entry.label}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Ecommerce: the four that carry the money, given the most weight -->
  <section class="section" id="ecommerce">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Ecommerce essentials</p>
      </div>

      <div class="opener">
        <h2 class="opener__lead">The monetization core</h2>
        <p class="opener__note">
          Storefront, card payments, compliant electronic invoicing, and your own domain —
          the part of the stack that has to work the day you open.
        </p>
      </div>

      <div class="lead-grid">
        {commerce.map((item) => (
          <Card
            variant="lead"
            icon={item.icon}
            title={item.title}
            description={item.description}
            href={item.href}
            class="reveal"
          />
        ))}
      </div>

      <div class="demo reveal">
        <p class="eyebrow demo__label">Example request</p>
        <CodeBlock language="bash" title="Create a payment transaction" code={codePayments} />
      </div>
    </div>
  </section>

  <!-- Content engine: a set of peers, so no surfaces — just a readable field -->
  <section class="section section--alt" id="content">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Content engine</p>
      </div>

      <div class="opener">
        <h2 class="opener__lead">Content that fuels the store</h2>
        <p class="opener__note">
          Articles, images, comments, author profiles, and legal pages — generated on demand,
          in the languages you sell in, and published without leaving the platform.
        </p>
      </div>

      <div class="bare-grid">
        {contentEngine.map((item) => (
          <Card
            variant="bare"
            icon={item.icon}
            title={item.title}
            description={item.description}
            class="reveal"
          />
        ))}
      </div>

      <div class="demo reveal">
        <p class="eyebrow demo__label">Example request</p>
        <CodeBlock language="bash" title="Generate an SEO article" code={codeContent} />
      </div>
    </div>
  </section>

  <!-- Distribution: an ordered sequence, drawn as one -->
  <section class="section" id="distribution">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Distribution &amp; growth</p>
      </div>

      <div class="opener">
        <h2 class="opener__lead">From published to discovered</h2>
        <p class="opener__note">
          Content only earns traffic once it has been researched, published, crawled, and linked.
          These four run in that order, and each one is an endpoint you can call.
        </p>
      </div>

      <ol class="flow">
        {distribution.map((step, i) => (
          <li class="flow__item reveal">
            <span class="flow__ord" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span class="flow__icon"><Icon name={step.icon} size={20} /></span>
            <div class="flow__body">
              <h3 class="flow__title">{step.title}</h3>
              <p class="flow__desc">{step.description}</p>
            </div>
          </li>
        ))}
      </ol>

      <div class="demo reveal">
        <p class="eyebrow demo__label">Example request</p>
        <CodeBlock language="bash" title="Submit a URL for indexing" code={codeIndexing} />
      </div>
    </div>
  </section>

  <!-- Developer platform: a reference ledger, name against description -->
  <section class="section section--alt" id="developer">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Developer platform</p>
      </div>

      <div class="opener">
        <h2 class="opener__lead">The operational layer</h2>
        <p class="opener__note">
          Everything the dashboard does is something your product can do too — call it, observe it,
          and ship it under your own brand.
        </p>
      </div>

      <dl class="ledger">
        {developer.map((item) => (
          <div class="ledger__row reveal">
            <dt class="ledger__term">
              <span class="ledger__icon"><Icon name={item.icon} size={18} /></span>
              {item.title}
            </dt>
            <dd class="ledger__desc">{item.description}</dd>
          </div>
        ))}
      </dl>

      <div class="demo reveal">
        <p class="eyebrow demo__label">Example request</p>
        <CodeBlock language="bash" title="Bootstrap a branded dashboard" code={codeWhitelabel} />
      </div>

      <p class="ledger__more">
        <a href="/for-developers/" class="link-cue">
          See the developer platform
          <Icon name="arrow-right" size={15} />
        </a>
      </p>
    </div>
  </section>
  <!-- The closing CTA lives in the footer, on every page — see Footer.astro. -->
</BaseLayout>

<style>
  /* The breadcrumb strip carries the page index, so it does not need a full
     section's worth of air. */
  .crumbs {
    padding-block: var(--space-8) 0;
  }

  /* ===== On-this-page index ===== */
  .contents {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .contents__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    min-height: 44px;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    background: var(--color-bg-alt);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  @media (prefers-reduced-motion: no-preference) {
    .contents__link {
      transition: color var(--duration-fast) ease,
                  border-color var(--duration-fast) ease;
    }
  }

  .contents__link:hover {
    color: var(--color-accent);
    border-color: var(--color-border-hover);
  }

  .contents__ord {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  /* ===== Section opener — left-aligned, one column ===== */
  .opener {
    max-width: 40rem;
    margin-bottom: var(--space-12);
  }

  .opener__lead {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .opener__note {
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ===== Commerce: four featured cards ===== */
  .lead-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  /* ===== Content engine: peers, no surfaces ===== */
  .bare-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-10) var(--space-8);
  }

  /* ===== Distribution: the ordered flow ===== */
  .flow {
    display: grid;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 54rem;
  }

  .flow__item {
    display: grid;
    grid-template-columns: auto auto minmax(0, 1fr);
    align-items: start;
    gap: var(--space-5);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .flow__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .flow__ord {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    padding-top: 2px;
  }

  .flow__icon {
    display: inline-flex;
    color: var(--color-accent);
    padding-top: 1px;
  }

  .flow__title {
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .flow__desc {
    font-size: var(--text-sm);
    margin: 0;
  }

  /* ===== Developer platform: term against definition ===== */
  .ledger {
    margin: 0;
    max-width: 60rem;
  }

  .ledger__row {
    display: grid;
    grid-template-columns: minmax(0, 15rem) minmax(0, 1fr);
    gap: var(--space-6);
    padding-block: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .ledger__row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .ledger__term {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-weight: 600;
    color: var(--color-text);
  }

  .ledger__icon {
    display: inline-flex;
    color: var(--color-accent);
  }

  .ledger__desc {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .ledger__more {
    margin: var(--space-8) 0 0;
  }

  .link-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .link-cue:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* ===== The API sample — one device, used the same way in every section =====
     The sample is the same kind of object each time, so it gets the same
     treatment; only the capability layouts above it differ. */
  .demo {
    max-width: 52rem;
    min-width: 0;
    margin-top: var(--space-12);
  }

  .demo__label {
    display: block;
    margin-bottom: var(--space-3);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .bare-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .lead-grid,
    .bare-grid {
      grid-template-columns: 1fr;
    }

    .bare-grid {
      gap: var(--space-8);
    }

    .ledger__row {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .flow__item {
      grid-template-columns: auto minmax(0, 1fr);
      gap: var(--space-3) var(--space-4);
    }

    /* The ordinal keeps its own line above the icon on narrow screens. */
    .flow__ord {
      grid-column: 1 / -1;
      padding-top: 0;
    }
  }
</style>
