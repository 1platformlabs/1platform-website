---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import FeatureCard from '@components/FeatureCard.astro';
import CodeBlock from '@components/CodeBlock.astro';

const title = 'Features — AI Content, Keywords, Indexing & More | 1Platform';
const description = 'Explore 1Platform features: AI content generation, keyword extraction, CMS publishing, Google indexing, link building, payments, and invoicing — all via REST API.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Features',
  description,
  url: 'https://1platform.pro/features/',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Features' },
    ],
  },
};

/* ── SVG Icons ── */
const icons = {
  keyword: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
  content: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
  image: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>',
  comments: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
  profiles: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
  legal: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  cms: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
  indexing: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>',
  linkBuilding: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
  payments: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>',
  nfc: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h6l3-9 3 18 3-9h5"/></svg>',
  invoicing: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>',
  searchConsole: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
  websites: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
  analytics: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4z"/></svg>',
  agents: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="3"/><path d="M12 8v3"/><path d="M8 16h0"/><path d="M16 16h0"/></svg>',
  adsense: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
  activityLogs: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>',
};

/* ── Code Examples ── */
const codeKeywords = `curl -X POST https://api.1platform.pro/api/v1/posts/keywords/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "domain": "example.com",
    "country": "us",
    "lang": "en"
  }'`;

const codeContent = `curl -X POST https://api.1platform.pro/api/v1/posts/content/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "keyword": "sustainable gardening tips",
    "lang": "en",
    "country": "us"
  }'`;

const codeIndexing = `curl -X POST https://api.1platform.pro/api/v1/posts/indexing/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "url": "https://myblog.com/sustainable-gardening-tips"
  }'`;

const codePayments = `curl -X POST https://api.1platform.pro/api/v1/users/transactions \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "amount": 25.00,
    "description": "Account top-up - March 2026"
  }'`;

const codeInvoice = `curl -X POST https://api.1platform.pro/api/v1/businesses/$BUSINESS_ID/invoices \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "items": [{"description": "Consulting service", "unit_price": 1000.00, "quantity": 1}],
    "receptorInfo": {
      "name": "Client S.A.",
      "documentType": "NIT",
      "documentNumber": "98765432",
      "email": "client@example.com"
    }
  }'`;

const codeAnalytics = `curl -X GET "https://api.1platform.pro/api/v1/analytics/overview?website_id=$WEBSITE_ID&period=30d" \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN"`;

const codeAgents = `curl -X POST https://api.1platform.pro/api/v1/agents \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "name": "SEO Content Writer",
    "description": "Generates weekly blog posts from trending keywords",
    "system_prompt": "You are an SEO content writer...",
    "model": "1platform-agent-default",
    "schedule": "0 9 * * 1",
    "max_iterations": 10
  }'`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Hero
    headline="Built for Developers Who Ship"
    subheadline="Every feature designed for programmatic access. Keywords, content, publishing, indexing, link building, payments, and invoicing — all through a unified REST API."
    primaryCta={{ label: 'Get Started Free', href: 'https://app.1platform.pro' }}
    secondaryCta={{ label: 'View API Docs', href: 'https://developer.1platform.pro/' }}
    badge="AI Content, SEO & Payments"
  />

  <div class="section">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Features' },
      ]} />
    </div>
  </div>

  <!-- AI & Content -->
  <section class="section" id="ai-content">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="gradient-text">AI & Content</h2>
        <p class="section-description">
          Extract keywords, generate articles, create images, produce comments, build author profiles, and draft legal pages — all from a single API.
        </p>
      </div>

      <div class="grid-3 features-grid">
        <FeatureCard
          icon={icons.keyword}
          title="Keyword Extraction"
          description="Extract high-value keywords from any URL or text. Get search volume, difficulty scores, and related terms in seconds."
        />
        <FeatureCard
          icon={icons.content}
          title="AI Content Generation"
          description="Generate long-form, SEO-optimized articles from a single keyword. Control tone, length, and structure via API parameters."
        />
        <FeatureCard
          icon={icons.image}
          title="Image Generation"
          description="Generate and source images programmatically. Get AI-generated visuals or curated stock photos matched to your content."
        />
        <FeatureCard
          icon={icons.comments}
          title="AI Comments"
          description="Generate contextual comments for blog posts and articles. Natural language output that matches your brand voice."
        />
        <FeatureCard
          icon={icons.profiles}
          title="Author Profiles"
          description="Create and manage author profiles with bios, avatars, and metadata. Perfect for multi-author publishing workflows."
        />
        <FeatureCard
          icon={icons.legal}
          title="Legal Pages"
          description="Generate privacy policies, terms of service, and cookie policies tailored to your business. Stay compliant effortlessly."
        />
      </div>

      <div class="code-example reveal">
        <CodeBlock
          language="bash"
          title="Extract keywords from a URL"
          code={codeKeywords}
        />
      </div>

      <div class="code-example reveal">
        <CodeBlock
          language="bash"
          title="Generate an article"
          code={codeContent}
        />
      </div>
    </div>
  </section>

  <!-- Publishing & Distribution -->
  <section class="section" id="publishing">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="gradient-text">Publishing & Distribution</h2>
        <p class="section-description">
          Push content to your CMS, submit URLs for indexing, and build backlinks — turning content into traffic automatically.
        </p>
      </div>

      <div class="grid-3 features-grid">
        <FeatureCard
          icon={icons.cms}
          title="CMS Publishing"
          description="Publish directly to WordPress and other CMS platforms via API. Schedule posts, set categories, and manage media uploads."
        />
        <FeatureCard
          icon={icons.indexing}
          title="Google Indexing"
          description="Submit URLs to search engines for faster indexing. Track submission status and get indexed sooner — no manual work."
        />
        <FeatureCard
          icon={icons.linkBuilding}
          title="Link Building"
          description="Access a marketplace of high-authority sites for guest posts and backlinks. Automate outreach and placement via API."
        />
      </div>

      <div class="code-example reveal">
        <CodeBlock
          language="bash"
          title="Submit a URL for indexing"
          code={codeIndexing}
        />
      </div>
    </div>
  </section>

  <!-- Payments & Invoicing -->
  <section class="section section--alt" id="payments">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="gradient-text">Payments & Invoicing</h2>
        <p class="section-description">
          Accept online and in-person payments, then generate certified electronic invoices (FEL) automatically — monetize your content ecosystem.
        </p>
      </div>

      <div class="grid-3 features-grid">
        <FeatureCard
          icon={icons.payments}
          title="Payment Processing"
          description="Accept credit and debit card payments via API. Get checkout URLs, receive webhook notifications, and track transaction history."
        />
        <FeatureCard
          icon={icons.nfc}
          title="NFC Tap-to-Pay"
          description="Turn any NFC-enabled smartphone into a point-of-sale terminal. Accept card-present payments without dedicated hardware."
        />
        <FeatureCard
          icon={icons.invoicing}
          title="Electronic Invoicing (FEL)"
          description="Generate certified electronic invoices automatically from transactions. Tax-compliant FEL billing for Guatemala."
        />
      </div>

      <div class="code-example reveal">
        <CodeBlock
          language="bash"
          title="Create a payment transaction"
          code={codePayments}
        />
      </div>

      <div class="code-example reveal">
        <CodeBlock
          language="bash"
          title="Generate an electronic invoice"
          code={codeInvoice}
        />
      </div>
    </div>
  </section>

  <!-- Analytics & AI Agents -->
  <section class="section" id="analytics-agents">
    <div class="container">
      <div class="section-header reveal">
        <h2>Analytics, Monetization & AI Agents</h2>
        <p>Connect analytics and ad monetization to measure performance and revenue. Deploy autonomous AI agents to automate recurring tasks. Track every API call with activity logs.</p>
      </div>

      <div class="feature-grid reveal">
        <FeatureCard
          icon={icons.analytics}
          title="Google Analytics Integration"
          description="Connect GA4 via OAuth, provision properties automatically, retrieve traffic metrics — sessions, pageviews, realtime data — and send server-side events."
        />
        <FeatureCard
          icon={icons.adsense}
          title="Ad Revenue Management"
          description="Connect your ad account via OAuth, monitor earnings by page, track RPM and CTR, review policy issues, and generate custom revenue reports — all via API."
        />
        <FeatureCard
          icon={icons.agents}
          title="AI Agents"
          description="Create autonomous agents from templates or via a guided wizard. Schedule runs, monitor execution, and handle human-in-the-loop approvals."
        />
        <FeatureCard
          icon={icons.activityLogs}
          title="Activity Logs"
          description="Track every API call with server-side logs, ingest client-side events, correlate with trace IDs, and manage retention — full observability for your integration."
        />
      </div>

      <div class="code-example reveal">
        <CodeBlock
          language="bash"
          title="Get site overview metrics"
          code={codeAnalytics}
        />
      </div>

      <div class="code-example reveal">
        <CodeBlock
          language="bash"
          title="Create an AI agent with a schedule"
          code={codeAgents}
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--alt">
    <div class="container cta-section">
      <h2 class="reveal">Ready to Build?</h2>
      <p class="reveal cta-description">
        Start integrating 18+ solutions into your workflow today. Free tier included — no credit card required.
      </p>
      <div class="cta-actions reveal">
        <a href="https://app.1platform.pro" class="btn btn--primary">Get Started Free</a>
        <a href="https://developer.1platform.pro/" class="btn btn--ghost">View API Docs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    margin-bottom: var(--space-4);
  }

  .section-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  .features-grid {
    margin-bottom: var(--space-10);
  }

  .code-example {
    margin-top: var(--space-6);
    max-width: 800px;
    margin-inline: auto;
  }

  .code-example + .code-example {
    margin-top: var(--space-4);
  }

  .cta-section {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
  }

  .cta-section h2 {
    margin-bottom: var(--space-4);
  }

  .cta-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .cta-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
