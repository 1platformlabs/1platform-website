---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import FeatureCard from '@components/FeatureCard.astro';
import CodeBlock from '@components/CodeBlock.astro';

const title = 'Features — E-Commerce, Delivery, Invoicing & AI | 1Platform';
const description = 'Explore 1Platform features: regional e-commerce, delivery management, payments, electronic invoicing (FEL), AI content generation — all via REST API.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Features',
  description,
  url: 'https://1platform.pro/features/',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Features' },
    ],
  },
};

/* ── SVG Icons ── */
const icons = {
  keyword: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
  content: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
  image: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>',
  comments: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
  profiles: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
  legal: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  cms: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
  indexing: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>',
  linkBuilding: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
  payments: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>',
  nfc: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h6l3-9 3 18 3-9h5"/></svg>',
  invoicing: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>',
  ecommerce: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>',
  delivery: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-4"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
  tracking: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>',
};

/* ── Code Examples ── */
const codeKeywords = `curl -X POST https://api.1platform.pro/api/v1/keywords/extract \\
  -H "Authorization: Bearer YOUR_APP_TOKEN" \\
  -H "x-user-token: USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{ "url": "https://example.com/blog-post", "language": "en" }'`;

const codeContent = `curl -X POST https://api.1platform.pro/api/v1/content/generate \\
  -H "Authorization: Bearer YOUR_APP_TOKEN" \\
  -H "x-user-token: USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "keyword": "astro static site generator",
    "language": "en",
    "tone": "professional",
    "length": "long"
  }'`;

const codeCms = `curl -X POST https://api.1platform.pro/api/v1/cms/publish \\
  -H "Authorization: Bearer YOUR_APP_TOKEN" \\
  -H "x-user-token: USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "website_id": "site_abc123",
    "title": "Your SEO Title",
    "content": "<p>Your HTML content...</p>",
    "status": "publish"
  }'`;

const codePayments = `curl -X POST https://api.1platform.pro/api/v1/payments/create \\
  -H "Authorization: Bearer YOUR_APP_TOKEN" \\
  -H "x-user-token: USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "amount": 49.99,
    "currency": "GTQ",
    "description": "Pro Plan - Monthly",
    "callback_url": "https://yoursite.com/callback"
  }'`;

const codeDelivery = `curl -X POST https://api.1platform.pro/api/v1/delivery/assign \\
  -H "Authorization: Bearer YOUR_APP_TOKEN" \\
  -H "x-user-token: USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "order_id": "ord_abc123",
    "pickup": "Zone 10, Guatemala City",
    "dropoff": "Zone 14, Guatemala City",
    "priority": "express"
  }'`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Hero
    headline="Built for Developers Who Ship"
    subheadline="Every feature designed for programmatic access. E-commerce, delivery, payments, invoicing, and AI content — all through a unified REST API."
    primaryCta={{ label: 'Get Started Free', href: 'https://app.1platform.pro' }}
    secondaryCta={{ label: 'View API Docs', href: 'https://developer.1platform.pro/' }}
    badge="E-Commerce, Delivery & AI"
  />

  <div class="section">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Features' },
      ]} />
    </div>
  </div>

  <!-- E-Commerce & Payments -->
  <section class="section" id="ecommerce">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="gradient-text">E-Commerce & Payments</h2>
        <p class="section-description">
          Build regional online stores with integrated checkout, accept cards and local payment methods, and process NFC transactions in person.
        </p>
      </div>

      <div class="grid-3 features-grid">
        <FeatureCard
          icon={icons.ecommerce}
          title="Online Store"
          description="Create e-commerce websites with product catalogs, checkout flows, and multi-currency support for Latin American markets."
        />
        <FeatureCard
          icon={icons.payments}
          title="Payment Processing"
          description="Accept credit cards, debit cards, and local payment methods. Hosted checkout or embedded payments via API."
        />
        <FeatureCard
          icon={icons.nfc}
          title="NFC Tap-to-Pay"
          description="Turn any NFC-enabled smartphone into a point-of-sale terminal. Accept card-present payments without dedicated hardware."
        />
      </div>

      <div class="code-example reveal">
        <CodeBlock
          language="bash"
          title="Create a payment"
          code={codePayments}
        />
      </div>
    </div>
  </section>

  <!-- Delivery & Invoicing -->
  <section class="section section--alt" id="delivery">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="gradient-text">Delivery & Invoicing</h2>
        <p class="section-description">
          Coordinate deliveries from order to doorstep and generate certified electronic invoices (FEL) automatically for every sale.
        </p>
      </div>

      <div class="grid-3 features-grid">
        <FeatureCard
          icon={icons.delivery}
          title="Delivery Coordination"
          description="Manage the full delivery lifecycle: order assignment, route optimization, driver tracking, and delivery confirmation."
        />
        <FeatureCard
          icon={icons.tracking}
          title="Real-Time Tracking"
          description="Give customers live order tracking. GPS-based driver location, ETA updates, and delivery status notifications."
        />
        <FeatureCard
          icon={icons.invoicing}
          title="Electronic Invoicing (FEL)"
          description="Generate certified electronic invoices automatically after each sale. Tax-compliant FEL billing for Guatemala and Central America."
        />
      </div>

      <div class="code-example reveal">
        <CodeBlock
          language="bash"
          title="Assign a delivery"
          code={codeDelivery}
        />
      </div>
    </div>
  </section>

  <!-- AI & Content -->
  <section class="section" id="ai-content">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="gradient-text">AI & Content</h2>
        <p class="section-description">
          Extract keywords, generate articles, create images, produce comments, build author profiles, and draft legal pages — all from a single API.
        </p>
      </div>

      <div class="grid-3 features-grid">
        <FeatureCard
          icon={icons.keyword}
          title="Keyword Extraction"
          description="Extract high-value keywords from any URL or text. Get search volume, difficulty scores, and related terms in seconds."
        />
        <FeatureCard
          icon={icons.content}
          title="AI Content Generation"
          description="Generate long-form, SEO-optimized articles from a single keyword. Control tone, length, and structure via API parameters."
        />
        <FeatureCard
          icon={icons.image}
          title="Image Generation"
          description="Generate and source images programmatically. Get AI-generated visuals or curated stock photos matched to your content."
        />
        <FeatureCard
          icon={icons.comments}
          title="AI Comments"
          description="Generate contextual comments for blog posts and articles. Natural language output that matches your brand voice."
        />
        <FeatureCard
          icon={icons.profiles}
          title="Author Profiles"
          description="Create and manage author profiles with bios, avatars, and metadata. Perfect for multi-author publishing workflows."
        />
        <FeatureCard
          icon={icons.legal}
          title="Legal Pages"
          description="Generate privacy policies, terms of service, and cookie policies tailored to your business. Stay compliant effortlessly."
        />
      </div>

      <div class="code-example reveal">
        <CodeBlock
          language="bash"
          title="Extract keywords from a URL"
          code={codeKeywords}
        />
      </div>

      <div class="code-example reveal">
        <CodeBlock
          language="bash"
          title="Generate an article"
          code={codeContent}
        />
      </div>
    </div>
  </section>

  <!-- Publishing & Distribution -->
  <section class="section" id="publishing">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="gradient-text">Publishing & Distribution</h2>
        <p class="section-description">
          Push content to your CMS, submit URLs for indexing, and build backlinks — turning content into traffic automatically.
        </p>
      </div>

      <div class="grid-3 features-grid">
        <FeatureCard
          icon={icons.cms}
          title="CMS Publishing"
          description="Publish directly to WordPress and other CMS platforms via API. Schedule posts, set categories, and manage media uploads."
        />
        <FeatureCard
          icon={icons.indexing}
          title="Google Indexing"
          description="Submit URLs to search engines for faster indexing. Track submission status and get indexed sooner — no manual work."
        />
        <FeatureCard
          icon={icons.linkBuilding}
          title="Link Building"
          description="Access a marketplace of high-authority sites for guest posts and backlinks. Automate outreach and placement via API."
        />
      </div>

      <div class="code-example reveal">
        <CodeBlock
          language="bash"
          title="Publish to your CMS"
          code={codeCms}
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--alt">
    <div class="container cta-section">
      <h2 class="reveal">Ready to Build?</h2>
      <p class="reveal cta-description">
        Start integrating 13+ solutions into your workflow today. Free tier included — no credit card required.
      </p>
      <div class="cta-actions reveal">
        <a href="https://app.1platform.pro" class="btn btn--primary">Get Started Free</a>
        <a href="https://developer.1platform.pro/" class="btn btn--ghost">View API Docs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    margin-bottom: var(--space-4);
  }

  .section-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  .features-grid {
    margin-bottom: var(--space-10);
  }

  .code-example {
    margin-top: var(--space-6);
    max-width: 800px;
    margin-inline: auto;
  }

  .code-example + .code-example {
    margin-top: var(--space-4);
  }

  .cta-section {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
  }

  .cta-section h2 {
    margin-bottom: var(--space-4);
  }

  .cta-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .cta-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
