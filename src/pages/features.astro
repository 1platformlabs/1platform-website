---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import FeatureCard from '@components/FeatureCard.astro';
import CodeBlock from '@components/CodeBlock.astro';

const title = 'Features — Store, Payments, Content & Developer Platform | 1Platform';
const description = 'Every feature 1Platform offers: online store, payments, electronic invoicing, AI content, distribution, and a developer-grade API — all unified.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Features',
  description,
  url: 'https://1platform.pro/features/',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Features' },
    ],
  },
};

const icons = {
  cart: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>',
  payments: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>',
  invoicing: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>',
  domains: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
  content: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
  image: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>',
  comments: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
  profiles: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
  legal: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  cms: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/></svg>',
  indexing: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>',
  keyword: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
  linkBuilding: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
  api: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  webhooks: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92V21a1 1 0 0 1-1.09 1 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 3.18 4.18 1 1 0 0 1 4.21 3h4.09a1 1 0 0 1 1 .75 12.84 12.84 0 0 0 .7 2.81 1 1 0 0 1-.27 1L8.09 9.21a16 16 0 0 0 6 6l1.65-1.65a1 1 0 0 1 1-.27 12.84 12.84 0 0 0 2.81.7 1 1 0 0 1 .75 1z"/></svg>',
  whitelabel: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M2 7h20"/></svg>',
  logs: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
  agents: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="3"/><path d="M12 8v3"/></svg>',
  analytics: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/></svg>',
};

const codePayments = `curl -X POST https://api.1platform.pro/api/v1/users/transactions \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "amount": 25.00,
    "description": "Order #1042"
  }'`;

const codeContent = `curl -X POST https://api.1platform.pro/api/v1/posts/content/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "keyword": "sustainable gardening tips",
    "lang": "en",
    "country": "us"
  }'`;

const codeIndexing = `curl -X POST https://api.1platform.pro/api/v1/posts/indexing/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "url": "https://myblog.com/sustainable-gardening-tips"
  }'`;

const codeWhitelabel = `curl -X GET https://api.1platform.pro/api/v1/dashboard/bootstrap \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN"`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Hero
    headline="Built for Builders Who Ship"
    subheadline="Online store, payments, invoicing, content, and a developer-grade API — every feature designed to work together so you can launch faster."
    primaryCta={{ label: 'Launch Your Store', href: 'https://app.1platform.pro/app/?intent=store' }}
    secondaryCta={{ label: 'For Developers — View API', href: 'https://developer.1platform.pro/' }}
    badge="Store · Payments · Content · API"
  />

  <div class="section">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Features' },
      ]} />
    </div>
  </div>

  <!-- Ecommerce Essentials -->
  <section class="section" id="ecommerce">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="gradient-text">Ecommerce Essentials</h2>
        <p class="section-description">
          Storefront, card payments, compliant electronic invoicing, and your own domain — the monetization core.
        </p>
      </div>

      <div class="grid-3 features-grid">
        <FeatureCard icon={icons.cart} title="Online Store" description="Catalog, cart, and checkout — ready to publish on your own domain. No plugins, no patchwork." />
        <FeatureCard icon={icons.payments} title="Payment Processing" description="Accept card payments via API. Hosted checkout URLs, real-time webhooks, automatic balance crediting." />
        <FeatureCard icon={icons.invoicing} title="Electronic Invoicing" description="Generate compliant electronic invoices automatically from every transaction. PDF + XML output." />
        <FeatureCard icon={icons.domains} title="Domain Management" description="Register, transfer, renew. Manage DNS records and nameservers — all programmatically." />
      </div>

      <div class="code-example reveal">
        <CodeBlock language="bash" title="Create a payment transaction" code={codePayments} />
      </div>
    </div>
  </section>

  <!-- Content Engine -->
  <section class="section section--alt" id="content">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="gradient-text">Content Engine</h2>
        <p class="section-description">
          AI articles, images, comments, author profiles, and legal pages — generate the content that fuels your store and website.
        </p>
      </div>

      <div class="grid-3 features-grid">
        <FeatureCard icon={icons.content} title="AI Content Generation" description="Generate long-form SEO-optimized articles from a single keyword. Async pipeline, multi-language." />
        <FeatureCard icon={icons.image} title="AI Image Generation" description="Unique AI visuals or stock library access — commercial license included, web-optimized formats." />
        <FeatureCard icon={icons.comments} title="AI Comments" description="Generate contextual comments for blog posts and articles. Natural language that matches your voice." />
        <FeatureCard icon={icons.profiles} title="Author Profiles" description="Create and manage author profiles with bios, avatars, and metadata for multi-author publishing." />
        <FeatureCard icon={icons.legal} title="Legal Pages" description="Generate privacy policies, terms of service, and cookie notices tailored to your business." />
      </div>

      <div class="code-example reveal">
        <CodeBlock language="bash" title="Generate an SEO article" code={codeContent} />
      </div>
    </div>
  </section>

  <!-- Distribution -->
  <section class="section" id="distribution">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="gradient-text">Distribution & Growth</h2>
        <p class="section-description">
          Publish to your CMS, surface in search engines, build authority — turn content into traffic.
        </p>
      </div>

      <div class="grid-3 features-grid">
        <FeatureCard icon={icons.cms} title="CMS Publishing" description="Publish directly to WordPress and other CMS platforms. Schedule, categorize, manage media via API." />
        <FeatureCard icon={icons.indexing} title="Indexing Automation" description="Submit URLs to search engines for faster crawling. Batch processing and status tracking." />
        <FeatureCard icon={icons.keyword} title="Keyword Intelligence" description="Extract keywords with volume, intent, and difficulty from any URL or topic." />
        <FeatureCard icon={icons.linkBuilding} title="Link Building" description="Integrated marketplace for guest posts and backlinks — build authority programmatically." />
      </div>

      <div class="code-example reveal">
        <CodeBlock language="bash" title="Submit a URL for indexing" code={codeIndexing} />
      </div>
    </div>
  </section>

  <!-- Developer Platform -->
  <section class="section section--alt" id="developer">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="gradient-text">Developer Platform</h2>
        <p class="section-description">
          REST API, async jobs, webhooks, whitelabel dashboard, activity logs, and AI agents — the operational layer for builders.
        </p>
      </div>

      <div class="grid-3 features-grid">
        <FeatureCard icon={icons.api} title="REST API" description="Dual-token auth, async jobs, predictable JSON envelopes. Interactive docs at developer.1platform.pro." />
        <FeatureCard icon={icons.webhooks} title="Webhooks" description="HMAC-signed lifecycle events, allowed-domain registration, and one-call secret rotation." />
        <FeatureCard icon={icons.whitelabel} title="Whitelabel Dashboard" description="Bootstrap a fully branded dashboard in one API call — branding, theme, layout, i18n, KPIs." />
        <FeatureCard icon={icons.logs} title="Activity Logs" description="Every API call logged with method, endpoint, status, latency. Register client-side events." />
        <FeatureCard icon={icons.agents} title="AI Agents" description="Autonomous agents from templates or via wizard. Scheduled runs, human-in-the-loop approvals." />
        <FeatureCard icon={icons.analytics} title="Analytics" description="Connect analytics, provision properties, retrieve traffic metrics — all through one API." />
      </div>

      <div class="code-example reveal">
        <CodeBlock language="bash" title="Bootstrap a branded dashboard" code={codeWhitelabel} />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta-section">
      <h2 class="reveal">Ready to Build?</h2>
      <p class="reveal cta-description">
        Start with one platform — store, payments, invoicing, content, and a developer-grade API.
      </p>
      <div class="cta-actions reveal">
        <a href="https://app.1platform.pro/app/?intent=store" class="btn btn--primary">Launch Your Store</a>
        <a href="https://developer.1platform.pro/" class="btn btn--ghost">View API Docs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    margin-bottom: var(--space-4);
  }

  .section-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  .features-grid {
    margin-bottom: var(--space-10);
  }

  .code-example {
    margin-top: var(--space-6);
    max-width: 800px;
    margin-inline: auto;
  }

  .cta-section {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
  }

  .cta-section h2 {
    margin-bottom: var(--space-4);
  }

  .cta-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .cta-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
