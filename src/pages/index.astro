---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import Icon from '@components/Icon.astro';
import ProcessSpine from '@components/ProcessSpine.astro';
import ComparisonTable from '@components/ComparisonTable.astro';
import CodeBlock from '@components/CodeBlock.astro';
import type { IconName } from '@components/icons';

const title = '1Platform — Online Store, Website & Payments in One Platform';
const description = 'Launch an online store or website with payments, electronic invoicing, AI content, and your own domain — all from one platform. Or integrate it via REST API.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: '1Platform',
    url: 'https://1platform.pro',
    description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: '1Platform',
    description,
    brand: {
      '@type': 'Brand',
      name: '1Platform Labs',
    },
    offers: {
      '@type': 'Offer',
      url: 'https://1platform.pro/pricing/',
      priceCurrency: 'USD',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        priceType: 'PayPerUse',
      },
      availability: 'https://schema.org/InStock',
    },
  },
];

const pillars: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'cart',
    title: 'Sell online from day one',
    description: 'Checkout, payments, electronic invoicing, and your own domain — ready to go without integrating five separate providers.',
  },
  {
    icon: 'content',
    title: 'Content that ranks itself',
    description: 'Articles, images, comments, and legal pages generated and published by AI — optimized for search and conversion.',
  },
  {
    icon: 'dashboard',
    title: 'Your own brand, your own dashboard',
    description: 'Whitelabel the entire experience under your brand — colors, layout, KPIs, and localization — from a single API call.',
  },
  {
    icon: 'code',
    title: 'Built on a developer-grade API',
    description: 'Everything above is available via REST. Dual-token auth, async jobs, predictable envelopes — power your own SaaS on top.',
  },
];

/** The four outcomes most people arrive for. */
const featured: { icon: IconName; title: string; description: string; href: string }[] = [
  {
    icon: 'cart',
    title: 'Online Store',
    description: 'Launch a store with checkout, catalog, and customer accounts — no plugins, no patchwork.',
    href: '/solutions/online-store/',
  },
  {
    icon: 'card',
    title: 'Payment Processing',
    description: 'Accept card payments via API. Checkout URLs, webhook notifications, and automatic balance crediting.',
    href: '/payments-invoicing/',
  },
  {
    icon: 'invoice',
    title: 'Electronic Invoicing',
    description: 'Generate compliant electronic invoices automatically from every transaction — PDF + XML out of the box.',
    href: '/payments-invoicing/',
  },
  {
    icon: 'content',
    title: 'AI Content Generation',
    description: 'Generate full SEO-optimized articles, descriptions, and landing copy from a single keyword.',
    href: '/solutions/content/',
  },
];

/** Everything else, grouped — an index, not another wall of cards. */
const capabilityGroups: { group: string; items: { title: string; href: string }[] }[] = [
  {
    group: 'Content & SEO',
    items: [
      { title: 'AI Image Generation', href: '/solutions/content/' },
      { title: 'AI Keyword Extraction', href: '/solutions/content/' },
      { title: 'CMS Publishing', href: '/solutions/content/' },
      { title: 'Indexing Automation', href: '/solutions/content/' },
      { title: 'Link Building', href: '/solutions/content/' },
      { title: 'Search Console', href: '/solutions/content/' },
      { title: 'Legal Page Generation', href: '/solutions/content/' },
    ],
  },
  {
    group: 'Storefront & brand',
    items: [
      { title: 'Custom Domain', href: '/solutions/website/' },
      { title: 'Whitelabel Dashboard', href: '/solutions/whitelabel/' },
    ],
  },
  {
    group: 'Developer platform',
    items: [
      { title: 'Webhooks', href: '/for-developers/' },
      { title: 'AI Agents', href: '/for-developers/' },
      { title: 'Activity Logs', href: '/for-developers/' },
    ],
  },
];

const useCases: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'monitor',
    title: 'Small business owners',
    description: 'Launch your store or website in days, not months — payments, invoicing, and content handled for you.',
  },
  {
    icon: 'cart',
    title: 'Online sellers & creators',
    description: 'Sell products, services, or digital downloads — accept payments and issue compliant invoices automatically.',
  },
  {
    icon: 'message',
    title: 'Service-based businesses',
    description: 'Book services, collect deposits, send invoices, and publish your portfolio — all from one dashboard.',
  },
  {
    icon: 'users',
    title: 'Agencies managing client sites',
    description: 'Run dozens of client stores and websites from one dashboard — whitelabel optional, billing per client.',
  },
  {
    icon: 'code',
    title: 'Developers building SaaS',
    description: 'Use 1Platform as the backend for your own product — payments, invoicing, content, and dashboard included.',
  },
];

const intentChips = [
  { label: 'I want to sell online', href: '/solutions/online-store/' },
  { label: 'I want a website', href: '/solutions/website/' },
  { label: 'I integrate via API', href: '/for-developers/' },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Hero
    headline="One Platform. Every Solution."
    subheadline="Launch your online store or website with payments, electronic invoicing, AI-generated content, and your own domain — all from one platform. Or integrate it into your product via one REST API."
    badge="Stores · Websites · Payments · Invoicing"
    primaryCta={{ label: 'Launch Your Store', href: 'https://app.1platform.pro/app/?intent=store' }}
    secondaryCta={{ label: 'For Developers — View API', href: 'https://developer.1platform.pro/' }}
    intentChips={intentChips}
    motif
  />

  <!-- What it is: a wide editorial statement, then the four claims -->
  <section class="section">
    <div class="container">
      <div class="statement reveal">
        <p class="eyebrow">What you get</p>
        <h2 class="statement__lead">
          Everything a business needs to sell online, already connected.
        </h2>
      </div>

      <div class="pillars">
        {pillars.map((pillar) => (
          <Card
            variant="bare"
            icon={pillar.icon}
            title={pillar.title}
            description={pillar.description}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities: four featured, the rest as a readable index -->
  <section class="section section--alt" id="solutions">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Capabilities</p>
      </div>

      <div class="featured">
        {featured.map((item) => (
          <Card
            variant="lead"
            icon={item.icon}
            title={item.title}
            description={item.description}
            href={item.href}
            class="reveal"
          />
        ))}
      </div>

      <div class="index reveal">
        {capabilityGroups.map((group) => (
          <div class="index__group">
            <h3 class="index__title">{group.group}</h3>
            <ul class="index__list">
              {group.items.map((item) => (
                <li>
                  <a href={item.href} class="index__link">{item.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <p class="index__all">
        <a href="/solutions/" class="link-cue">
          See all solutions
          <Icon name="arrow-right" size={15} />
        </a>
      </p>
    </div>
  </section>

  <!-- How it works: the schematic, unrolled as a sequence -->
  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">How it works</p>
      </div>
      <h2 class="section__lead">From account to live store, in one platform.</h2>
      <ProcessSpine />
    </div>
  </section>

  <!-- Integrate: copy and code, side by side -->
  <section class="section section--alt">
    <div class="container">
      <div class="split">
        <div class="split__copy reveal">
          <p class="eyebrow">Integrate</p>
          <h2>A REST API with no surprises</h2>
          <p>
            Predictable endpoints, one token pair, consistent response envelopes.
            Everything the dashboard does, your product can do too.
          </p>
          <a href="https://developer.1platform.pro/" class="link-cue">
            Read the API docs
            <Icon name="arrow-right" size={15} />
          </a>
        </div>

        <div class="split__demo">
          <CodeBlock
            language="bash"
            title="Create a payment transaction"
            code={`curl -X POST https://api.1platform.pro/api/v1/users/transactions \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "amount": 25.00,
    "description": "Order #1042"
  }'`}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Who it's for: an editorial list, not a grid of identical cards -->
  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Who it's for</p>
      </div>

      <ul class="audience">
        {useCases.map((useCase) => (
          <li class="audience__item reveal">
            <span class="audience__icon"><Icon name={useCase.icon} size={20} /></span>
            <div>
              <h3 class="audience__title">{useCase.title}</h3>
              <p class="audience__desc">{useCase.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Unified vs fragmented -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Unified vs fragmented</p>
      </div>
      <h2 class="section__lead">What changes when it's one platform</h2>
      <ComparisonTable />
    </div>
  </section>
  <!-- The closing CTA lives in the footer, on every page — see Footer.astro. -->
</BaseLayout>

<style>
  /* ===== Editorial statement ===== */
  .statement {
    max-width: 40rem;
    margin-bottom: var(--space-12);
  }

  .statement__lead {
    font-size: var(--text-4xl);
    margin-top: var(--space-4);
  }

  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-10);
  }

  /* ===== Pillars: 2x2, generous, no surfaces ===== */
  .pillars {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-10) var(--space-12);
  }

  /* ===== Featured capabilities ===== */
  .featured {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-12);
  }

  /* ===== The index of everything else ===== */
  .index {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .index__title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .index__list {
    display: grid;
    gap: var(--space-2);
  }

  .index__link {
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .index__link:hover {
    color: var(--color-accent);
  }

  .index__all {
    margin-top: var(--space-8);
  }

  .link-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .link-cue:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* ===== Split: copy + code ===== */
  .split {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
    gap: var(--space-12);
    align-items: center;
  }

  .split__copy h2 {
    margin-block: var(--space-4);
  }

  .split__copy p {
    margin-bottom: var(--space-6);
  }

  /* Grid children default to min-width:auto, which lets the code block's long
     lines push the whole page wider than the viewport. */
  .split__demo {
    min-width: 0;
  }

  /* ===== Audience list ===== */
  .audience {
    display: grid;
    gap: 0;
    max-width: 52rem;
  }

  .audience__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .audience__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .audience__icon {
    display: inline-flex;
    color: var(--color-accent);
    padding-top: 2px;
  }

  .audience__title {
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .audience__desc {
    font-size: var(--text-sm);
    margin: 0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .split {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .index {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .pillars,
    .featured,
    .index {
      grid-template-columns: 1fr;
    }

    .pillars {
      gap: var(--space-8);
    }

    .statement__lead {
      font-size: var(--text-3xl);
    }
  }
</style>
