---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import PillarSection from '@components/PillarSection.astro';
import SolutionCard from '@components/SolutionCard.astro';
import MetricCounter from '@components/MetricCounter.astro';
import PipelineAnimation from '@components/PipelineAnimation.astro';
import LogoCarousel from '@components/LogoCarousel.astro';
import UseCaseCard from '@components/UseCaseCard.astro';
import ComparisonTable from '@components/ComparisonTable.astro';
import CodeBlock from '@components/CodeBlock.astro';

const title = '1Platform — One API for Every SEO Solution';
const description = '1Platform unifies keyword extraction, AI content generation, WordPress publishing, Google indexing, and link building into one REST API. Get started free.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '1Platform',
  url: 'https://1platform.pro',
  description,
};

const pillars = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>',
    title: 'Unified Platform',
    description: 'One integration replaces 19+ separate tools. Single account, single API key, single documentation set.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
    title: 'AI-Powered Pipeline',
    description: 'From keyword to published article — fully automated with AI at every step.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><circle cx="19" cy="5" r="2"/><circle cx="5" cy="5" r="2"/><circle cx="19" cy="19" r="2"/><circle cx="5" cy="19" r="2"/><line x1="12" y1="9" x2="12" y2="3"/><line x1="14.5" y1="10" x2="17.5" y2="6.5"/><line x1="9.5" y1="10" x2="6.5" y2="6.5"/><line x1="14.5" y1="14" x2="17.5" y2="17.5"/><line x1="9.5" y1="14" x2="6.5" y2="17.5"/></svg>',
    title: 'End-to-End Ecosystem',
    description: 'Content, publishing, indexing, payments, and invoicing — all interconnected out of the box.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>',
    title: 'Scalable by Design',
    description: 'Async job processing, rate-limited endpoints, credits-based billing. Built for production workloads.',
  },
];

const solutions = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><path d="M8 8h6"/><path d="M11 5v6"/></svg>',
    title: 'AI Keyword Extraction',
    description: 'Extract SEO keywords with volume, intent, and cannibalization detection from any domain.',
    href: '/solutions/#intelligence',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
    title: 'AI Content Generation',
    description: 'Generate full SEO-optimized articles from a single keyword with async job pipeline.',
    href: '/solutions/#content',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>',
    title: 'AI Image Generation',
    description: 'Create unique AI visuals or source from premium stock libraries automatically.',
    href: '/solutions/#content',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
    title: 'Search Console Integration',
    description: 'Connect, verify, submit sitemaps, and monitor performance programmatically.',
    href: '/solutions/#intelligence',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
    title: 'Indexing Automation',
    description: 'Submit URLs directly for faster crawling and indexing.',
    href: '/solutions/#distribution',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>',
    title: 'CMS Publishing',
    description: 'Publish generated content directly to WordPress sites via API.',
    href: '/solutions/#distribution',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
    title: 'Link Building',
    description: 'Integrated marketplace for guest posts and backlinks — build authority programmatically.',
    href: '/solutions/#distribution',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
    title: 'Website Management',
    description: 'Manage multiple websites, languages, and categories from one account.',
    href: '/solutions/#intelligence',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
    title: 'AI Comment Generation',
    description: 'Generate realistic, contextual comments for social proof and engagement.',
    href: '/solutions/#content',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
    title: 'AI Profile Generation',
    description: 'Create complete user profiles with bios, avatars, and social links on demand.',
    href: '/solutions/#content',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
    title: 'Legal Page Generation',
    description: 'Auto-generate privacy policies, terms of service, and cookie policies for your websites.',
    href: '/solutions/#content',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>',
    title: 'Payment Processing',
    description: 'Accept online card payments via API. Checkout URLs, webhook notifications, and automatic balance crediting.',
    href: '/solutions/#payments',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>',
    title: 'Electronic Invoicing',
    description: 'Generate compliant electronic invoices (FEL) automatically from transactions.',
    href: '/solutions/#payments',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4z"/></svg>',
    title: 'Google Analytics',
    description: 'Connect GA4, provision properties, and retrieve traffic metrics — all via API.',
    href: '/solutions/#intelligence',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="3"/><path d="M12 8v3"/><path d="M8 16h0"/><path d="M16 16h0"/></svg>',
    title: 'AI Agents',
    description: 'Deploy autonomous AI agents that execute tasks, follow schedules, and request human approval.',
    href: '/solutions/#automation',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><line x1="2" y1="12" x2="22" y2="12"/></svg>',
    title: 'Domain Management',
    description: 'Register domains, manage DNS records, configure nameservers, and handle transfers and renewals — all via API.',
    href: '/solutions/#distribution',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><line x1="6" y1="11" x2="10" y2="11"/><line x1="14" y1="11" x2="18" y2="11"/></svg>',
    title: 'Ad Revenue Tracking',
    description: 'Connect your ad accounts, monitor earnings, track policy issues, and generate custom revenue reports from your dashboard.',
    href: '/solutions/#intelligence',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>',
    title: 'Activity Logs',
    description: 'Track every API call with detailed logs, filter by endpoint or status, and register client-side events for full observability.',
    href: '/solutions/#automation',
  },
];

const useCases = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
    title: 'SaaS & Tech Companies',
    description: 'Integrate SEO automation into your product. Offer content generation as a feature to your users.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
    title: 'Marketing Agencies',
    description: 'Scale content production across dozens of client sites. One API, unlimited websites.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>',
    title: 'E-Commerce Teams',
    description: 'Generate product descriptions, category pages, and blog content at scale.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
    title: 'Publishers & Media',
    description: 'Automate content pipelines from keyword research to indexed, backlinked articles.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
    title: 'Freelance Developers',
    description: 'Build SEO tools and dashboards for clients using 1Platform as your backend.',
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <!-- Hero -->
  <Hero
    headline="One Platform. Every Solution."
    subheadline="1Platform unifies AI content, keyword intelligence, CMS publishing, indexing, link building, payments, and invoicing into one interconnected platform. Integrate once, automate everything."
    badge="19+ Solutions, 1 API"
  />

  <!-- Logo Carousel -->
  <section class="section">
    <div class="container">
      <LogoCarousel />
    </div>
  </section>

  <!-- Platform Pillars -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header reveal">
        <h2>Built on 4 Core Pillars</h2>
        <p>From keyword intelligence to published, indexed content — every capability works together in one ecosystem.</p>
      </div>
      <div class="grid-4 stagger-grid">
        {pillars.map((pillar, i) => (
          <PillarSection
            icon={pillar.icon}
            title={pillar.title}
            description={pillar.description}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Metrics -->
  <section class="section">
    <div class="container">
      <div class="section__header reveal">
        <h2>Platform in Numbers</h2>
        <p>Powering content pipelines and SEO automation for teams every day.</p>
      </div>
      <div class="grid-4 stagger-grid">
        <MetricCounter value={10000} label="Articles Generated" suffix="+" />
        <MetricCounter value={50000} label="Keywords Extracted" suffix="+" />
        <MetricCounter value={5} label="Min to First Article" suffix="" />
        <MetricCounter value={19} label="Integrated Solutions" suffix="+" />
      </div>
    </div>
  </section>

  <!-- Solutions Overview -->
  <section class="section section--alt" id="solutions">
    <div class="container">
      <div class="section__header reveal">
        <h2>19+ Solutions, One API</h2>
        <p>Keywords, content, images, publishing, indexing, link building, payments, invoicing, domains, and more — unified under a single REST API.</p>
      </div>
      <div class="grid-3 stagger-grid">
        {solutions.map((solution) => (
          <SolutionCard
            icon={solution.icon}
            title={solution.title}
            description={solution.description}
            href={solution.href}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="container">
      <div class="section__header reveal">
        <h2>How It Works</h2>
        <p>From keyword research to published, indexed content — every step flows into the next.</p>
      </div>
      <PipelineAnimation />
    </div>
  </section>

  <!-- API Preview -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header reveal">
        <h2>Integrate in Minutes</h2>
        <p>A clean REST API with predictable endpoints. One token pair, consistent responses, zero surprises.</p>
      </div>
      <CodeBlock
        language="bash"
        title="Generate an SEO article from a keyword"
        code={`curl -X POST https://api.1platform.pro/api/v1/posts/content/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "keyword": "sustainable gardening tips",
    "lang": "en",
    "country": "us"
  }'`}
      />
    </div>
  </section>

  <!-- Use Cases -->
  <section class="section">
    <div class="container">
      <div class="section__header reveal">
        <h2>Built for Every Team</h2>
        <p>From SaaS companies to agencies — 1Platform adapts to your content automation needs.</p>
      </div>
      <div class="grid-3 stagger-grid">
        {useCases.map((useCase) => (
          <UseCaseCard
            icon={useCase.icon}
            title={useCase.title}
            description={useCase.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header reveal">
        <h2>Why 1Platform Wins</h2>
        <p>See the difference between juggling 19+ separate tools and using one unified platform.</p>
      </div>
      <ComparisonTable />
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="section cta-banner">
    <div class="container">
      <div class="cta-banner__content reveal">
        <h2>Stop Managing 15+ Different Tools</h2>
        <p>Start with one platform. Automate your entire SEO pipeline from keyword research to published, indexed content.</p>
        <div class="cta-banner__actions">
          <a href="https://app.1platform.pro" class="btn btn--primary">Get Started Free</a>
          <a href="https://developer.1platform.pro/" class="btn btn--ghost">View API Docs</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section {
    padding-block: var(--space-20);
  }

  .section--alt {
    background-color: var(--color-bg-alt, #ffffff);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  .section__header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .section__header h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    text-wrap: balance;
  }

  .section__header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .grid-4 {
      grid-template-columns: repeat(2, 1fr);
    }

    .grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .grid-4,
    .grid-3 {
      grid-template-columns: 1fr;
    }

    .section {
      padding-block: var(--space-12);
    }
  }

  /* CTA Banner */
  .cta-banner {
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.06), rgba(8, 145, 178, 0.05));
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .cta-banner__content {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
  }

  .cta-banner__content h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    text-wrap: balance;
  }

  .cta-banner__content p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .cta-banner__actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
