---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import Icon from '@components/Icon.astro';
import CodeBlock from '@components/CodeBlock.astro';
import type { IconName } from '@components/icons';

const title = 'Accept Payments & Issue Electronic Invoices | 1Platform';
const description = 'Accept online card payments and issue compliant electronic invoices automatically — all from one platform. Webhook-driven, audit-ready, ready for production.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Payments & Electronic Invoicing',
    provider: { '@type': 'Organization', name: '1Platform Labs', url: 'https://1platform.pro' },
    description,
    url: 'https://1platform.pro/payments-invoicing/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Payments & Invoicing' },
    ],
  },
];

const faqs = [
  {
    question: 'Which countries are supported for electronic invoicing?',
    answer: 'Electronic invoicing currently issues compliant invoices for Guatemala (FEL). Additional jurisdictions are on the roadmap — contact sales for timelines.',
  },
  {
    question: 'What currencies and payment methods do you accept?',
    answer: 'We accept all major credit and debit cards. Settlement currency is configured per merchant — contact sales to enable additional currencies.',
  },
  {
    question: 'What types of invoices can I issue?',
    answer: 'Standard invoices, credit notes, and cancellations — all PDF + XML output. Multi-item line support and automatic tax calculation.',
  },
  {
    question: 'How does reconciliation work?',
    answer: 'Every transaction emits HMAC-signed webhooks for approved, denied, cancelled, expired, and dismissed states. Pair with activity logs for full audit trails.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const capabilities: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'card',
    title: 'Accept payments',
    description: 'Card payments via API. Hosted checkout URLs, real-time webhooks and automatic balance crediting.',
  },
  {
    icon: 'invoice',
    title: 'Issue invoices',
    description: 'Compliant electronic invoices generated automatically. PDF + XML output, multi-item lines, automatic tax calculation.',
  },
  {
    icon: 'logs',
    title: 'Track everything',
    description: 'HMAC-signed webhooks for every lifecycle event. Activity logs with method, endpoint, status and latency.',
  },
];

/** The states a transaction can report back, as the webhook emits them. */
const lifecycle = ['approved', 'denied', 'cancelled', 'expired', 'dismissed'];

const related: { icon: IconName; title: string; description: string; href: string }[] = [
  {
    icon: 'cart',
    title: 'Online Store',
    description: 'Add a full storefront with checkout and customer accounts.',
    href: '/solutions/online-store/',
  },
  {
    icon: 'code',
    title: 'For Developers',
    description: 'Integrate payments and invoicing into your own SaaS via REST.',
    href: '/for-developers/',
  },
  {
    icon: 'dashboard',
    title: 'Whitelabel Dashboard',
    description: 'Surface payments and invoicing under your own brand.',
    href: '/solutions/whitelabel/',
  },
];
---

<BaseLayout title={title} description={description} ogImage="/og/solution-payments-invoicing.png" jsonLd={[...jsonLd, faqJsonLd]}>
  <div class="container crumbs">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Payments & Invoicing' },
    ]} />
  </div>

  <Hero
    headline="Payments and compliant invoicing"
    subheadline="Accept payments and issue compliant electronic invoices automatically — from one platform. Webhook-driven, audit-ready, production-tested."
    badge="Payments · Invoicing"
    primaryCta={{ label: 'Start Accepting Payments', href: 'https://app.1platform.pro/app/?intent=payments' }}
    secondaryCta={{ label: 'For Developers — View API', href: 'https://developer.1platform.pro/' }}
  />

  <!-- What you get -->
  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">What you get</p>
      </div>
      <h2 class="section__lead">From checkout to compliant invoice, on one platform</h2>

      <div class="capabilities">
        {capabilities.map((capability) => (
          <Card
            variant="bare"
            icon={capability.icon}
            title={capability.title}
            description={capability.description}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- One call, two outcomes -->
  <section class="section section--alt">
    <div class="container">
      <div class="split">
        <div class="split__copy reveal">
          <p class="eyebrow">One API, two outcomes</p>
          <h2>Create a transaction, get an invoice</h2>
          <p>
            One call opens the checkout. When the payment settles, the invoice is issued from
            the same transaction — no second system to reconcile it against, no export in
            between.
          </p>

          <div class="lifecycle">
            <p class="lifecycle__label">Webhook states</p>
            <ul class="lifecycle__list">
              {lifecycle.map((state) => (
                <li class="lifecycle__state">{state}</li>
              ))}
            </ul>
          </div>
        </div>

        <div class="split__demo">
          <CodeBlock
            language="bash"
            title="Create a payment transaction"
            code={`curl -X POST https://api.1platform.pro/api/v1/users/transactions \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "amount": 25.00,
    "description": "Order #1042"
  }'`}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Questions</p>
      </div>
      <h2 class="section__lead">What people ask before they switch</h2>

      <div class="faq">
        {faqs.map((faq) => (
          <details class="faq__item">
            <summary class="faq__question">
              <span>{faq.question}</span>
              <Icon name="chevron-down" size={20} class="faq__chevron" />
            </summary>
            <div class="faq__answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Related</p>
      </div>
      <h2 class="section__lead">Payments and invoicing connect with the rest of the platform</h2>

      <ul class="related">
        {related.map((item) => (
          <li>
            <a href={item.href} class="related__link">
              <span class="related__icon"><Icon name={item.icon} size={20} /></span>
              <span class="related__text">
                <span class="related__title">{item.title}</span>
                <span class="related__desc">{item.description}</span>
              </span>
              <Icon name="arrow-right" size={16} class="related__arrow" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
  <!-- The closing CTA lives in the footer, on every page — see Footer.astro. -->
</BaseLayout>

<style>
  /* Breadcrumbs clear the fixed header; the hero then drops its own top
     offset so the two don't stack into a canyon of whitespace. */
  .crumbs {
    padding-top: calc(var(--header-height) + var(--space-8));
  }

  .crumbs + :global(.hero) {
    padding-top: var(--space-6);
  }

  .section__lead {
    max-width: 36rem;
    margin-bottom: var(--space-10);
  }

  /* ===== Capabilities ===== */
  .capabilities {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-10);
  }

  /* ===== Split: copy + the call itself ===== */
  .split {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
    gap: var(--space-12);
    align-items: center;
  }

  .split__copy h2 {
    margin-block: var(--space-4);
  }

  .split__copy p {
    margin-bottom: var(--space-8);
  }

  /* Grid children default to min-width:auto, which lets a long code line push
     the whole page wider than the viewport. */
  .split__demo {
    min-width: 0;
  }

  /* ===== Lifecycle states ===== */
  .lifecycle {
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .lifecycle__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-3);
  }

  .lifecycle__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .lifecycle__state {
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    background: var(--color-bg);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  /* ===== FAQ: hairline rows, not a stack of rounded cards ===== */
  .faq {
    max-width: 46rem;
    border-top: 1px solid var(--color-border);
  }

  .faq__item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    min-height: 44px;
    padding-block: var(--space-4);
    cursor: pointer;
    font-weight: 600;
    color: var(--color-text);
    list-style: none;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::marker {
    content: '';
  }

  .faq__question:hover {
    color: var(--color-accent);
  }

  .faq__question :global(.faq__chevron) {
    color: var(--color-text-tertiary);
  }

  @media (prefers-reduced-motion: no-preference) {
    .faq__question :global(.faq__chevron) {
      transition: transform var(--duration-normal) var(--ease-out-expo);
    }
  }

  .faq__item[open] .faq__question :global(.faq__chevron) {
    transform: rotate(180deg);
  }

  .faq__question:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .faq__answer {
    padding-bottom: var(--space-5);
    max-width: 40rem;
  }

  .faq__answer p {
    font-size: var(--text-sm);
    line-height: 1.75;
    margin: 0;
  }

  /* ===== Related ===== */
  .related {
    display: grid;
    max-width: 52rem;
  }

  .related li {
    border-top: 1px solid var(--color-border);
  }

  .related li:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .related__link {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding-block: var(--space-5);
    color: var(--color-text);
  }

  .related__icon {
    display: inline-flex;
    color: var(--color-accent);
  }

  .related__text {
    display: grid;
    gap: var(--space-1);
    flex: 1;
    min-width: 0;
  }

  .related__title {
    font-weight: 600;
  }

  .related__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .related__link :global(.related__arrow) {
    color: var(--color-text-tertiary);
  }

  .related__link:hover {
    color: var(--color-accent);
  }

  .related__link:hover :global(.related__arrow) {
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .related__link :global(.related__arrow) {
      transition: transform var(--duration-fast) var(--ease-out-expo),
                  color var(--duration-fast) ease;
    }

    .related__link:hover :global(.related__arrow) {
      transform: translateX(3px);
    }
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .split {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .capabilities {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
