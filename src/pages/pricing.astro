---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import Icon from '@components/Icon.astro';
import Check from '@components/Check.astro';
import ProcessSpine from '@components/ProcessSpine.astro';
import type { IconName } from '@components/icons';

const title = 'Pricing — Transparent, Pay-as-You-Use | 1Platform';
const description = 'Transparent pricing — pay only for what you use. No subscriptions, no hidden fees. Online store, payments, invoicing, content, and whitelabel dashboard.';

/* Answers describe the billing mechanism as it actually runs: a prepaid
   balance, a hold taken before the work and captured only on success, and
   per-account rates. Nothing here promises a feature the platform does not
   have — the previous copy advertised hard spending caps that auto-pause,
   which do not exist; the prepaid balance is what actually bounds spend. */
const faqs = [
  {
    question: 'How does pricing work?',
    answer: 'There is no subscription. Your account holds a prepaid balance in USD, and every billable operation draws from it at a per-unit rate. You activate whichever solutions you need and pay for the operations you actually run.',
  },
  {
    question: 'Why are per-unit rates not listed on this page?',
    answer: 'Rates are set per account rather than published as one list, because they move with volume and with the country you operate in. The unit each operation is billed by is fixed and listed above — the rate attached to each unit comes on your rate card.',
  },
  {
    question: 'Is there a free plan?',
    answer: 'Yes. Create an account with no credit card and you get a daily allowance for content generation and keyword extraction, plus full REST API access. When you need more than the daily allowance, add balance — nothing about how you build changes.',
  },
  {
    question: 'What happens if an operation fails?',
    answer: 'Nothing is charged. The cost is held against your balance before the work starts and captured only once the operation completes. If it fails, the hold is released and your balance is untouched. Retries carry an idempotency key, so a repeated call is never charged twice.',
  },
  {
    question: 'Can I end up with a bill I did not expect?',
    answer: 'No. Because the balance is prepaid, you cannot spend past it. You get a low-balance notification as it runs down, and once it is insufficient the affected operations stop rather than accruing a debt. Every charge is itemised in your consumption log with the operation, the endpoint, the cost, and your balance before and after.',
  },
  {
    question: 'Do rates improve with volume?',
    answer: 'Yes. Per-unit rates are configured per account, so sustained volume is reflected in your rate card. Tell us the operations you expect to run and we will quote against them.',
  },
  {
    question: 'What payment methods do you accept?',
    answer: 'Credit and debit cards, charged through the same hosted checkout the platform gives you for your own customers. For larger accounts we can arrange billing terms and consolidated invoicing.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const pageJsonLd = [
  faqJsonLd,
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Pricing',
    description,
    url: 'https://1platform.pro/pricing/',
    breadcrumb: {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
        { '@type': 'ListItem', position: 2, name: 'Pricing' },
      ],
    },
  },
];

/* How the model works, stated as four checkable facts about the ledger.
   Replaces the four vanity tiles (zero-subscriptions / infinite-scale /
   turnaround / percent-transparent), which asserted nothing a reader could
   verify and one thing that was not true — usage is bounded by the balance,
   not uncapped. */
const model = [
  {
    label: 'No subscription',
    body: 'Your account holds a balance in USD. Every billable operation draws from it. There is no monthly fee, and nothing renews on its own.',
  },
  {
    label: 'Charged on success',
    body: 'The cost is held against your balance before the work starts, and captured only when the operation completes. A failure releases the hold and leaves the balance untouched.',
  },
  {
    label: 'Itemised, line by line',
    body: 'Each operation writes a line to your consumption log: what ran, which endpoint served it, what it cost, and your balance before and after.',
  },
  {
    label: 'Bounded by design',
    body: 'A prepaid balance cannot be overspent. You are notified as it runs low, and operations stop rather than accruing a bill you never agreed to.',
  },
];

const chargeSteps = [
  { label: 'Add balance' },
  { label: 'Call an operation' },
  { label: 'Cost is held' },
  { label: 'The work runs' },
  { label: 'Hold is captured' },
  { label: 'Or released on failure' },
];

/* The metered operations and the unit each is billed by. The unit is the part
   that is fixed and publishable; the rate attached to it is per-account, which
   is why no figures appear here rather than invented ones. */
const metered: { icon: IconName; name: string; unit: string; note: string }[] = [
  {
    icon: 'content',
    name: 'AI content generation',
    unit: 'per article',
    note: 'One charge per generated article, in any supported language, whatever its length.',
  },
  {
    icon: 'image',
    name: 'AI image generation',
    unit: 'per image',
    note: 'Three rates, by output: standard, HD, and HD wide.',
  },
  {
    icon: 'image',
    name: 'Stock image lookup',
    unit: 'per image',
    note: 'Billed separately from generated images, at a materially lower unit rate.',
  },
  {
    icon: 'keyword',
    name: 'Keyword extraction',
    unit: 'per search',
    note: 'Extraction and topic expansion share the same unit rate.',
  },
  {
    icon: 'indexing',
    name: 'Indexing submission',
    unit: 'per URL',
    note: 'One charge per URL submitted to search engines for indexing.',
  },
  {
    icon: 'message',
    name: 'Comment generation',
    unit: 'per comment',
    note: 'Generated review and discussion copy for your catalog or articles.',
  },
  {
    icon: 'user',
    name: 'Profile generation',
    unit: 'per profile',
    note: 'Author and customer profiles, generated with matching avatars.',
  },
  {
    icon: 'logs',
    name: 'Legal page generation',
    unit: 'per page',
    note: 'Privacy policy, terms of service, and cookie notice, per jurisdiction.',
  },
  {
    icon: 'chart',
    name: 'Search Console reports',
    unit: 'per report',
    note: 'Pulled performance reports for a connected property.',
  },
  {
    icon: 'agent',
    name: 'AI agent conversations',
    unit: 'per step',
    note: 'Charged by step: opening the session, each response, and confirmation.',
  },
];

/* Capabilities with no per-operation charge attached. Grouped rather than
   listed flat, so the page reads as a document instead of another card grid. */
const included: { group: string; items: string[] }[] = [
  {
    group: 'Platform',
    items: [
      'Full REST API access',
      'Dual-token authentication',
      'Async jobs and webhook delivery',
      'Activity logs and consumption history',
    ],
  },
  {
    group: 'Storefront',
    items: [
      'Catalog and hosted checkout',
      'Customer accounts',
      'Analytics',
      'Referrals',
    ],
  },
  {
    group: 'Your brand',
    items: [
      'Whitelabel branding and theme',
      'Localization bundles',
      'Dashboard KPIs and feature flags',
      'Low-balance and activity notifications',
    ],
  },
  {
    // Support carries no per-operation charge. Stated qualitatively on purpose:
    // the previous page named specific tiers ("Community on free tier",
    // "Dedicated on custom plans") that nothing in the product backs.
    group: 'Support',
    items: [
      'In-app help center',
      'Support tickets from the dashboard',
      'Documentation and API reference',
      'Dedicated support on custom plans',
    ],
  },
];

/* The only things that genuinely need a conversation: their cost is set
   outside the platform, by a registry, a card network, or a tax authority. */
const quoted = [
  { name: 'Domain registration, transfer and renewal', reason: 'set by the extension and the registry' },
  { name: 'Payment processing', reason: 'set by the card networks in your country' },
  { name: 'Electronic invoicing', reason: 'set by your tax authority’s certification regime' },
  { name: 'Link building placements', reason: 'set by the publisher you place with' },
  { name: 'Volume rates for metered operations', reason: 'set against the volume you expect to run' },
];
---

<BaseLayout title={title} description={description} jsonLd={pageJsonLd}>
  <Hero
    headline="Pay for the operations you run."
    subheadline="No subscription and no seat count. Your account holds a balance, each operation draws from it at a per-unit rate, and everything else that comes with the platform is not metered at all."
    primaryCta={{ label: 'Start Free', href: 'https://app.1platform.pro/app/' }}
    secondaryCta={{ label: 'Contact Sales', href: '/contact/' }}
    badge="Pricing"
  />

  <div class="crumbs">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Pricing' },
      ]} />
    </div>
  </div>

  <!-- The model, as four checkable facts rather than four large numbers -->
  <section class="section" id="model">
    <div class="container">
      <div class="statement reveal">
        <p class="eyebrow">The model</p>
        <h2 class="statement__lead">There is no plan to choose. There is a balance.</h2>
      </div>

      <ol class="model">
        {model.map((item, i) => (
          <li class="model__item reveal">
            <p class="model__label">
              <span class="model__num">{String(i + 1).padStart(2, '0')}</span>
              {item.label}
            </p>
            <p class="model__body">{item.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- The mechanism, drawn on the spine -->
  <section class="section section--alt" id="how-a-charge-works">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">How a charge works</p>
      </div>
      <h2 class="section__lead">A hold first, a charge only if the work lands.</h2>
      <ProcessSpine steps={chargeSteps} label="How a single charge moves through your balance" />
    </div>
  </section>

  <!-- The rate card: what is metered, and by what unit -->
  <section class="section" id="metered">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Metered operations</p>
      </div>

      <div class="rates__intro">
        <h2>What draws from your balance, and by what unit</h2>
        <p>
          The unit is fixed — it is what one charge covers. The rate attached to
          each unit is set per account, because it moves with volume and with
          where you operate, so it lives on your rate card rather than on a
          public list.
        </p>
      </div>

      <ul class="rates">
        {metered.map((item) => (
          <li class="rates__row reveal">
            <span class="rates__icon"><Icon name={item.icon} size={20} /></span>
            <div class="rates__main">
              <h3 class="rates__name">{item.name}</h3>
              <p class="rates__note">{item.note}</p>
            </div>
            <span class="rates__unit">{item.unit}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- The other half of the answer: what is not metered at all -->
  <section class="section section--alt" id="included">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Not metered</p>
      </div>
      <h2 class="section__lead">Included with the account, at no per-operation charge.</h2>

      <div class="included">
        {included.map((column) => (
          <div class="included__group">
            <h3 class="included__title">{column.group}</h3>
            <ul class="included__list">
              {column.items.map((item) => (
                <li class="included__item">
                  <Check yes={true} label="Included" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <p class="included__all">
        <a href="/solutions/" class="link-cue">
          See what each solution does
          <Icon name="arrow-right" size={15} />
        </a>
      </p>
    </div>
  </section>

  <!-- Two honest routes in: open an account, or ask for a rate card -->
  <section class="section" id="start">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Two ways to start</p>
      </div>

      <div class="panels">
        <div class="panel card reveal">
          <p class="panel__kicker">Open an account</p>
          <h3 class="panel__title">Start on the free plan</h3>
          <p class="panel__body">
            No credit card. You get a daily allowance for content generation and
            keyword extraction, and the full REST API from the first request.
            When the allowance stops being enough, add balance — the code you
            wrote against it does not change.
          </p>
          <a href="https://app.1platform.pro/app/" class="btn btn--primary panel__cta">Start Free</a>
        </div>

        <div class="panel card reveal">
          <p class="panel__kicker">Get a quote</p>
          <h3 class="panel__title">Ask for your rate card</h3>
          <p class="panel__body">
            Some costs are not ours to publish — they are set outside the
            platform and passed through. Those, plus volume rates, are what a
            quote is actually for:
          </p>
          <ul class="panel__list">
            {quoted.map((item) => (
              <li>
                <span class="panel__list-name">{item.name}</span>
                <span class="panel__list-reason">{item.reason}</span>
              </li>
            ))}
          </ul>
          <a href="/contact/" class="btn btn--ghost panel__cta">Contact Sales</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt" id="faq">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Questions</p>
      </div>
      <h2 class="section__lead">The rest of what people ask before they start.</h2>

      <div class="faq">
        {faqs.map((faq) => (
          <details class="faq__item reveal">
            <summary class="faq__q">
              <span>{faq.question}</span>
              <span class="faq__chevron"><Icon name="chevron-down" size={18} /></span>
            </summary>
            <div class="faq__a">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
  <!-- The closing CTA lives in the footer, on every page — see Footer.astro. -->
</BaseLayout>

<style>
  /* Breadcrumbs sit tight under the hero rather than owning a full section
     band of their own. */
  .crumbs {
    padding-block: var(--space-6);
  }

  /* ===== Opening statement ===== */
  .statement {
    max-width: 40rem;
    margin-bottom: var(--space-12);
  }

  .statement__lead {
    font-size: var(--text-4xl);
    margin-top: var(--space-4);
  }

  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-10);
  }

  /* ===== The model: four statements on rules, numbered in mono ===== */
  .model {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0 var(--space-12);
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 58rem;
  }

  .model__item {
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  /* The last row in each column closes the block. */
  .model__item:nth-last-child(-n + 2) {
    border-bottom: 1px solid var(--color-border);
  }

  .model__label {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .model__num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .model__body {
    font-size: var(--text-sm);
    margin: 0;
  }

  /* ===== Rate card ===== */
  .rates__intro {
    max-width: 40rem;
    margin-bottom: var(--space-10);
  }

  .rates__intro h2 {
    margin-bottom: var(--space-4);
  }

  .rates {
    display: grid;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .rates__row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: baseline;
    column-gap: var(--space-5);
    padding-block: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .rates__row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .rates__icon {
    display: inline-flex;
    color: var(--color-accent);
    /* Baseline alignment would hang the glyph off the cap height. */
    align-self: start;
    padding-top: 2px;
  }

  .rates__main {
    min-width: 0;
  }

  .rates__name {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .rates__note {
    font-size: var(--text-sm);
    margin: 0;
  }

  /* The unit is the data on this page, so it is set in the data face. */
  .rates__unit {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    white-space: nowrap;
    text-align: right;
  }

  /* ===== Not metered ===== */
  /* Count-agnostic, so adding a group doesn't strand one on its own row. */
  .included {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-8);
  }

  .included__title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-5);
  }

  .included__list {
    display: grid;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .included__item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .included__all {
    margin-top: var(--space-10);
  }

  .link-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .link-cue:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* ===== The two routes in ===== */
  .panels {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    align-items: start;
  }

  .panel {
    display: flex;
    flex-direction: column;
    padding: var(--space-8);
  }

  .panel__kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .panel__title {
    margin-bottom: var(--space-3);
  }

  .panel__body {
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
  }

  .panel__list {
    display: grid;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-6);
  }

  .panel__list li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2);
    padding-block: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .panel__list li:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .panel__list-name {
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .panel__list-reason {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .panel__cta {
    align-self: flex-start;
    margin-top: auto;
  }

  /* ===== FAQ ===== */
  .faq {
    display: grid;
    gap: 0;
    max-width: 46rem;
  }

  .faq__item {
    border-top: 1px solid var(--color-border);
  }

  .faq__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .faq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    min-height: 44px;
    padding-block: var(--space-5);
    cursor: pointer;
    font-weight: 500;
    color: var(--color-text);
    font-size: var(--text-base);
    list-style: none;
  }

  .faq__q::-webkit-details-marker {
    display: none;
  }

  .faq__q::marker {
    content: '';
  }

  .faq__chevron {
    display: inline-flex;
    flex-shrink: 0;
    color: var(--color-text-tertiary);
  }

  @media (prefers-reduced-motion: no-preference) {
    .faq__chevron {
      transition: transform var(--duration-normal) var(--ease-out-expo);
    }
  }

  .faq__item[open] .faq__chevron {
    transform: rotate(180deg);
  }

  .faq__item[open] .faq__q {
    color: var(--color-accent);
  }

  .faq__a {
    padding-bottom: var(--space-5);
    max-width: 40rem;
  }

  .faq__a p {
    font-size: var(--text-sm);
    line-height: 1.7;
    margin: 0;
  }

  .faq__q:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: var(--border-radius);
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .included {
      grid-template-columns: repeat(2, 1fr);
    }

    .panels {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .statement__lead {
      font-size: var(--text-3xl);
    }

    .model,
    .included {
      grid-template-columns: 1fr;
    }

    /* Single column: only the true last item closes the block. */
    .model__item:nth-last-child(-n + 2) {
      border-bottom: none;
    }

    .model__item:last-child {
      border-bottom: 1px solid var(--color-border);
    }

    /* The unit drops under the name rather than squeezing the note. */
    .rates__row {
      grid-template-columns: auto minmax(0, 1fr);
      row-gap: var(--space-2);
    }

    .rates__unit {
      grid-column: 2;
      text-align: left;
    }

    .panel {
      padding: var(--space-6);
    }
  }
</style>
