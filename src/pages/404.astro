---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Page Not Found | 1Platform';
const description = 'The page you are looking for could not be found. Navigate back to the 1Platform homepage or explore our solutions and documentation.';
---

<BaseLayout title={title} description={description}>
  <section class="error-page dot-grid">
    <div class="container error-page__content">
      <p class="error-page__code gradient-text">404</p>
      <h1>Page Not Found</h1>
      <p class="error-page__message">The page you are looking for does not exist, has been moved, or is temporarily unavailable.</p>

      <nav class="error-page__nav" aria-label="Helpful links">
        <h2 class="sr-only">Helpful Links</h2>
        <ul>
          <li>
            <a href="/" class="error-page__link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              <span>Home</span>
            </a>
          </li>
          <li>
            <a href="/solutions/" class="error-page__link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              <span>Solutions</span>
            </a>
          </li>
          <li>
            <a href="/docs/" class="error-page__link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              <span>Docs</span>
            </a>
          </li>
          <li>
            <a href="/blog/" class="error-page__link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              <span>Blog</span>
            </a>
          </li>
        </ul>
      </nav>

      <a href="/" class="btn btn--primary error-page__cta">Back to Homepage</a>
    </div>
  </section>
</BaseLayout>

<style>
  .error-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--header-height));
    padding-block: var(--space-20);
    text-align: center;
  }

  .error-page__content {
    max-width: 560px;
    margin-inline: auto;
  }

  .error-page__code {
    font-size: clamp(6rem, 15vw, 12rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: var(--space-4);
  }

  .error-page h1 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .error-page__message {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-10);
    max-width: 440px;
    margin-inline: auto;
  }

  .error-page__nav {
    margin-bottom: var(--space-10);
  }

  .error-page__nav ul {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .error-page__link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    font-weight: 500;
    min-height: 48px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .error-page__link {
      transition: border-color var(--duration-fast) ease,
                  color var(--duration-fast) ease,
                  box-shadow var(--duration-fast) ease;
    }
  }

  .error-page__link:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
    box-shadow: 0 0 20px var(--color-accent-glow);
  }

  .error-page__cta {
    min-width: 200px;
  }

  @media (max-width: 480px) {
    .error-page__nav ul {
      flex-direction: column;
      align-items: center;
    }

    .error-page__link {
      width: 100%;
      justify-content: center;
    }
  }
</style>
