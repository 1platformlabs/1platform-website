---
import BaseLayout from '@layouts/BaseLayout.astro';
import Icon from '@components/Icon.astro';
import type { IconName } from '@components/icons';

const title = 'Page Not Found | 1Platform';
const description = 'The page you are looking for could not be found. Navigate back to the 1Platform homepage or explore our solutions and documentation.';

const destinations: { icon: IconName; label: string; detail: string; href: string }[] = [
  { icon: 'home', label: 'Home', detail: 'What the platform does, start to finish.', href: '/' },
  { icon: 'layers', label: 'Solutions', detail: 'Stores, websites, payments, whitelabel.', href: '/solutions/' },
  { icon: 'logs', label: 'Docs', detail: 'API reference and integration guides.', href: 'https://developer.1platform.pro/' },
  { icon: 'content', label: 'Blog', detail: 'Product notes and how-to articles.', href: '/blog/' },
];
---

<BaseLayout title={title} description={description}>
  <section class="error">
    <div class="container error__inner">
      <div class="error__copy">
        <p class="eyebrow error__status">HTTP 404 — Not found</p>
        <h1 class="error__headline">This page isn't here.</h1>
        <p class="error__message">
          The address may have changed, the page may have been retired, or the link that
          brought you here may have a typo. Everything below still works.
        </p>
        <a href="/" class="btn btn--primary error__cta">Back to homepage</a>
      </div>

      <nav class="error__nav" aria-labelledby="error-nav-title">
        <h2 class="eyebrow" id="error-nav-title">Try one of these</h2>
        <ul class="destinations">
          {destinations.map((destination) => (
            <li>
              <a href={destination.href} class="destination">
                <span class="destination__icon"><Icon name={destination.icon} size={20} /></span>
                <span class="destination__body">
                  <span class="destination__label">{destination.label}</span>
                  <span class="destination__detail">{destination.detail}</span>
                </span>
                <span class="destination__cue" aria-hidden="true">
                  <Icon name="arrow-right" size={16} />
                </span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .error {
    display: flex;
    align-items: center;
    min-height: calc(100vh - var(--header-height));
    padding-block: var(--space-20);
  }

  /* Two columns: the explanation, then the way out. The old page stacked a
     giant gradient numeral over a centred row of pills on a dot grid. */
  .error__inner {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: var(--space-16);
    align-items: start;
  }

  /* The status code belongs to the same mono register as the rest of the
     system's labels — it is data, not decoration. */
  .error__status {
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
    display: block;
  }

  .error__headline {
    font-size: var(--text-5xl);
    line-height: 1.06;
    margin: var(--space-8) 0 var(--space-5);
  }

  .error__message {
    color: var(--color-text-secondary);
    max-width: 34rem;
    margin: 0 0 var(--space-8);
  }

  .error__cta {
    min-height: 44px;
  }

  .destinations {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0 0;
  }

  .destination {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-4);
    min-height: 44px;
    padding-block: var(--space-5);
    border-top: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .destinations li:last-child .destination {
    border-bottom: 1px solid var(--color-border);
  }

  .destination__icon {
    display: inline-flex;
    color: var(--color-accent);
  }

  .destination__body {
    display: grid;
    gap: 2px;
  }

  .destination__label {
    font-weight: 600;
  }

  .destination__detail {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .destination__cue {
    display: inline-flex;
    color: var(--color-text-tertiary);
  }

  .destination:hover .destination__label {
    color: var(--color-accent);
  }

  .destination:hover .destination__cue {
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .destination__cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .destination:hover .destination__cue :global(svg) {
      transform: translateX(3px);
    }
  }

  @media (max-width: 900px) {
    .error {
      min-height: 0;
      padding-block: var(--space-16);
    }

    .error__inner {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }
  }
</style>
