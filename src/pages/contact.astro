---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Icon from '@components/Icon.astro';
import type { IconName } from '@components/icons';

const title = 'Contact Sales — Custom Quotes & Onboarding | 1Platform';
const description = 'Talk to the 1Platform sales team. Custom quotes, demos, onboarding help, and partnership inquiries. Response within 24 hours, business days.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: title,
  description,
  url: 'https://1platform.pro/contact/',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Contact' },
    ],
  },
};

/** What the reader needs to know before writing — kept as a ledger, not as
 *  three identical boxes. */
const expectations: { icon: IconName; term: string; detail: string }[] = [
  {
    icon: 'clock',
    term: 'Response time',
    detail: 'Within 24 hours on business days (GMT-6).',
  },
  {
    icon: 'clipboard',
    term: 'What to include',
    detail: 'Use case, expected volume, team size, and any deadline you are working to.',
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="section">
    <div class="container">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />

      <div class="contact">
        <!-- Left: the ask -->
        <header class="contact__intro reveal">
          <p class="eyebrow">Talk to sales</p>
          <h1 class="contact__headline">
            Let's talk about <span class="contact__accent">your scale</span>.
          </h1>
          <p class="contact__sub">
            Need a custom quote, a live demo, or onboarding help for your team? Our sales engineers
            reply within <strong>24 hours</strong> on business days.
          </p>
          <p class="contact__topic" data-contact-topic hidden>
            Asking about <strong data-contact-topic-label></strong>
          </p>

          <dl class="expectations">
            {expectations.map((row) => (
              <div class="expectations__row">
                <dt class="expectations__term">
                  <span class="expectations__icon"><Icon name={row.icon} size={18} /></span>
                  {row.term}
                </dt>
                <dd class="expectations__detail">{row.detail}</dd>
              </div>
            ))}
            <div class="expectations__row">
              <dt class="expectations__term">
                <span class="expectations__icon"><Icon name="code" size={18} /></span>
                Technical questions
              </dt>
              <dd class="expectations__detail">
                Check the <a href="https://developer.1platform.pro/">developer documentation</a>
                first — it covers most integrations.
              </dd>
            </div>
          </dl>
        </header>

        <!-- Right: the address itself, given its own surface -->
        <div class="card contact__panel reveal">
          <div class="panel-mark" aria-hidden="true"><Icon name="mail" size={22} /></div>

          <h2 class="panel__title">Email sales</h2>

          <p
            class="panel__email"
            aria-label="sales at 1platform dot pro"
            data-contact-email
            data-user="sales"
            data-domain="1platform.pro"
          >
            <noscript>Enable JavaScript to see the email address, or use the Open Email button below.</noscript>
          </p>

          <div class="panel__actions">
            <button type="button" class="btn btn--primary" data-contact-open>
              Open Email
              <Icon name="arrow-right" size={16} />
            </button>
            <button type="button" class="btn btn--ghost" data-contact-copy aria-live="polite">
              Copy Email
            </button>
          </div>

          <p class="panel__hint">
            Already on 1Platform? Sign in at
            <a href="https://app.1platform.pro/app/">app.1platform.pro</a>
            and use the in-app chat for faster support.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const TOPIC_LABELS: Record<string, string> = {
    agency: 'Agency Inquiry',
    whitelabel: 'Whitelabel Inquiry',
    enterprise: 'Enterprise Inquiry',
    custom: 'Custom Pricing',
  };

  function resolveTopic(): { subject: string; label: string | null } {
    const raw = new URLSearchParams(globalThis.location.search).get('topic');
    if (!raw) return { subject: 'Sales Inquiry', label: null };
    const key = raw.toLowerCase().replace(/[^a-z]/g, '');
    const label = TOPIC_LABELS[key];
    if (label) return { subject: label, label };
    return { subject: 'Sales Inquiry', label: null };
  }

  function wireContactPage() {
    const target = document.querySelector('[data-contact-email]') as HTMLElement | null;
    const openBtn = document.querySelector('[data-contact-open]') as HTMLButtonElement | null;
    const copyBtn = document.querySelector('[data-contact-copy]') as HTMLButtonElement | null;
    const topicEl = document.querySelector('[data-contact-topic]') as HTMLElement | null;
    const topicLabelEl = document.querySelector('[data-contact-topic-label]') as HTMLElement | null;
    if (!target) return;

    const user = target.dataset.user ?? '';
    const dom = target.dataset.domain ?? '';
    if (!user || !dom) return;

    const email = user + '@' + dom;
    target.textContent = email;

    const { subject, label } = resolveTopic();
    if (label && topicEl && topicLabelEl) {
      topicLabelEl.textContent = label;
      topicEl.hidden = false;
    }

    openBtn?.addEventListener('click', () => {
      globalThis.location.href = 'mailto:' + email + '?subject=' + encodeURIComponent(subject);
    });

    copyBtn?.addEventListener('click', async () => {
      const original = copyBtn.textContent ?? 'Copy Email';
      try {
        await navigator.clipboard.writeText(email);
        copyBtn.textContent = 'Copied!';
      } catch {
        const range = document.createRange();
        range.selectNodeContents(target);
        const sel = globalThis.getSelection();
        sel?.removeAllRanges();
        sel?.addRange(range);
        copyBtn.textContent = 'Email selected — press Cmd/Ctrl+C';
      }
      globalThis.setTimeout(() => {
        copyBtn.textContent = original;
      }, 1800);
    });
  }

  document.addEventListener('astro:page-load', wireContactPage);
</script>

<style>
  /* Asymmetric split: the argument on the left, the address on the right.
     The old page stacked both, centred, down the middle of the viewport. */
  .contact {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 5fr);
    gap: var(--space-16);
    align-items: start;
    margin-top: var(--space-10);
  }

  .contact__intro {
    max-width: 34rem;
  }

  .contact__headline {
    font-size: var(--text-5xl);
    line-height: 1.06;
    text-wrap: balance;
    margin: var(--space-5) 0 var(--space-5);
  }

  /* The emphasis is carried by the one accent in the system, not by a
     gradient wash across the letterforms. */
  .contact__accent {
    color: var(--color-accent);
  }

  .contact__sub {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    margin: 0;
  }

  .contact__sub strong {
    color: var(--color-text);
    font-weight: 500;
  }

  .contact__topic {
    display: inline-block;
    margin: var(--space-5) 0 0;
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-accent-ring);
    border-radius: var(--border-radius);
  }

  .contact__topic strong {
    color: var(--color-accent);
    margin-left: var(--space-1);
  }

  /* ===== Expectations: term against detail, on hairlines ===== */
  .expectations {
    margin: var(--space-12) 0 0;
  }

  .expectations__row {
    display: grid;
    grid-template-columns: minmax(0, 12rem) minmax(0, 1fr);
    gap: var(--space-4);
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .expectations__row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .expectations__term {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .expectations__icon {
    display: inline-flex;
    color: var(--color-accent);
  }

  .expectations__detail {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  /* Underlined, not colour-only: a link sitting inside a run of text needs a
     non-colour cue. Matches the .prose a convention. */
  .expectations__detail a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ===== The address panel ===== */
  /* Surface comes from the shared .card; only the additive bits live here. */
  .contact__panel {
    position: sticky;
    top: calc(var(--header-height) + var(--space-8));
    padding: var(--space-8);
    box-shadow: var(--shadow-md);
  }

  .panel-mark {
    display: inline-flex;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .panel__title {
    font-size: var(--text-xl);
    margin: 0 0 var(--space-4);
  }

  .panel__email {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0 0 var(--space-6);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-muted);
    border-radius: var(--border-radius);
    user-select: all;
    word-break: break-all;
  }

  .panel__email noscript {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .panel__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .panel__actions .btn {
    min-height: 44px;
  }

  .panel__hint {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    margin: 0;
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .panel__hint a {
    color: var(--color-accent);
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .contact {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    /* Sticky is only useful next to a long column. */
    .contact__panel {
      position: static;
    }

    .contact__intro {
      max-width: none;
    }
  }

  @media (max-width: 600px) {
    .expectations__row {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .contact__panel {
      padding: var(--space-6);
    }
  }
</style>
