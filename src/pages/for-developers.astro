---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import FeatureCard from '@components/FeatureCard.astro';
import SolutionCard from '@components/SolutionCard.astro';
import CodeBlock from '@components/CodeBlock.astro';

const title = 'Ecommerce REST API for SaaS — Payments, Content, Whitelabel | 1Platform';
const description = 'Power your own SaaS on top of 1Platform. REST API with dual-token auth, async jobs, predictable JSON envelopes — payments, content, and whitelabel dashboard included.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: 'https://1platform.pro/for-developers/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'For Developers' },
    ],
  },
];

const features = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
    title: 'One REST API, two tokens',
    description: 'Dual-token auth: app token identifies your product, user token identifies the end user. Clean separation across every endpoint.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
    title: 'Async jobs by default',
    description: 'Long-running operations return a job ID. Poll, subscribe via webhook, or attach to in-app notifications.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>',
    title: 'Predictable JSON envelopes',
    description: 'Every endpoint returns { success, data, msg }. Consistent error model, standard HTTP statuses, no surprises.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92V21a1 1 0 0 1-1.09 1 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 3.18 4.18 1 1 0 0 1 4.21 3h4.09a1 1 0 0 1 1 .75 12.84 12.84 0 0 0 .7 2.81 1 1 0 0 1-.27 1L8.09 9.21a16 16 0 0 0 6 6l1.65-1.65a1 1 0 0 1 1-.27 12.84 12.84 0 0 0 2.81.7 1 1 0 0 1 .75 1z"/></svg>',
    title: 'Webhooks & observability',
    description: 'HMAC-signed payment lifecycle webhooks, allowed-domain registration, secret rotation, and detailed activity logs.',
  },
];

const related = [
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M2 7h20"/></svg>', title: 'Whitelabel Dashboard', description: 'Bootstrap a branded dashboard for your own SaaS in one API call.', href: '/solutions/whitelabel/' },
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/></svg>', title: 'Payments & Invoicing', description: 'Add payments and compliant invoicing to your product via REST.', href: '/payments-invoicing/' },
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>', title: 'AI Content Generation', description: 'Embed content generation, images, and SEO inside your product.', href: '/solutions/content/' },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="section section--breadcrumb">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'For Developers' },
      ]} />
    </div>
  </section>

  <Hero
    headline="Build on a Developer-Grade API"
    subheadline="Power your own SaaS on top of 1Platform. One REST API, two tokens, async jobs, predictable JSON envelopes — payments, content, and whitelabel dashboard included."
    badge="REST API · Async Jobs · Webhooks"
    primaryCta={{ label: 'Read API Docs', href: 'https://developer.1platform.pro/' }}
    secondaryCta={{ label: 'Power Your SaaS', href: '/solutions/whitelabel/' }}
  />

  <section class="section">
    <div class="container">
      <div class="section__header reveal">
        <h2>API Design Principles</h2>
        <p>A platform you can build a product on top of — without fighting the abstractions.</p>
      </div>
      <div class="grid-2 stagger-grid">
        {features.map((f) => (
          <FeatureCard icon={f.icon} title={f.title} description={f.description} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__header reveal">
        <h2>Code Samples</h2>
        <p>Same shape across every endpoint. Two tokens, JSON in, JSON out.</p>
      </div>
      <div class="code-stack">
        <CodeBlock
          language="bash"
          title="Generate an SEO article"
          code={`curl -X POST https://api.1platform.pro/api/v1/posts/content/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "keyword": "sustainable gardening tips",
    "lang": "en",
    "country": "us"
  }'`}
        />
        <CodeBlock
          language="bash"
          title="Create a payment transaction"
          code={`curl -X POST https://api.1platform.pro/api/v1/users/transactions \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "amount": 25.00,
    "description": "Order #1042"
  }'`}
        />
        <CodeBlock
          language="bash"
          title="Bootstrap a whitelabel dashboard"
          code={`curl -X GET https://api.1platform.pro/api/v1/dashboard/bootstrap \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN"`}
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="docs-callout reveal">
        <h2>Full API Reference</h2>
        <p>Interactive documentation, code examples in cURL, Python, and JavaScript — at developer.1platform.pro.</p>
        <div class="docs-callout__actions">
          <a href="https://developer.1platform.pro/" class="btn btn--primary">Read API Docs</a>
          <a href="https://developer.1platform.pro/api-docs" class="btn btn--ghost">API Reference</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__header reveal">
        <h2>Related Solutions</h2>
        <p>Power your product with the full platform.</p>
      </div>
      <div class="grid-3 stagger-grid">
        {related.map((r) => (
          <SolutionCard icon={r.icon} title={r.title} description={r.description} href={r.href} />
        ))}
      </div>
    </div>
  </section>

  <section class="section cta-banner">
    <div class="container">
      <div class="cta-banner__content reveal">
        <h2>Power Your Own SaaS</h2>
        <p>One REST API. Payments, content, whitelabel dashboard — everything you need to ship a product.</p>
        <div class="cta-banner__actions">
          <a href="https://developer.1platform.pro/" class="btn btn--primary">Read API Docs</a>
          <a href="/solutions/whitelabel/" class="btn btn--ghost">Whitelabel Your Dashboard</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section { padding-block: var(--space-20); }
  .section--breadcrumb { padding-block: var(--space-4) 0; padding-top: calc(var(--header-height) + var(--space-4)); }
  .section--alt {
    background-color: var(--color-bg-alt, #ffffff);
    border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);
  }
  .container { max-width: 1200px; margin-inline: auto; padding-inline: var(--space-6); }
  .section__header { text-align: center; max-width: 700px; margin-inline: auto; margin-bottom: var(--space-12); }
  .section__header h2 { font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-4); text-wrap: balance; }
  .section__header p { font-size: var(--text-lg); color: var(--color-text-secondary); }
  .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-6); }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  @media (max-width: 1024px) { .grid-3 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) {
    .grid-2, .grid-3 { grid-template-columns: 1fr; }
    .section { padding-block: var(--space-12); }
  }
  .code-stack {
    display: flex; flex-direction: column; gap: var(--space-6);
    max-width: 800px; margin-inline: auto;
  }
  .docs-callout {
    text-align: center; max-width: 700px; margin-inline: auto;
  }
  .docs-callout h2 { font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-4); text-wrap: balance; }
  .docs-callout p { font-size: var(--text-lg); color: var(--color-text-secondary); margin-bottom: var(--space-8); }
  .docs-callout__actions, .cta-banner__actions { display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap; }
  .cta-banner {
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.06), rgba(8, 145, 178, 0.05));
    border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);
  }
  .cta-banner__content { text-align: center; max-width: 700px; margin-inline: auto; }
  .cta-banner__content h2 { font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-4); text-wrap: balance; }
  .cta-banner__content p { font-size: var(--text-lg); color: var(--color-text-secondary); margin-bottom: var(--space-8); }
</style>
