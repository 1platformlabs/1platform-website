---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import Icon from '@components/Icon.astro';
import CodeBlock from '@components/CodeBlock.astro';
import type { IconName } from '@components/icons';

const title = 'Ecommerce REST API for SaaS — Payments, Content, Whitelabel | 1Platform';
const description = 'Power your SaaS on 1Platform. REST API with dual-token auth, async jobs, predictable JSON envelopes — payments, content, and whitelabel dashboard included.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: 'https://1platform.pro/for-developers/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'For Developers' },
    ],
  },
];

const principles: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'code',
    title: 'One REST API, two tokens',
    description: 'Dual-token auth: the app token identifies your product, the user token identifies the end user. The same separation on every endpoint.',
  },
  {
    icon: 'clock',
    title: 'Async jobs by default',
    description: 'Long-running operations return a job ID. Poll it, subscribe by webhook, or attach it to in-app notifications.',
  },
  {
    icon: 'console',
    title: 'Predictable JSON envelopes',
    description: 'Every endpoint returns the same envelope. Consistent error model, standard HTTP statuses, no per-endpoint surprises.',
  },
  {
    icon: 'webhook',
    title: 'Webhooks & observability',
    description: 'HMAC-signed payment lifecycle webhooks, allowed-domain registration, secret rotation, and detailed activity logs.',
  },
];

/** The contract, stated once so the samples below don't have to repeat it. */
const contract = [
  { term: 'Base URL', value: 'https://api.1platform.pro/api/v1/' },
  { term: 'App token', value: 'Authorization: Bearer' },
  { term: 'User token', value: 'x-user-token' },
  { term: 'Envelope', value: '{ success, data, msg }' },
];

const related: { icon: IconName; title: string; description: string; href: string }[] = [
  {
    icon: 'dashboard',
    title: 'Whitelabel Dashboard',
    description: 'Bootstrap a branded dashboard for your own SaaS in one API call.',
    href: '/solutions/whitelabel/',
  },
  {
    icon: 'card',
    title: 'Payments & Invoicing',
    description: 'Add payments and compliant invoicing to your product via REST.',
    href: '/payments-invoicing/',
  },
  {
    icon: 'content',
    title: 'AI Content Generation',
    description: 'Embed content generation, images and SEO inside your product.',
    href: '/solutions/content/',
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="container crumbs">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'For Developers' },
    ]} />
  </div>

  <Hero
    headline="Build on a developer-grade API"
    subheadline="Power your own SaaS on top of 1Platform. One REST API, two tokens, async jobs, predictable JSON envelopes — payments, content and whitelabel dashboard included."
    badge="REST API · Async Jobs · Webhooks"
    primaryCta={{ label: 'Read API Docs', href: 'https://developer.1platform.pro/' }}
    secondaryCta={{ label: 'Power Your SaaS', href: '/solutions/whitelabel/' }}
  />

  <!-- Design principles -->
  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">API design</p>
      </div>
      <h2 class="section__lead">A platform you can build a product on, without fighting the abstractions</h2>

      <div class="principles">
        {principles.map((principle) => (
          <Card
            variant="bare"
            icon={principle.icon}
            title={principle.title}
            description={principle.description}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- The contract, then the samples that follow it -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Code samples</p>
      </div>
      <h2 class="section__lead">Same shape across every endpoint</h2>

      <div class="samples">
        <div class="samples__contract">
          <dl class="contract">
            {contract.map((item) => (
              <div class="contract__row">
                <dt>{item.term}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
          <p class="samples__note">
            Two tokens, JSON in, JSON out. The calls below reach three different capabilities
            and are still the same request.
          </p>
        </div>

        <div class="samples__stack">
          <CodeBlock
            language="bash"
            title="Generate an SEO article"
            code={`curl -X POST https://api.1platform.pro/api/v1/posts/content/ \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "keyword": "sustainable gardening tips",
    "lang": "en",
    "country": "us"
  }'`}
          />
          <CodeBlock
            language="bash"
            title="Create a payment transaction"
            code={`curl -X POST https://api.1platform.pro/api/v1/users/transactions \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d '{
    "amount": 25.00,
    "description": "Order #1042"
  }'`}
          />
          <CodeBlock
            language="bash"
            title="Bootstrap a whitelabel dashboard"
            code={`curl -X GET https://api.1platform.pro/api/v1/dashboard/bootstrap \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN"`}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Reference -->
  <section class="section">
    <div class="container">
      <div class="panel reveal">
        <div class="panel__copy">
          <p class="eyebrow">Reference</p>
          <h2>The full API reference</h2>
          <p>
            Interactive documentation with code examples in cURL, Python and JavaScript,
            at developer.1platform.pro.
          </p>
        </div>
        <div class="panel__actions">
          <a href="https://developer.1platform.pro/" class="btn btn--primary">Read API Docs</a>
          <a href="https://developer.1platform.pro/api-docs" class="btn btn--ghost">API Reference</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Related</p>
      </div>
      <h2 class="section__lead">Power your product with the rest of the platform</h2>

      <ul class="related">
        {related.map((item) => (
          <li>
            <a href={item.href} class="related__link">
              <span class="related__icon"><Icon name={item.icon} size={20} /></span>
              <span class="related__text">
                <span class="related__title">{item.title}</span>
                <span class="related__desc">{item.description}</span>
              </span>
              <Icon name="arrow-right" size={16} class="related__arrow" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
  <!-- The closing CTA lives in the footer, on every page — see Footer.astro. -->
</BaseLayout>

<style>
  /* Breadcrumbs clear the fixed header; the hero then drops its own top
     offset so the two don't stack into a canyon of whitespace. */
  .crumbs {
    padding-top: calc(var(--header-height) + var(--space-8));
  }

  .crumbs + :global(.hero) {
    padding-top: var(--space-6);
  }

  .section__lead {
    max-width: 36rem;
    margin-bottom: var(--space-10);
  }

  /* ===== Principles ===== */
  .principles {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-10) var(--space-12);
  }

  /* ===== Samples: the contract on a rail, the calls beside it ===== */
  .samples {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 7fr);
    gap: var(--space-12);
    align-items: start;
  }

  .samples__contract {
    position: sticky;
    top: calc(var(--header-height) + var(--space-8));
  }

  .contract {
    border-top: 1px solid var(--color-border);
  }

  .contract__row {
    display: grid;
    gap: var(--space-1);
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    min-width: 0;
  }

  .contract dt {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  .contract dd {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
    overflow-wrap: anywhere;
  }

  .samples__note {
    margin-top: var(--space-6);
    font-size: var(--text-sm);
  }

  /* Grid children default to min-width:auto, which lets a long code line push
     the whole page wider than the viewport. */
  .samples__stack {
    display: grid;
    gap: var(--space-6);
    min-width: 0;
  }

  /* ===== Reference panel ===== */
  .panel {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 4fr);
    gap: var(--space-10);
    align-items: end;
    padding: var(--space-10);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    background: var(--color-bg-alt);
  }

  .panel__copy h2 {
    font-size: var(--text-3xl);
    margin-block: var(--space-3) var(--space-4);
  }

  .panel__copy p {
    max-width: 38rem;
    margin: 0;
  }

  .panel__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ===== Related ===== */
  .related {
    display: grid;
    max-width: 52rem;
  }

  .related li {
    border-top: 1px solid var(--color-border);
  }

  .related li:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .related__link {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding-block: var(--space-5);
    color: var(--color-text);
  }

  .related__icon {
    display: inline-flex;
    color: var(--color-accent);
  }

  .related__text {
    display: grid;
    gap: var(--space-1);
    flex: 1;
    min-width: 0;
  }

  .related__title {
    font-weight: 600;
  }

  .related__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .related__link :global(.related__arrow) {
    color: var(--color-text-tertiary);
  }

  .related__link:hover {
    color: var(--color-accent);
  }

  .related__link:hover :global(.related__arrow) {
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .related__link :global(.related__arrow) {
      transition: transform var(--duration-fast) var(--ease-out-expo),
                  color var(--duration-fast) ease;
    }

    .related__link:hover :global(.related__arrow) {
      transform: translateX(3px);
    }
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .samples {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .samples__contract {
      position: static;
    }

    .panel {
      grid-template-columns: 1fr;
      align-items: start;
      gap: var(--space-8);
      padding: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .principles {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
