---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import Icon from '@components/Icon.astro';
import ProcessSpine from '@components/ProcessSpine.astro';
import CodeBlock from '@components/CodeBlock.astro';
import type { IconName } from '@components/icons';

const title = 'Whitelabel Dashboard — Branded SaaS in One API Call | 1Platform';
const description = 'Bootstrap a fully branded dashboard from one API call — branding, theme, layout, i18n, and home KPIs. Power your own product under your brand.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Whitelabel Dashboard',
    provider: { '@type': 'Organization', name: '1Platform Labs', url: 'https://1platform.pro' },
    description,
    url: 'https://1platform.pro/solutions/whitelabel/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Solutions', item: 'https://1platform.pro/solutions/' },
      { '@type': 'ListItem', position: 3, name: 'Whitelabel' },
    ],
  },
];

/**
 * What the bootstrap response actually resolves, as a spec rather than four
 * feature tiles.
 *
 * The last row used to assert production readiness by gesturing at an
 * unnamed, uncountable set of existing customers — traction a reader has no
 * way to check. It now states the one thing that is verifiable: the 1Platform
 * dashboard is itself a consumer of this contract.
 */
const spec = [
  {
    term: 'Branding & theme',
    detail: 'Logo, palette, typography, layout, enabled modules, and feature flags — all returned in a single bootstrap response, so the shell renders branded on first paint.',
  },
  {
    term: 'Localization',
    detail: 'Localized bundles served per tenant. Language packs reload without redeploying the dashboard.',
  },
  {
    term: 'Home KPIs',
    detail: 'Balance, unread counts, in-flight counters, and feature gates resolved in the same call — no extra round trips before the first screen is useful.',
  },
  {
    term: 'The contract we use ourselves',
    detail: 'The 1Platform dashboard is built on this bootstrap response. You are configuring the same surface we ship, not a separate whitelabel edition of it.',
  },
];

const whitelabelSteps = [
  { label: 'Configure your tenant' },
  { label: 'Set branding & theme' },
  { label: 'Bootstrap the dashboard' },
  { label: 'Launch under your brand' },
];

const related: { icon: IconName; title: string; description: string; href: string }[] = [
  {
    icon: 'code',
    title: 'For Developers',
    description: 'Power your own SaaS on top of the platform — REST API, async jobs, predictable envelopes.',
    href: '/for-developers/',
  },
  {
    icon: 'users',
    title: 'For Agencies',
    description: 'Run dozens of client stores and websites from one dashboard.',
    href: '/for-agencies/',
  },
  {
    icon: 'card',
    title: 'Payments & Invoicing',
    description: 'Built-in payments and electronic invoicing across every tenant.',
    href: '/payments-invoicing/',
  },
];
---

<BaseLayout title={title} description={description} ogImage="/og/solution-whitelabel.png" jsonLd={jsonLd}>
  <div class="page-top">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Solutions', href: '/solutions/' },
        { label: 'Whitelabel' },
      ]} />
    </div>
  </div>

  <Hero
    headline="Your own brand, your own dashboard"
    subheadline="Bootstrap a fully branded dashboard from one API call. Branding, theme, layout, i18n, and home KPIs — everything your users see, under your name."
    badge="Whitelabel Dashboard"
    primaryCta={{ label: 'Talk to Sales', href: '/contact/?topic=whitelabel' }}
    secondaryCta={{ label: 'Read API Docs', href: 'https://developer.1platform.pro/' }}
  />

  <!-- The subject of the page is one request, so it opens with the request -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split__copy reveal">
          <p class="eyebrow">One bootstrap call</p>
          <h2>Everything the dashboard needs, in a single response</h2>
          <p>
            No configuration bundle to build, no theme file to ship, no second request
            before the first screen is useful. Authenticate as the tenant and the shell
            comes back branded.
          </p>
          <a href="https://developer.1platform.pro/" class="link-cue">
            Read the bootstrap reference
            <Icon name="arrow-right" size={15} />
          </a>
        </div>

        <div class="split__demo">
          <CodeBlock
            language="bash"
            title="Bootstrap a branded dashboard"
            code={`curl -X GET https://api.1platform.pro/api/v1/dashboard/bootstrap \\
  -H "Authorization: Bearer $APP_TOKEN" \\
  -H "x-user-token: $USER_TOKEN"`}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- What the response resolves, read as a spec -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">What you get</p>
      </div>
      <h2 class="section__lead">What the bootstrap response resolves</h2>

      <dl class="spec">
        {spec.map((row) => (
          <div class="spec__row">
            <dt class="spec__term">{row.term}</dt>
            <dd class="spec__detail">{row.detail}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">How it works</p>
      </div>
      <h2 class="section__lead">
        From tenant configuration to a branded dashboard in production.
      </h2>
      <ProcessSpine steps={whitelabelSteps} label="How to launch a whitelabel dashboard, step by step" />
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Related solutions</p>
      </div>
      <h2 class="section__lead">Whitelabel pairs naturally with the rest of the platform.</h2>
      <div class="related">
        {related.map((item) => (
          <Card
            icon={item.icon}
            title={item.title}
            description={item.description}
            href={item.href}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Page-specific next step. The general closing CTA lives in the footer. -->
  <section class="section">
    <div class="container">
      <div class="next reveal">
        <div>
          <p class="eyebrow">Next step</p>
          <h2 class="next__title">Ready to whitelabel?</h2>
          <p class="next__desc">
            Talk to sales about pricing and onboarding for your tenant, or read the API
            reference and try the bootstrap call first.
          </p>
        </div>
        <div class="next__actions">
          <a href="/contact/?topic=whitelabel" class="btn btn--primary">Talk to Sales</a>
          <a href="https://developer.1platform.pro/" class="btn btn--ghost">Read API Docs</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* The hero carries its own header offset, so it is neutralised below the
     breadcrumb strip to avoid stacking two header heights of space. */
  .page-top {
    padding-top: calc(var(--header-height) + var(--space-8));
  }

  .page-top + :global(.hero) {
    padding-top: var(--space-6);
  }

  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-10);
  }

  /* ===== Split: the claim and the request that backs it ===== */
  .split {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
    gap: var(--space-12);
    align-items: center;
  }

  .split__copy h2 {
    margin-block: var(--space-4);
  }

  .split__copy p {
    margin: 0;
  }

  /* Long code lines would otherwise widen the whole page. */
  .split__demo {
    min-width: 0;
  }

  /* ===== Spec list: mono term, prose detail, on hairlines ===== */
  .spec {
    margin: 0;
    max-width: 60rem;
  }

  .spec__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: var(--space-8);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .spec__row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .spec__term {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
  }

  .spec__detail {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
    min-width: 0;
  }

  /* ===== Related ===== */
  .related {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .link-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    min-height: 44px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .link-cue:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* ===== Closing band ===== */
  .next {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .next__title {
    font-size: var(--text-3xl);
    margin-block: var(--space-4);
  }

  .next__desc {
    max-width: 34rem;
    margin: 0;
  }

  .next__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .split {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .related {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .spec__row {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .related {
      grid-template-columns: 1fr;
    }
  }
</style>
