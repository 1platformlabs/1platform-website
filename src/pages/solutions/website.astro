---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import FeatureCard from '@components/FeatureCard.astro';
import SolutionCard from '@components/SolutionCard.astro';
import PipelineAnimation from '@components/PipelineAnimation.astro';
import ComparisonTable from '@components/ComparisonTable.astro';

const title = 'Website Builder with AI Content & Custom Domain | 1Platform';
const description = 'Build a website with AI-generated content, your own custom domain, and integrated CMS publishing — all from one platform. No plugins, no setup.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Website Builder',
    provider: { '@type': 'Organization', name: '1Platform Labs', url: 'https://1platform.pro' },
    description,
    url: 'https://1platform.pro/solutions/website/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Solutions', item: 'https://1platform.pro/solutions/' },
      { '@type': 'ListItem', position: 3, name: 'Website' },
    ],
  },
];

const features = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
    title: 'Custom domain included',
    description: 'Register or transfer a domain in minutes. DNS, nameservers, and renewals handled — no separate registrar account.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
    title: 'AI-generated content',
    description: 'Articles, landing copy, comments, and legal pages — generated and optimized for search in minutes.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>',
    title: 'CMS publishing',
    description: 'Publish directly to WordPress and other CMS platforms via API. Schedule posts, set categories, manage media.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
    title: 'Built for SEO',
    description: 'Keyword intelligence, automatic indexing submission, and link-building marketplace baked in.',
  },
];

const websiteSteps = [
  { label: 'Create your account', icon: '&#128100;' },
  { label: 'Connect your domain', icon: '&#127760;' },
  { label: 'Generate content with AI', icon: '&#9997;' },
  { label: 'Publish & rank', icon: '&#128640;' },
];

const comparisonRows = [
  { without: 'Website builder — around $20/mo', with_: 'Website included' },
  { without: 'AI writing tool — around $49/mo', with_: 'AI content built in' },
  { without: 'Stock images — around $29/mo', with_: 'AI images included' },
  { without: 'Domain registrar — separate dashboard', with_: 'Domain managed for you' },
];

const related = [
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>', title: 'AI Content Generation', description: 'Generate full SEO-optimized articles, descriptions, and landing copy.', href: '/solutions/content/' },
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>', title: 'Online Store', description: 'Add a storefront with checkout, payments, and invoicing.', href: '/solutions/online-store/' },
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>', title: 'For Developers', description: 'Use 1Platform as a backend for your own product via REST API.', href: '/for-developers/' },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="section section--breadcrumb">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Solutions', href: '/solutions/' },
        { label: 'Website' },
      ]} />
    </div>
  </section>

  <Hero
    headline="Your Website, Your Domain, Your Brand"
    subheadline="Launch a website with AI-generated content, your own custom domain, and integrated publishing — all from one platform. No plugins, no setup, no patchwork."
    badge="Website Builder"
    primaryCta={{ label: 'Build Your Site', href: 'https://app.1platform.pro/app/?intent=website' }}
    secondaryCta={{ label: 'See Pricing', href: '/pricing/' }}
  />

  <section class="section">
    <div class="container">
      <div class="section__header reveal">
        <h2>What You Get</h2>
        <p>A complete website toolkit — content, domain, publishing, and SEO baked in.</p>
      </div>
      <div class="grid-2 stagger-grid">
        {features.map((f) => (
          <FeatureCard icon={f.icon} title={f.title} description={f.description} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__header reveal">
        <h2>How It Works</h2>
        <p>Four steps from idea to live website.</p>
      </div>
      <PipelineAnimation steps={websiteSteps} />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header reveal">
        <h2>What It Replaces</h2>
        <p>One platform, not five different tools.</p>
      </div>
      <ComparisonTable rows={comparisonRows} />
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="pricing-callout reveal">
        <h2>Transparent Pricing</h2>
        <p>Pay only for what you use — no subscriptions, no hidden fees.</p>
        <div class="pricing-callout__actions">
          <a href="/pricing/" class="btn btn--primary">View Pricing</a>
          <a href="https://app.1platform.pro/app/?intent=website" class="btn btn--ghost">Start Free</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header reveal">
        <h2>Related Solutions</h2>
        <p>Grow your website with the rest of the platform.</p>
      </div>
      <div class="grid-3 stagger-grid">
        {related.map((r) => (
          <SolutionCard icon={r.icon} title={r.title} description={r.description} href={r.href} />
        ))}
      </div>
    </div>
  </section>

  <section class="section cta-banner">
    <div class="container">
      <div class="cta-banner__content reveal">
        <h2>Ready to Launch?</h2>
        <p>Stop stitching together five different tools. Build your website with one platform — content, domain, and SEO included.</p>
        <div class="cta-banner__actions">
          <a href="https://app.1platform.pro/app/?intent=website" class="btn btn--primary">Build Your Site</a>
          <a href="https://developer.1platform.pro/" class="btn btn--ghost">For Developers</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section { padding-block: var(--space-20); }
  .section--breadcrumb {
    padding-block: var(--space-4) 0;
    padding-top: calc(var(--header-height) + var(--space-4));
  }
  .section--alt {
    background-color: var(--color-bg-alt, #ffffff);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .container { max-width: 1200px; margin-inline: auto; padding-inline: var(--space-6); }
  .section__header { text-align: center; max-width: 700px; margin-inline: auto; margin-bottom: var(--space-12); }
  .section__header h2 { font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-4); text-wrap: balance; }
  .section__header p { font-size: var(--text-lg); color: var(--color-text-secondary); }
  .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-6); }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  @media (max-width: 1024px) { .grid-3 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) {
    .grid-2, .grid-3 { grid-template-columns: 1fr; }
    .section { padding-block: var(--space-12); }
  }
  .pricing-callout { text-align: center; max-width: 700px; margin-inline: auto; }
  .pricing-callout h2 { font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-4); text-wrap: balance; }
  .pricing-callout p { font-size: var(--text-lg); color: var(--color-text-secondary); margin-bottom: var(--space-8); }
  .pricing-callout__actions, .cta-banner__actions { display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap; }
  .cta-banner {
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.06), rgba(8, 145, 178, 0.05));
    border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);
  }
  .cta-banner__content { text-align: center; max-width: 700px; margin-inline: auto; }
  .cta-banner__content h2 { font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-4); text-wrap: balance; }
  .cta-banner__content p { font-size: var(--text-lg); color: var(--color-text-secondary); margin-bottom: var(--space-8); }
</style>
