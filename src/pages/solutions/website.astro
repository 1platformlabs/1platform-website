---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import Icon from '@components/Icon.astro';
import ProcessSpine from '@components/ProcessSpine.astro';
import ComparisonTable from '@components/ComparisonTable.astro';
import type { IconName } from '@components/icons';

const title = 'Website Builder with AI Content & Custom Domain | 1Platform';
const description = 'Build a website with AI-generated content, your own custom domain, and integrated CMS publishing — all from one platform. No plugins, no setup.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Website Builder',
    provider: { '@type': 'Organization', name: '1Platform Labs', url: 'https://1platform.pro' },
    description,
    url: 'https://1platform.pro/solutions/website/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Solutions', item: 'https://1platform.pro/solutions/' },
      { '@type': 'ListItem', position: 3, name: 'Website' },
    ],
  },
];

const features: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'globe',
    title: 'Custom domain included',
    description: 'Register or transfer a domain in minutes. DNS, nameservers, and renewals handled — no separate registrar account.',
  },
  {
    icon: 'content',
    title: 'AI-generated content',
    description: 'Articles, landing copy, comments, and legal pages — generated and optimized for search in minutes.',
  },
  {
    icon: 'cms',
    title: 'CMS publishing',
    description: 'Publish directly to WordPress and other CMS platforms via API. Schedule posts, set categories, manage media.',
  },
  {
    icon: 'indexing',
    title: 'Built for SEO',
    description: 'Keyword intelligence, automatic indexing submission, and link-building marketplace baked in.',
  },
];

const websiteSteps = [
  { label: 'Create your account' },
  { label: 'Connect your domain' },
  { label: 'Generate content with AI' },
  { label: 'Publish & rank' },
];

/**
 * Compared by what running a fragmented site stack actually involves. The
 * monthly prices this table used to quote were invented and are gone.
 */
const comparisonRows = [
  { without: 'A website builder on its own plan', with_: 'Website included' },
  { without: 'An AI writing tool on a separate subscription', with_: 'AI content built in' },
  { without: 'A stock image library billed separately', with_: 'AI images included' },
  { without: 'A registrar dashboard you log into separately', with_: 'Domain managed for you' },
];

const related: { icon: IconName; title: string; description: string; href: string }[] = [
  {
    icon: 'content',
    title: 'AI Content Generation',
    description: 'Generate full SEO-optimized articles, descriptions, and landing copy.',
    href: '/solutions/content/',
  },
  {
    icon: 'cart',
    title: 'Online Store',
    description: 'Add a storefront with checkout, payments, and invoicing.',
    href: '/solutions/online-store/',
  },
  {
    icon: 'code',
    title: 'For Developers',
    description: 'Use 1Platform as a backend for your own product via REST API.',
    href: '/for-developers/',
  },
];
---

<BaseLayout title={title} description={description} ogImage="/og/solution-website.png" jsonLd={jsonLd}>
  <div class="page-top">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Solutions', href: '/solutions/' },
        { label: 'Website' },
      ]} />
    </div>
  </div>

  <Hero
    headline="Your website, your domain, your brand"
    subheadline="Launch a website with AI-generated content, your own custom domain, and integrated publishing — all from one platform. No plugins, no setup, no patchwork."
    badge="Website Builder"
    primaryCta={{ label: 'Build Your Site', href: 'https://app.1platform.pro/app/?intent=website' }}
    secondaryCta={{ label: 'See Pricing', href: '/pricing/' }}
  />

  <!-- Capabilities as an editorial spread: claim held left, detail listed right -->
  <section class="section">
    <div class="container spread">
      <div class="spread__intro reveal">
        <p class="eyebrow">What you get</p>
        <h2 class="spread__title">
          A complete website toolkit, not a builder plus a stack of separate accounts.
        </h2>
        <p class="spread__desc">
          Content, domain, publishing, and SEO come from the same platform, so the
          pieces already know about each other.
        </p>
      </div>

      <ul class="capabilities">
        {features.map((feature) => (
          <li class="capabilities__item">
            <span class="capabilities__icon"><Icon name={feature.icon} size={20} /></span>
            <div class="capabilities__body">
              <h3 class="capabilities__title">{feature.title}</h3>
              <p class="capabilities__desc">{feature.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">How it works</p>
      </div>
      <h2 class="section__lead">Four steps from idea to live website.</h2>
      <ProcessSpine steps={websiteSteps} label="How to launch a website, step by step" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">What it replaces</p>
      </div>
      <h2 class="section__lead">One platform instead of separate tools</h2>
      <ComparisonTable rows={comparisonRows} />
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Related solutions</p>
      </div>
      <h2 class="section__lead">Grow your website with the rest of the platform.</h2>
      <div class="related">
        {related.map((item) => (
          <Card
            variant="bare"
            icon={item.icon}
            title={item.title}
            description={item.description}
            href={item.href}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Page-specific next step. The general closing CTA lives in the footer. -->
  <section class="section">
    <div class="container">
      <div class="next reveal">
        <div>
          <p class="eyebrow">Next step</p>
          <h2 class="next__title">Ready to launch?</h2>
          <p class="next__desc">
            Pay only for what you use — no subscriptions, no hidden fees. Build your
            website with content, domain, and SEO from one platform.
          </p>
          <a href="https://developer.1platform.pro/" class="link-cue">
            Read the API docs
            <Icon name="arrow-right" size={15} />
          </a>
        </div>
        <div class="next__actions">
          <a href="https://app.1platform.pro/app/?intent=website" class="btn btn--primary">Build Your Site</a>
          <a href="/pricing/" class="btn btn--ghost">View Pricing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* The hero carries its own header offset, so it is neutralised below the
     breadcrumb strip to avoid stacking two header heights of space. */
  .page-top {
    padding-top: calc(var(--header-height) + var(--space-8));
  }

  .page-top + :global(.hero) {
    padding-top: var(--space-6);
  }

  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-10);
  }

  /* ===== Editorial spread ===== */
  .spread {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
    gap: var(--space-16);
    align-items: start;
  }

  .spread__intro {
    position: sticky;
    top: calc(var(--header-height) + var(--space-10));
  }

  .spread__title {
    font-size: var(--text-3xl);
    margin-block: var(--space-4);
  }

  .spread__desc {
    margin: 0;
  }

  .capabilities {
    display: grid;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
    min-width: 0;
  }

  .capabilities__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .capabilities__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .capabilities__icon {
    display: inline-flex;
    color: var(--color-accent);
    padding-top: 2px;
  }

  .capabilities__body {
    min-width: 0;
  }

  .capabilities__title {
    font-size: var(--text-lg);
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .capabilities__desc {
    font-size: var(--text-sm);
    margin: 0;
  }

  /* ===== Related ===== */
  .related {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-10);
  }

  .link-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    min-height: 44px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .link-cue:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* ===== Closing band ===== */
  .next {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .next__title {
    font-size: var(--text-3xl);
    margin-block: var(--space-4);
  }

  .next__desc {
    max-width: 34rem;
    margin: 0;
  }

  .next__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .spread {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .spread__intro {
      position: static;
    }

    .related {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .related {
      grid-template-columns: 1fr;
    }

    .spread__title {
      font-size: var(--text-2xl);
    }
  }
</style>
