---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import FeatureCard from '@components/FeatureCard.astro';
import SolutionCard from '@components/SolutionCard.astro';
import PipelineAnimation from '@components/PipelineAnimation.astro';
import ComparisonTable from '@components/ComparisonTable.astro';

const title = 'Online Store Platform — Launch Your Store in Minutes | 1Platform';
const description = 'Launch a full online store with checkout, payments, electronic invoicing, and your own domain — all from one platform. No plugins, no patchwork.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Online Store',
    provider: { '@type': 'Organization', name: '1Platform Labs', url: 'https://1platform.pro' },
    description,
    url: 'https://1platform.pro/solutions/online-store/',
    areaServed: 'Worldwide',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Solutions', item: 'https://1platform.pro/solutions/' },
      { '@type': 'ListItem', position: 3, name: 'Online Store' },
    ],
  },
];

const iconCart = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>';
const iconCard = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>';
const iconInvoice = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>';
const iconDomain = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>';

const features = [
  { icon: iconCart, title: 'Storefront & checkout', description: 'Catalog, cart, and one-page checkout — ready to publish on your own domain.' },
  { icon: iconCard, title: 'Payments built in', description: 'Accept card payments out of the box. Webhook notifications and automatic balance reconciliation.' },
  { icon: iconInvoice, title: 'Compliant invoicing', description: 'Issue electronic invoices automatically for every transaction. PDF + XML included.' },
  { icon: iconDomain, title: 'Your own domain', description: 'Register or connect a domain in minutes. DNS, nameservers, and renewals handled for you.' },
];

const storeSteps = [
  { label: 'Create your account', icon: '&#128100;' },
  { label: 'Add products', icon: '&#128722;' },
  { label: 'Connect your domain', icon: '&#127760;' },
  { label: 'Go live', icon: '&#128640;' },
];

const comparisonRows = [
  { without: 'Ecommerce platform — around $30/mo', with_: 'Storefront included' },
  { without: 'Payment processor — separate account + fees', with_: 'Payments built in' },
  { without: 'Invoicing software — around $15/mo', with_: 'Electronic invoicing included' },
  { without: 'Domain registrar — separate dashboard', with_: 'Domain managed for you' },
];

const related = [
  { icon: iconCard, title: 'Payments & Invoicing', description: 'Accept payments and issue compliant electronic invoices — automatically.', href: '/payments-invoicing/' },
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>', title: 'AI Content Generation', description: 'Generate product descriptions, blog posts, and landing copy with AI.', href: '/solutions/content/' },
  { icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M2 7h20"/></svg>', title: 'Whitelabel Dashboard', description: 'Brand the entire experience under your own name — from a single API call.', href: '/solutions/whitelabel/' },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="section section--breadcrumb">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Solutions', href: '/solutions/' },
        { label: 'Online Store' },
      ]} />
    </div>
  </section>

  <Hero
    headline="Launch Your Online Store"
    subheadline="Sell online from day one. Storefront, payments, electronic invoicing, and your own domain — all from one platform. No plugins, no integrations, no patchwork."
    badge="Online Store Platform"
    primaryCta={{ label: 'Launch Your Store', href: 'https://app.1platform.pro/app/?intent=store' }}
    secondaryCta={{ label: 'See Pricing', href: '/pricing/' }}
  />

  <section class="section">
    <div class="container">
      <div class="section__header reveal">
        <h2>What You Get</h2>
        <p>Everything you need to sell online — in one place, one bill, one dashboard.</p>
      </div>
      <div class="grid-2 stagger-grid">
        {features.map((f) => (
          <FeatureCard icon={f.icon} title={f.title} description={f.description} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__header reveal">
        <h2>How It Works</h2>
        <p>Four steps from idea to live store.</p>
      </div>
      <PipelineAnimation steps={storeSteps} />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header reveal">
        <h2>What It Replaces</h2>
        <p>One platform, not six different services.</p>
      </div>
      <ComparisonTable rows={comparisonRows} />
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="pricing-callout reveal">
        <h2>Transparent Pricing</h2>
        <p>Pay only for what you use — no subscriptions, no hidden fees. Free tier included for testing every solution.</p>
        <div class="pricing-callout__actions">
          <a href="/pricing/" class="btn btn--primary">View Pricing</a>
          <a href="https://app.1platform.pro/app/?intent=store" class="btn btn--ghost">Start Free</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header reveal">
        <h2>Related Solutions</h2>
        <p>Everything your store needs to grow.</p>
      </div>
      <div class="grid-3 stagger-grid">
        {related.map((r) => (
          <SolutionCard icon={r.icon} title={r.title} description={r.description} href={r.href} />
        ))}
      </div>
    </div>
  </section>

  <section class="section cta-banner">
    <div class="container">
      <div class="cta-banner__content reveal">
        <h2>Ready to Sell Online?</h2>
        <p>Stop juggling six different services. Start with one platform — store, payments, invoicing, and domain included.</p>
        <div class="cta-banner__actions">
          <a href="https://app.1platform.pro/app/?intent=store" class="btn btn--primary">Launch Your Store</a>
          <a href="https://developer.1platform.pro/" class="btn btn--ghost">For Developers</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section { padding-block: var(--space-20); }
  .section--breadcrumb {
    padding-block: var(--space-4) 0;
    padding-top: calc(var(--header-height) + var(--space-4));
  }
  .section--alt {
    background-color: var(--color-bg-alt, #ffffff);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .container { max-width: 1200px; margin-inline: auto; padding-inline: var(--space-6); }
  .section__header {
    text-align: center; max-width: 700px; margin-inline: auto; margin-bottom: var(--space-12);
  }
  .section__header h2 {
    font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-4); text-wrap: balance;
  }
  .section__header p { font-size: var(--text-lg); color: var(--color-text-secondary); }
  .grid-2 {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-6);
  }
  .grid-3 {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6);
  }
  @media (max-width: 1024px) {
    .grid-3 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .grid-2, .grid-3 { grid-template-columns: 1fr; }
    .section { padding-block: var(--space-12); }
  }
  .pricing-callout {
    text-align: center; max-width: 700px; margin-inline: auto;
  }
  .pricing-callout h2 {
    font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-4); text-wrap: balance;
  }
  .pricing-callout p {
    font-size: var(--text-lg); color: var(--color-text-secondary); margin-bottom: var(--space-8);
  }
  .pricing-callout__actions, .cta-banner__actions {
    display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap;
  }
  .cta-banner {
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.06), rgba(8, 145, 178, 0.05));
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .cta-banner__content {
    text-align: center; max-width: 700px; margin-inline: auto;
  }
  .cta-banner__content h2 {
    font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-4); text-wrap: balance;
  }
  .cta-banner__content p {
    font-size: var(--text-lg); color: var(--color-text-secondary); margin-bottom: var(--space-8);
  }
</style>
