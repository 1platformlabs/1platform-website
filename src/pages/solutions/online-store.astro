---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import Check from '@components/Check.astro';
import Icon from '@components/Icon.astro';
import ProcessSpine from '@components/ProcessSpine.astro';
import ComparisonTable from '@components/ComparisonTable.astro';
import type { IconName } from '@components/icons';

const title = 'Online Store Platform — Launch Your Store in Minutes | 1Platform';
const description = 'Launch a full online store with checkout, payments, electronic invoicing, and your own domain — all from one platform. No plugins, no patchwork.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Online Store',
    provider: { '@type': 'Organization', name: '1Platform Labs', url: 'https://1platform.pro' },
    description,
    url: 'https://1platform.pro/solutions/online-store/',
    areaServed: 'Worldwide',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Solutions', item: 'https://1platform.pro/solutions/' },
      { '@type': 'ListItem', position: 3, name: 'Online Store' },
    ],
  },
];

const features: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'cart',
    title: 'Storefront & checkout',
    description: 'Catalog, cart, and one-page checkout — ready to publish on your own domain.',
  },
  {
    icon: 'card',
    title: 'Payments built in',
    description: 'Accept card payments out of the box. Webhook notifications and automatic balance reconciliation.',
  },
  {
    icon: 'invoice',
    title: 'Compliant invoicing',
    description: 'Issue electronic invoices automatically for every transaction. PDF + XML included.',
  },
  {
    icon: 'domain',
    title: 'Your own domain',
    description: 'Register or connect a domain in minutes. DNS, nameservers, and renewals handled for you.',
  },
];

/** Concrete pieces that ship with the store, drawn from the capabilities above. */
const included = [
  'Product catalog and cart',
  'One-page checkout',
  'Customer accounts',
  'Card payments via API',
  'Webhook notifications on every transaction',
  'Automatic balance reconciliation',
  'Electronic invoices as PDF and XML',
  'Automatic tax calculation on invoice lines',
  'Domain registration and transfer',
  'DNS records and nameserver management',
];

const storeSteps = [
  { label: 'Create your account' },
  { label: 'Add products' },
  { label: 'Connect your domain' },
  { label: 'Go live' },
];

/**
 * Compared by what a fragmented stack costs you to run. The monthly prices
 * previously listed here were invented and have been removed.
 */
const comparisonRows = [
  { without: 'An ecommerce platform on its own plan', with_: 'Storefront included' },
  { without: 'A payment processor with a separate account and onboarding', with_: 'Payments built in' },
  { without: 'Invoicing software billed and managed on its own', with_: 'Electronic invoicing included' },
  { without: 'A registrar dashboard you log into separately', with_: 'Domain managed for you' },
];

const related: { title: string; description: string; href: string }[] = [
  {
    title: 'Payments & Invoicing',
    description: 'Accept payments and issue compliant electronic invoices — automatically.',
    href: '/payments-invoicing/',
  },
  {
    title: 'AI Content Generation',
    description: 'Generate product descriptions, blog posts, and landing copy with AI.',
    href: '/solutions/content/',
  },
  {
    title: 'Whitelabel Dashboard',
    description: 'Brand the entire experience under your own name — from a single API call.',
    href: '/solutions/whitelabel/',
  },
];
---

<BaseLayout title={title} description={description} ogImage="/og/solution-online-store.png" jsonLd={jsonLd}>
  <div class="page-top">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Solutions', href: '/solutions/' },
        { label: 'Online Store' },
      ]} />
    </div>
  </div>

  <Hero
    headline="Launch your online store"
    subheadline="Sell online from day one. Storefront, payments, electronic invoicing, and your own domain — all from one platform. No plugins, no integrations, no patchwork."
    badge="Online Store Platform"
    primaryCta={{ label: 'Launch Your Store', href: 'https://app.1platform.pro/app/?intent=store' }}
    secondaryCta={{ label: 'See Pricing', href: '/pricing/' }}
  />

  <section class="section">
    <div class="container">
      <div class="statement reveal">
        <p class="eyebrow">What you get</p>
        <h2 class="statement__lead">
          Everything you need to sell online — one place, one bill, one dashboard.
        </h2>
      </div>

      <div class="features">
        {features.map((feature) => (
          <Card
            icon={feature.icon}
            title={feature.title}
            description={feature.description}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- The concrete inventory, so "everything you need" is checkable -->
  <section class="section section--alt">
    <div class="container">
      <div class="split">
        <div class="split__copy reveal">
          <p class="eyebrow">In the box</p>
          <h2>No plugin list to assemble</h2>
          <p>
            These are not add-ons to buy later. Every item ships with the store and is
            available from the dashboard and the REST API on the day you open it.
          </p>
        </div>

        <ul class="included">
          {included.map((item) => (
            <li class="included__item">
              <Check yes label="Included:" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">How it works</p>
      </div>
      <h2 class="section__lead">Four steps from idea to live store.</h2>
      <ProcessSpine steps={storeSteps} label="How to launch a store, step by step" />
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">What it replaces</p>
      </div>
      <h2 class="section__lead">One platform instead of separate tools</h2>
      <ComparisonTable rows={comparisonRows} />
    </div>
  </section>

  <!-- Related work, as a readable index rather than another row of cards -->
  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Related solutions</p>
      </div>
      <h2 class="section__lead">Everything your store needs to grow.</h2>

      <ul class="index">
        {related.map((item) => (
          <li class="index__item">
            <h3 class="index__title">
              <a href={item.href} class="index__link">{item.title}</a>
            </h3>
            <p class="index__desc">{item.description}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Page-specific next step. The general closing CTA lives in the footer. -->
  <section class="section section--alt">
    <div class="container">
      <div class="next reveal">
        <div>
          <p class="eyebrow">Next step</p>
          <h2 class="next__title">Ready to sell online?</h2>
          <p class="next__desc">
            Pay only for what you use — no subscriptions, no hidden fees, and a free tier
            for testing every solution before you open the doors.
          </p>
          <a href="https://developer.1platform.pro/" class="link-cue">
            Read the API docs
            <Icon name="arrow-right" size={15} />
          </a>
        </div>
        <div class="next__actions">
          <a href="https://app.1platform.pro/app/?intent=store" class="btn btn--primary">Launch Your Store</a>
          <a href="/pricing/" class="btn btn--ghost">View Pricing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* The hero carries its own header offset, so it is neutralised below the
     breadcrumb strip to avoid stacking two header heights of space. */
  .page-top {
    padding-top: calc(var(--header-height) + var(--space-8));
  }

  .page-top + :global(.hero) {
    padding-top: var(--space-6);
  }

  .statement {
    max-width: 40rem;
    margin-bottom: var(--space-12);
  }

  .statement__lead {
    font-size: var(--text-4xl);
    margin-top: var(--space-4);
  }

  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-10);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  /* ===== Split: claim on the left, the inventory on the right ===== */
  .split {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
    gap: var(--space-12);
    align-items: start;
  }

  .split__copy h2 {
    margin-block: var(--space-4);
  }

  .split__copy p {
    margin: 0;
  }

  .included {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3) var(--space-6);
    list-style: none;
    padding: 0;
    margin: 0;
    min-width: 0;
  }

  .included__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  /* ===== Related: a bordered index ===== */
  .index {
    display: grid;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 52rem;
  }

  .index__item {
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .index__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .index__title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .index__link {
    color: var(--color-text);
  }

  .index__link:hover {
    color: var(--color-accent);
  }

  .index__desc {
    font-size: var(--text-sm);
    margin: 0;
  }

  .link-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    min-height: 44px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .link-cue:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* ===== Closing band ===== */
  .next {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .next__title {
    font-size: var(--text-3xl);
    margin-block: var(--space-4);
  }

  .next__desc {
    max-width: 34rem;
    margin: 0;
  }

  .next__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .split {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .features,
    .included {
      grid-template-columns: 1fr;
    }

    .statement__lead {
      font-size: var(--text-3xl);
    }
  }
</style>
