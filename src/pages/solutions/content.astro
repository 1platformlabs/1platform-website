---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import Icon from '@components/Icon.astro';
import ProcessSpine from '@components/ProcessSpine.astro';
import ComparisonTable from '@components/ComparisonTable.astro';
import type { IconName } from '@components/icons';

const title = 'AI Content Generation API — Articles, Images & SEO | 1Platform';
const description = 'Generate SEO-optimized articles, images, comments, and landing pages with AI. Extract keywords, publish to CMS, and submit for indexing — all from one platform.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'AI Content Generation',
    provider: { '@type': 'Organization', name: '1Platform Labs', url: 'https://1platform.pro' },
    description,
    url: 'https://1platform.pro/solutions/content/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'Solutions', item: 'https://1platform.pro/solutions/' },
      { '@type': 'ListItem', position: 3, name: 'Content' },
    ],
  },
];

const features: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'content',
    title: 'AI articles',
    description: 'SEO-optimized articles from a single keyword. Multi-language, async job pipeline, human-quality output.',
  },
  {
    icon: 'image',
    title: 'AI images',
    description: 'Generate unique visuals or source from premium libraries — commercial license included.',
  },
  {
    icon: 'keyword',
    title: 'Keyword intelligence',
    description: 'Extract keywords with volume, intent, and difficulty from any URL or topic.',
  },
  {
    icon: 'indexing',
    title: 'Publish & index',
    description: 'Push content to your CMS, submit URLs for indexing, and build backlinks — all from one API.',
  },
];

/* The sequence is the information here. Steps carry labels, not decoration. */
const contentSteps = [
  { label: 'Extract keywords' },
  { label: 'Generate content' },
  { label: 'Publish to your CMS' },
  { label: 'Submit for indexing' },
];

/**
 * Compared by what a fragmented content stack costs you in effort. The prices
 * that used to sit in this table were invented and are gone.
 */
const comparisonRows = [
  { without: 'An AI writing tool on its own subscription', with_: 'AI content built in' },
  { without: 'A stock image library billed separately', with_: 'AI images included' },
  { without: 'A keyword research tool with its own login', with_: 'Keyword intelligence included' },
  { without: 'An indexing plugin plus manual URL submission', with_: 'Automatic indexing' },
];

const related: { icon: IconName; title: string; description: string; href: string }[] = [
  {
    icon: 'monitor',
    title: 'Website Builder',
    description: 'Launch a complete website with AI content and your own domain.',
    href: '/solutions/website/',
  },
  {
    icon: 'cart',
    title: 'Online Store',
    description: 'Sell products with AI-generated descriptions and landing pages.',
    href: '/solutions/online-store/',
  },
  {
    icon: 'code',
    title: 'For Developers',
    description: 'Power your own product with the content API.',
    href: '/for-developers/',
  },
];
---

<BaseLayout title={title} description={description} ogImage="/og/solution-content.png" jsonLd={jsonLd}>
  <div class="page-top">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Solutions', href: '/solutions/' },
        { label: 'Content' },
      ]} />
    </div>
  </div>

  <Hero
    headline="Content that ranks itself"
    subheadline="Generate SEO-optimized articles, images, and legal pages with AI. Extract keywords, publish to your CMS, and submit for indexing — all from one platform."
    badge="AI Content Generation"
    primaryCta={{ label: 'Start Publishing', href: 'https://app.1platform.pro/app/?intent=content' }}
    secondaryCta={{ label: 'See Pricing', href: '/pricing/' }}
  />

  <!-- What it is: an editorial statement, then the four claims -->
  <section class="section">
    <div class="container">
      <div class="statement reveal">
        <p class="eyebrow">What you get</p>
        <h2 class="statement__lead">
          A complete content engine — research, generation, publishing, and indexing in one API.
        </h2>
      </div>

      <div class="pillars">
        {features.map((feature) => (
          <Card
            variant="bare"
            icon={feature.icon}
            title={feature.title}
            description={feature.description}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- The pipeline, drawn as a spine rather than four emoji -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">How it works</p>
      </div>
      <h2 class="section__lead">From keyword to indexed article, without leaving the platform.</h2>
      <ProcessSpine steps={contentSteps} label="How content generation works, step by step" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">What it replaces</p>
      </div>
      <h2 class="section__lead">One platform instead of separate tools</h2>
      <ComparisonTable rows={comparisonRows} />
    </div>
  </section>

  <!-- Related work, as an index of linked cards -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Related solutions</p>
      </div>
      <h2 class="section__lead">Pair content with the rest of the platform.</h2>
      <div class="related">
        {related.map((item) => (
          <Card
            icon={item.icon}
            title={item.title}
            description={item.description}
            href={item.href}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Page-specific next step. The general closing CTA lives in the footer. -->
  <section class="section">
    <div class="container">
      <div class="next reveal">
        <div>
          <p class="eyebrow">Next step</p>
          <h2 class="next__title">Ready to publish?</h2>
          <p class="next__desc">
            Pay only for what you use — no subscriptions, no hidden fees. Generate,
            publish, and rank content from one platform.
          </p>
          <a href="https://developer.1platform.pro/" class="link-cue">
            Read the content API docs
            <Icon name="arrow-right" size={15} />
          </a>
        </div>
        <div class="next__actions">
          <a href="https://app.1platform.pro/app/?intent=content" class="btn btn--primary">Start Publishing</a>
          <a href="/pricing/" class="btn btn--ghost">View Pricing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* The hero carries its own header offset, so it is neutralised below the
     breadcrumb strip to avoid stacking two header heights of space. */
  .page-top {
    padding-top: calc(var(--header-height) + var(--space-8));
  }

  .page-top + :global(.hero) {
    padding-top: var(--space-6);
  }

  .statement {
    max-width: 40rem;
    margin-bottom: var(--space-12);
  }

  .statement__lead {
    font-size: var(--text-4xl);
    margin-top: var(--space-4);
  }

  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-10);
  }

  /* Bare, generous, no surfaces — these are claims, not tiles. */
  .pillars {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-10) var(--space-12);
  }

  .related {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .link-cue {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    min-height: 44px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .link-cue :global(svg) {
      transition: transform var(--duration-fast) var(--ease-out-expo);
    }

    .link-cue:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* Closing band: left-aligned, bordered, no wash. */
  .next {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-8);
    padding-top: var(--space-10);
    border-top: 1px solid var(--color-border);
  }

  .next__title {
    font-size: var(--text-3xl);
    margin-block: var(--space-4);
  }

  .next__desc {
    max-width: 34rem;
    margin: 0;
  }

  .next__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .related {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .pillars,
    .related {
      grid-template-columns: 1fr;
    }

    .pillars {
      gap: var(--space-8);
    }

    .statement__lead {
      font-size: var(--text-3xl);
    }
  }
</style>
