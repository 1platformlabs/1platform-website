---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import SolutionCard from '@components/SolutionCard.astro';
import ComparisonTable from '@components/ComparisonTable.astro';

const title = 'E-Commerce, Delivery & AI Solutions | 1Platform';
const description = 'Explore 13+ solutions unified under one REST API. Regional e-commerce, delivery management, payments, electronic invoicing (FEL), AI content generation, and more.';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Solutions' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: 'https://1platform.pro/solutions/',
  isPartOf: {
    '@type': 'WebSite',
    name: '1Platform',
    url: 'https://1platform.pro',
  },
};

/* ── Intelligence Pillar ── */
const intelligenceSolutions = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><path d="M8 8h6"/><path d="M11 5v6"/></svg>',
    title: 'AI Keyword Extraction',
    description: 'Extract high-value keywords from any URL, topic, or seed phrase. Get search volume, keyword difficulty, CPC, and opportunity scores — powered by AI analysis.',
    replaces: 'Standalone keyword research tools',
    href: '/docs/keywords/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
    title: 'Search Console Integration',
    description: 'Connect Google Search Console programmatically. Pull ranking data, clicks, impressions, and CTR for any property — then feed insights directly into content generation.',
    replaces: 'Manual Search Console workflows',
    href: '/docs/search-console/',
  },
];

/* ── Content Pillar ── */
const contentSolutions = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
    title: 'AI Content Generation',
    description: 'Generate SEO-optimized articles, blog posts, product descriptions, and landing pages. Multi-language support with natural, human-quality output tuned for search performance.',
    replaces: 'AI writing tools, freelance content services',
    href: '/docs/content/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>',
    title: 'AI Image Generation',
    description: 'Create unique, royalty-free images tailored to your content. AI-generated visuals automatically optimized for web performance with proper alt-text suggestions.',
    replaces: 'Stock photo subscriptions, image editing tools',
    href: '/docs/images/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
    title: 'AI Comment Generation',
    description: 'Generate contextually relevant blog comments that drive engagement. Natural language responses based on article content and topic analysis.',
    replaces: 'Manual community management tools',
    href: '/docs/comments/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
    title: 'AI Profile Generation',
    description: 'Create professional author profiles and bios optimized for E-E-A-T signals. Build topical authority and credibility across your entire content portfolio.',
    replaces: 'Manual bio writing, profile management tools',
    href: '/docs/profiles/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
    title: 'Legal Page Generation',
    description: 'Auto-generate privacy policies, terms of service, and cookie consent notices. Compliant templates customized to your jurisdiction and business type.',
    replaces: 'Legal template services, compliance tools',
    href: '/docs/legal/',
  },
];

/* ── Distribution Pillar ── */
const distributionSolutions = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>',
    title: 'CMS Publishing',
    description: 'Publish directly to WordPress and other CMS platforms. Schedule posts, manage categories, set featured images, and update content — all via API.',
    replaces: 'WordPress plugins, manual CMS workflows',
    href: '/docs/cms/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
    title: 'Indexing Automation',
    description: 'Submit URLs to search engines via the Indexing API. Batch processing, status tracking, and automatic resubmission for failed requests.',
    replaces: 'Manual URL submission, indexing plugins',
    href: '/docs/indexing/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
    title: 'Link Building',
    description: 'Acquire high-quality backlinks through vetted publisher networks. Automated outreach, placement tracking, and domain authority monitoring.',
    replaces: 'Outreach platforms, link marketplaces',
    href: '/docs/link-building/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
    title: 'Website Management',
    description: 'Register, configure, and manage multiple websites from a single account. Centralized control over domains, credentials, and publishing targets.',
    replaces: 'Separate hosting dashboards, site managers',
    href: '/docs/websites/',
  },
];

/* ── E-Commerce Pillar ── */
const ecommerceSolutions = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>',
    title: 'Online Store Builder',
    description: 'Create regional e-commerce websites with integrated product catalogs, checkout flows, and multi-currency support for Latin American markets.',
    replaces: 'Standalone e-commerce platforms',
    href: '/docs/ecommerce/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>',
    title: 'Payment Processing',
    description: 'Accept credit cards, debit cards, and local payment methods across Latin America. Hosted checkout, webhook notifications, and automatic receipts.',
    replaces: 'Standalone payment gateways',
    href: '/docs/payments/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18"/></svg>',
    title: 'NFC Tap-to-Pay',
    description: 'Accept card-present payments with NFC-enabled mobile devices. Turn any smartphone into a point-of-sale terminal — no hardware needed.',
    replaces: 'Dedicated POS hardware',
    href: '/docs/nfc/',
  },
];

/* ── Delivery Pillar ── */
const deliverySolutions = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-4"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
    title: 'Delivery Coordination',
    description: 'Manage the full delivery lifecycle: order assignment, route optimization, driver tracking, and delivery confirmation — all via API.',
    replaces: 'Third-party delivery platforms',
    href: '/docs/delivery/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>',
    title: 'Real-Time Tracking',
    description: 'Give customers live order tracking from store to doorstep. GPS-based driver location, ETA updates, and delivery status notifications.',
    replaces: 'Manual delivery coordination',
    href: '/docs/delivery/',
  },
];

/* ── Invoicing Pillar ── */
const invoicingSolutions = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>',
    title: 'Electronic Invoicing (FEL)',
    description: 'Generate certified electronic invoices automatically after each sale. Tax-compliant FEL billing for Guatemala and Central America.',
    replaces: 'Invoicing software, tax compliance tools',
    href: '/docs/invoicing/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    title: 'Tax Compliance',
    description: 'Automatic SAT compliance for Guatemala. Every invoice certified and submitted in real time — zero manual tax filing required.',
    replaces: 'Manual tax reporting',
    href: '/docs/invoicing/',
  },
];

const pillarSections = [
  {
    id: 'ecommerce',
    title: 'E-Commerce & Payments',
    description: 'Launch your online store with integrated checkout, multi-currency support, and NFC tap-to-pay for Latin American markets.',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>',
    solutions: ecommerceSolutions,
  },
  {
    id: 'delivery',
    title: 'Delivery Management',
    description: 'Coordinate deliveries from order to doorstep with real-time tracking, route optimization, and driver management.',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-4"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
    solutions: deliverySolutions,
  },
  {
    id: 'invoicing',
    title: 'Invoicing & Tax Compliance',
    description: 'Generate certified electronic invoices (FEL) automatically from every transaction. Tax compliance built for Central America.',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>',
    solutions: invoicingSolutions,
  },
  {
    id: 'content',
    title: 'AI Content Assistant',
    description: 'Generate product descriptions, articles, images, and more with AI — boost your store\'s visibility and attract more customers.',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
    solutions: contentSolutions,
  },
  {
    id: 'distribution',
    title: 'Distribution & Growth',
    description: 'Publish to CMS, get indexed by search engines, and build backlinks — the complete distribution pipeline, automated.',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>',
    solutions: distributionSolutions,
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <!-- Breadcrumb -->
  <section class="section section--breadcrumb">
    <div class="container">
      <Breadcrumb items={breadcrumbs} />
    </div>
  </section>

  <!-- Hero -->
  <Hero
    headline="E-Commerce, Delivery & AI — One Platform."
    subheadline="Build online stores, manage deliveries, accept payments, generate invoices, and create content with AI — all from a single, unified API."
    badge="13+ Solutions, 1 API"
    primaryCta={{ label: 'Get Started Free', href: 'https://app.1platform.pro' }}
    secondaryCta={{ label: 'View API Docs', href: '/docs/' }}
  />

  <!-- Pillar Sections -->
  {pillarSections.map((pillar, pillarIndex) => (
    <section class:list={['section', { 'section--alt': pillarIndex % 2 === 0 }]} id={pillar.id}>
      <div class="container">
        <div class="pillar-header reveal">
          <div class="pillar-header__icon" aria-hidden="true" set:html={pillar.icon} />
          <h2>{pillar.title}</h2>
          <p>{pillar.description}</p>
        </div>
        <div class:list={[pillar.solutions.length <= 2 ? 'grid-2' : 'grid-3', 'stagger-grid']}>
          {pillar.solutions.map((solution) => (
            <SolutionCard
              icon={solution.icon}
              title={solution.title}
              description={solution.description}
              replaces={solution.replaces}
              href={solution.href}
            />
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Comparison Table -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header reveal">
        <h2>The 1Platform Advantage</h2>
        <p>See what changes when you unify your entire tool stack under one platform.</p>
      </div>
      <ComparisonTable />
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-banner">
    <div class="container">
      <div class="cta-banner__content reveal">
        <h2>Ready to Simplify Your Stack?</h2>
        <p>Start building with 1Platform today. One integration, 13+ capabilities, zero complexity.</p>
        <div class="cta-banner__actions">
          <a href="https://app.1platform.pro" class="btn btn--primary">Get Started Free</a>
          <a href="/pricing/" class="btn btn--ghost">View Pricing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section {
    padding-block: var(--space-20);
  }

  .section--breadcrumb {
    padding-block: var(--space-4) 0;
    padding-top: calc(var(--header-height) + var(--space-4));
  }

  .section--alt {
    background-color: var(--color-bg-alt, #111);
  }

  .container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  .section__header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .section__header h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    text-wrap: balance;
  }

  .section__header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  /* Pillar Headers */
  .pillar-header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .pillar-header__icon {
    width: 56px;
    height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--border-radius-xl);
    background: linear-gradient(135deg, var(--color-accent-glow), rgba(6, 182, 212, 0.1));
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .pillar-header h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    text-wrap: balance;
  }

  .pillar-header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  /* Grids */
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    max-width: 800px;
    margin-inline: auto;
  }

  @media (max-width: 1024px) {
    .grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .grid-3,
    .grid-2 {
      grid-template-columns: 1fr;
    }

    .section {
      padding-block: var(--space-12);
    }

    .grid-2 {
      max-width: none;
    }
  }

  /* CTA Banner */
  .cta-banner {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(6, 182, 212, 0.08));
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .cta-banner__content {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
  }

  .cta-banner__content h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    text-wrap: balance;
  }

  .cta-banner__content p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .cta-banner__actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
