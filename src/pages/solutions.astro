---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import Icon from '@components/Icon.astro';
import ComparisonTable from '@components/ComparisonTable.astro';
import type { IconName } from '@components/icons';

const title = 'Solutions — Online Store, Website, Payments, Content | 1Platform';
const description = 'Sell online, build a website, generate content, and ship a developer platform — all from one unified platform. Outcome-driven solutions for every business.';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Solutions' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: 'https://1platform.pro/solutions/',
  isPartOf: {
    '@type': 'WebSite',
    name: '1Platform',
    url: 'https://1platform.pro',
  },
};

interface Solution {
  icon: IconName;
  title: string;
  description: string;
  replaces: string;
  href: string;
}

/**
 * The four outcomes people arrive for. Everything else is real, but these are
 * the entry points — so they get weight instead of being one of 23 identical
 * tiles.
 */
const featured: { icon: IconName; title: string; description: string; href: string }[] = [
  {
    icon: 'cart',
    title: 'Online Store',
    description: 'Catalog, cart, and checkout on your own domain — with payments and invoicing already wired in.',
    href: '/solutions/online-store/',
  },
  {
    icon: 'monitor',
    title: 'Website Builder',
    description: 'A complete site with AI-generated content, your own domain, and publishing straight to your CMS.',
    href: '/solutions/website/',
  },
  {
    icon: 'card',
    title: 'Payments & Invoicing',
    description: 'Accept card payments and issue compliant electronic invoices from the same transaction.',
    href: '/payments-invoicing/',
  },
  {
    icon: 'dashboard',
    title: 'Whitelabel Dashboard',
    description: 'Branding, theme, layout, i18n, and KPIs resolved in one bootstrap call — under your name.',
    href: '/solutions/whitelabel/',
  },
];

/* Sell & get paid — the monetization core. */
const sellAndGetPaid: Solution[] = [
  {
    icon: 'card',
    title: 'Payment Processing',
    description: 'Accept card payments via API. Checkout URLs, real-time webhooks, and automatic balance crediting.',
    replaces: 'A separate payment gateway integration',
    href: '/payments-invoicing/',
  },
  {
    icon: 'invoice',
    title: 'Electronic Invoicing',
    description: 'Compliant electronic invoices generated automatically. PDF + XML output, multi-item lines, automatic tax calculation.',
    replaces: 'Invoicing software plus manual compliance',
    href: '/payments-invoicing/',
  },
  {
    icon: 'domain',
    title: 'Domain Management',
    description: 'Register, transfer, and renew domains. Manage DNS records and nameservers — all programmatically.',
    replaces: 'A separate registrar dashboard',
    href: '/solutions/website/',
  },
  {
    icon: 'wallet',
    title: 'Subscriptions & Billing',
    description: 'Track balance, manage usage, and bill customers — credits-based, pay-per-use, transparent.',
    replaces: 'Custom billing infrastructure',
    href: '/pricing/',
  },
];

/* Build your site — everything a storefront or site is made of. */
const buildYourSite: Solution[] = [
  {
    icon: 'cart',
    title: 'Online Store',
    description: 'Launch a store with checkout, catalog, and customer accounts — no plugins, no patchwork.',
    replaces: 'A standalone ecommerce platform',
    href: '/solutions/online-store/',
  },
  {
    icon: 'monitor',
    title: 'Website Builder',
    description: 'Build a complete website with AI content, your own domain, and integrated publishing.',
    replaces: 'A standalone website builder',
    href: '/solutions/website/',
  },
  {
    icon: 'content',
    title: 'AI Content Generation',
    description: 'Generate SEO-optimized articles, descriptions, and landing pages with AI. Multi-language, async pipeline.',
    replaces: 'A standalone AI writing tool',
    href: '/solutions/content/',
  },
  {
    icon: 'image',
    title: 'AI Image Generation',
    description: 'Create unique AI visuals or source from premium libraries — commercial license included.',
    replaces: 'Stock photo subscriptions',
    href: '/solutions/content/',
  },
  {
    icon: 'shield',
    title: 'Legal Page Generation',
    description: 'Auto-generate privacy policies, terms of service, and cookie notices — tailored to your business.',
    replaces: 'Legal template services',
    href: '/solutions/content/',
  },
  {
    icon: 'cms',
    title: 'CMS Publishing',
    description: 'Publish directly to WordPress and other CMS platforms. Schedule posts, set categories, manage media.',
    replaces: 'CMS plugins and manual publishing workflows',
    href: '/solutions/content/',
  },
];

/* Grow & reach — the distribution layer. */
const growAndReach: Solution[] = [
  {
    icon: 'keyword',
    title: 'SEO Intelligence',
    description: 'Extract keywords with volume, intent, and difficulty from any URL or topic.',
    replaces: 'A standalone keyword research tool',
    href: '/solutions/content/',
  },
  {
    icon: 'console',
    title: 'Search Console',
    description: 'Connect, verify, submit sitemaps, and monitor performance programmatically.',
    replaces: 'Manual search console workflows',
    href: '/solutions/content/',
  },
  {
    icon: 'indexing',
    title: 'Indexing Automation',
    description: 'Submit URLs to search engines for faster crawling. Batch processing and status tracking.',
    replaces: 'Manual URL submission and indexing plugins',
    href: '/solutions/content/',
  },
  {
    icon: 'link',
    title: 'Link Building',
    description: 'Integrated marketplace for guest posts and backlinks — build authority programmatically.',
    replaces: 'Outreach platforms and link marketplaces',
    href: '/solutions/content/',
  },
  {
    icon: 'chart',
    title: 'Analytics',
    description: 'Connect analytics, provision properties, and retrieve traffic metrics — all through one API.',
    replaces: 'Manual analytics setup across separate dashboards',
    href: '/for-developers/',
  },
  {
    icon: 'trend',
    title: 'Ad Revenue Tracking',
    description: 'Connect ad accounts, monitor earnings, track policy issues, and generate custom revenue reports.',
    replaces: 'Ad platform dashboards and manual tracking',
    href: '/for-developers/',
  },
];

/* Developer platform — the operational layer for builders. */
const developerPlatform: Solution[] = [
  {
    icon: 'dashboard',
    title: 'Whitelabel Dashboard',
    description: 'Bootstrap a fully branded dashboard from one API call. Branding, theme, layout, i18n, and KPIs.',
    replaces: 'A custom dashboard framework',
    href: '/solutions/whitelabel/',
  },
  {
    icon: 'webhook',
    title: 'Webhooks',
    description: 'Subscribe to real-time lifecycle events with HMAC-signed payloads, allowed-domain registration, and secret rotation.',
    replaces: 'Custom event polling infrastructure',
    href: '/for-developers/',
  },
  {
    icon: 'logs',
    title: 'Activity Logs',
    description: 'Track every API call with detailed logs. Filter by endpoint, status, or date. Register client-side events.',
    replaces: 'A logging service and separate monitoring',
    href: '/for-developers/',
  },
  {
    icon: 'agent',
    title: 'AI Agents',
    description: 'Create autonomous agents from templates or a guided wizard. Schedule runs and handle human approvals.',
    replaces: 'Custom automation scripts',
    href: '/for-developers/',
  },
  {
    icon: 'bell',
    title: 'In-App Notifications',
    description: 'Push notifications to a single user or broadcast to all. List the feed, mark read, and read unread count.',
    replaces: 'A separate notification service',
    href: '/for-developers/',
  },
  {
    icon: 'share',
    title: 'Referrals',
    description: 'Resolve referral codes to referrer username and pre-filled signup URLs — power personalized landing pages.',
    replaces: 'A standalone referral platform',
    href: '/for-developers/',
  },
  {
    icon: 'support',
    title: 'Support Center',
    description: 'Embed an in-app help center — tickets, threaded replies, and a public FAQ catalog grouped by category.',
    replaces: 'A standalone help-desk tool',
    href: '/for-developers/',
  },
];

/* ids are preserved from the previous structure so existing deep links keep working. */
const groups: { id: string; eyebrow: string; title: string; description: string; solutions: Solution[] }[] = [
  {
    id: 'intelligence',
    eyebrow: 'Sell and get paid',
    title: 'The monetization core',
    description: 'Take money, prove it with a compliant invoice, own the domain it happens on, and bill for usage — without stitching separate vendors together.',
    solutions: sellAndGetPaid,
  },
  {
    id: 'content',
    eyebrow: 'Build your site',
    title: 'Everything the storefront is made of',
    description: 'Launch a store or a website, generate the content and images that fill it, ship the legal pages it needs, and publish to your CMS.',
    solutions: buildYourSite,
  },
  {
    id: 'distribution',
    eyebrow: 'Grow and reach',
    title: 'The distribution layer',
    description: 'Keyword intelligence, indexing, link building, analytics, and ad revenue — the work that happens after the site is live.',
    solutions: growAndReach,
  },
  {
    id: 'payments',
    eyebrow: 'Developer platform',
    title: 'The operational layer for builders',
    description: 'The same capabilities the dashboard uses, exposed as REST: a whitelabel shell, webhooks, logs, agents, notifications, referrals, and support.',
    solutions: developerPlatform,
  },
];

const intentChips = groups.map((group) => ({ label: group.eyebrow, href: `#${group.id}` }));
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="page-top">
    <div class="container">
      <Breadcrumb items={breadcrumbs} />
    </div>
  </div>

  <Hero
    headline="Every Solution. One Platform."
    subheadline="Sell online, build a website, generate content, and ship a developer platform — all from one unified product. Every capability below shares one account, one API, and one bill."
    badge="Sell · Build · Grow · Integrate"
    primaryCta={{ label: 'Launch Your Store', href: 'https://app.1platform.pro/app/?intent=store' }}
    secondaryCta={{ label: 'For Developers — View API', href: 'https://developer.1platform.pro/' }}
    intentChips={intentChips}
  />

  <!-- The four entry points, given weight before the full index -->
  <section class="section">
    <div class="container">
      <div class="statement reveal">
        <p class="eyebrow">Start here</p>
        <h2 class="statement__lead">Most people arrive for one of four things.</h2>
      </div>

      <div class="featured">
        {featured.map((item) => (
          <Card
            variant="lead"
            icon={item.icon}
            title={item.title}
            description={item.description}
            href={item.href}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- The full catalogue, grouped by what you are trying to do -->
  {groups.map((group, index) => (
    <section class:list={['section', index % 2 === 0 && 'section--alt']} id={group.id}>
      <div class="container group">
        <div class="group__intro reveal">
          <p class="eyebrow">{group.eyebrow}</p>
          <h2 class="group__title">{group.title}</h2>
          <p class="group__desc">{group.description}</p>
        </div>

        <ul class="catalog">
          {group.solutions.map((solution) => (
            <li class="catalog__item">
              <span class="catalog__icon"><Icon name={solution.icon} size={20} /></span>
              <div class="catalog__body">
                <h3 class="catalog__title">
                  <a href={solution.href} class="catalog__link">{solution.title}</a>
                </h3>
                <p class="catalog__desc">{solution.description}</p>
                <p class="catalog__meta">
                  <span class="catalog__meta-label">Replaces</span>
                  {solution.replaces}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Unified vs fragmented</p>
      </div>
      <h2 class="section__lead">One account instead of separate subscriptions</h2>
      <ComparisonTable />
    </div>
  </section>

  <!-- Page-specific next step. The general closing CTA lives in the footer. -->
  <section class="section">
    <div class="container">
      <div class="next reveal">
        <div>
          <p class="eyebrow">Next step</p>
          <h2 class="next__title">Ready to simplify your stack?</h2>
          <p class="next__desc">
            Start with one platform. Sell online, issue invoices, and publish content —
            from one dashboard, one API, one bill.
          </p>
        </div>
        <div class="next__actions">
          <a href="https://app.1platform.pro/app/?intent=store" class="btn btn--primary">Launch Your Store</a>
          <a href="/pricing/" class="btn btn--ghost">View Pricing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Breadcrumb strip. The hero carries its own header offset, so it is
     neutralised here to avoid stacking two full header heights of space. */
  .page-top {
    padding-top: calc(var(--header-height) + var(--space-8));
  }

  .page-top + :global(.hero) {
    padding-top: var(--space-6);
  }

  /* ===== Editorial opener ===== */
  .statement {
    max-width: 40rem;
    margin-bottom: var(--space-12);
  }

  .statement__lead {
    font-size: var(--text-4xl);
    margin-top: var(--space-4);
  }

  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-10);
  }

  .featured {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  /* ===== Group: intro on the left, catalogue on the right ===== */
  .group {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 7fr);
    gap: var(--space-16);
    align-items: start;
  }

  .group__intro {
    position: sticky;
    top: calc(var(--header-height) + var(--space-10));
  }

  .group__title {
    font-size: var(--text-3xl);
    margin-block: var(--space-4);
  }

  .group__desc {
    font-size: var(--text-base);
    margin: 0;
  }

  /* ===== Catalogue: a bordered index, not another grid of tiles ===== */
  .catalog {
    display: grid;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
    min-width: 0;
  }

  .catalog__item {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .catalog__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .catalog__icon {
    display: inline-flex;
    color: var(--color-accent);
    padding-top: 2px;
  }

  .catalog__body {
    min-width: 0;
  }

  .catalog__title {
    font-size: var(--text-lg);
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .catalog__link {
    color: inherit;
  }

  /* The whole row is the hit area, but there is still exactly one link. */
  .catalog__link::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .catalog__item:hover .catalog__title {
    color: var(--color-accent);
  }

  .catalog__desc {
    font-size: var(--text-sm);
    margin: 0 0 var(--space-3);
  }

  .catalog__meta {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin: 0;
  }

  .catalog__meta-label {
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-right: var(--space-2);
  }

  /* ===== Closing next step: a band, left-aligned, no wash ===== */
  .next {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .next__title {
    font-size: var(--text-3xl);
    margin-block: var(--space-4);
  }

  .next__desc {
    max-width: 34rem;
    margin: 0;
  }

  .next__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .group {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .group__intro {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .featured {
      grid-template-columns: 1fr;
    }

    .statement__lead {
      font-size: var(--text-3xl);
    }
  }
</style>
