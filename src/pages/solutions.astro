---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import SolutionCard from '@components/SolutionCard.astro';
import ComparisonTable from '@components/ComparisonTable.astro';

const title = 'SEO Automation Solutions — Unified API | 1Platform';
const description = 'Replace 19+ separate tools with one platform. AI content, keywords, publishing, indexing, link building, payments, and invoicing — unified. Try free.';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Solutions' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: 'https://1platform.pro/solutions/',
  isPartOf: {
    '@type': 'WebSite',
    name: '1Platform',
    url: 'https://1platform.pro',
  },
};

/* ── Intelligence Pillar ── */
const intelligenceSolutions = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><path d="M8 8h6"/><path d="M11 5v6"/></svg>',
    title: 'AI Keyword Extraction',
    description: 'Extract high-value keywords from any URL, topic, or seed phrase. Get search volume, keyword difficulty, CPC, and opportunity scores — powered by AI analysis.',
    replaces: 'Standalone keyword research tools',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
    title: 'Search Console Integration',
    description: 'Connect Google Search Console programmatically. Pull ranking data, clicks, impressions, and CTR for any property — then feed insights directly into content generation.',
    replaces: 'Manual Search Console workflows',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4z"/></svg>',
    title: 'Google Analytics Integration',
    description: 'Connect Google Analytics 4 via OAuth, provision properties automatically, and retrieve traffic metrics — sessions, pageviews, realtime data, and per-page performance — all through one API.',
    replaces: 'Manual GA4 setup, separate analytics dashboards',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><line x1="6" y1="11" x2="10" y2="11"/><line x1="14" y1="11" x2="18" y2="11"/></svg>',
    title: 'Ad Revenue Tracking',
    description: 'Connect your ad accounts via OAuth, monitor earnings by site and page, track policy issues, and generate custom revenue reports — all from a single API integration.',
    replaces: 'Ad platform dashboards, manual revenue tracking',
    href: 'https://developer.1platform.pro/',
  },
];

/* ── Content Pillar ── */
const contentSolutions = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
    title: 'AI Content Generation',
    description: 'Generate SEO-optimized articles, blog posts, product descriptions, and landing pages. Multi-language support with natural, human-quality output tuned for search performance.',
    replaces: 'AI writing tools, freelance content services',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>',
    title: 'AI Image Generation',
    description: 'Create unique, royalty-free images tailored to your content. AI-generated visuals automatically optimized for web performance with proper alt-text suggestions.',
    replaces: 'Stock photo subscriptions, image editing tools',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
    title: 'AI Comment Generation',
    description: 'Generate contextually relevant blog comments that drive engagement. Natural language responses based on article content and topic analysis.',
    replaces: 'Manual community management tools',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
    title: 'AI Profile Generation',
    description: 'Create professional author profiles and bios optimized for E-E-A-T signals. Build topical authority and credibility across your entire content portfolio.',
    replaces: 'Manual bio writing, profile management tools',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
    title: 'Legal Page Generation',
    description: 'Auto-generate privacy policies, terms of service, and cookie consent notices. Compliant templates customized to your jurisdiction and business type.',
    replaces: 'Legal template services, compliance tools',
    href: 'https://developer.1platform.pro/',
  },
];

/* ── Distribution Pillar ── */
const distributionSolutions = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>',
    title: 'CMS Publishing',
    description: 'Publish directly to WordPress and other CMS platforms. Schedule posts, manage categories, set featured images, and update content — all via API.',
    replaces: 'WordPress plugins, manual CMS workflows',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
    title: 'Indexing Automation',
    description: 'Submit URLs to search engines via the Indexing API. Batch processing, status tracking, and automatic resubmission for failed requests.',
    replaces: 'Manual URL submission, indexing plugins',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
    title: 'Link Building',
    description: 'Acquire high-quality backlinks through vetted publisher networks. Automated outreach, placement tracking, and domain authority monitoring.',
    replaces: 'Outreach platforms, link marketplaces',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
    title: 'Website Management',
    description: 'Register, configure, and manage multiple websites from a single account. Centralized control over domains, credentials, and publishing targets.',
    replaces: 'Separate hosting dashboards, site managers',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
    title: 'Domain Management',
    description: 'Check availability, register domains, manage DNS records, configure nameservers, renew registrations, and handle domain transfers — all programmatically through one API.',
    replaces: 'Separate domain registrar dashboards, manual DNS management',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>',
    title: 'Referrals',
    description: 'Resolve referral codes to their destination payload — referrer username and pre-filled signup URL — to power personalized landing pages and reward both parties on signup.',
    replaces: 'Standalone referral platforms, manual code tracking',
    href: 'https://developer.1platform.pro/',
  },
];

/* ── Payments & Invoicing Pillar ── */
const paymentsSolutions = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>',
    title: 'Online Payment Processing',
    description: 'Accept credit and debit card payments via API. Checkout URLs, webhook notifications, and automatic balance crediting.',
    replaces: 'Separate payment gateway integration + POS terminal rental',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>',
    title: 'Electronic Invoicing (FEL)',
    description: 'Generate FEL-compliant electronic invoices automatically from transactions. Certified tax compliance for Guatemala.',
    replaces: 'Separate invoicing software + manual tax compliance',
    href: 'https://developer.1platform.pro/',
  },
];

/* ── Automation & AI Agents Pillar ── */
const automationSolutions = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="3"/><path d="M12 8v3"/><path d="M8 16h0"/><path d="M16 16h0"/></svg>',
    title: 'AI Agents',
    description: 'Create autonomous AI agents from a catalog of templates or via a guided wizard. Schedule runs, monitor execution, and handle human-in-the-loop approvals — all through the API.',
    replaces: 'Custom automation scripts, separate AI orchestration tools',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>',
    title: 'Activity Logs',
    description: 'Track every API call with detailed structured logs. Filter by endpoint, status code, or time range. Register client-side events for full end-to-end observability across your integration.',
    replaces: 'Logging services, separate monitoring tools',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8a6 6 0 1 1-12 0c0-7 12-7 12 0"/><path d="M6 8h12"/><path d="M22 16.92V21a1 1 0 0 1-1.09 1 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 3.18 4.18 1 1 0 0 1 4.21 3h4.09a1 1 0 0 1 1 .75 12.84 12.84 0 0 0 .7 2.81 1 1 0 0 1-.27 1L8.09 9.21a16 16 0 0 0 6 6l1.65-1.65a1 1 0 0 1 1-.27 12.84 12.84 0 0 0 2.81.7 1 1 0 0 1 .75 1z"/></svg>',
    title: 'Webhooks',
    description: 'Subscribe to real-time payment lifecycle events (approved, denied, cancelled, expired, dismissed). Register allowed domains, define handler URLs per event, and rotate signing secrets — with HMAC-signed payloads out of the box.',
    replaces: 'Custom event polling, manual webhook infrastructure',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>',
    title: 'In-App Notifications',
    description: 'Push notifications to a single user or broadcast to all users in your app. List the feed with pagination, mark items as read, and read the unread count for navbar badges — all behind one consistent API.',
    replaces: 'Separate notification services, custom inbox infrastructure',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M2 7h20"/><circle cx="6" cy="5" r=".5"/><circle cx="9" cy="5" r=".5"/><circle cx="12" cy="5" r=".5"/><path d="M7 12h2"/><path d="M11 12h6"/><path d="M7 15h10"/></svg>',
    title: 'Whitelabel Dashboard',
    description: 'Bootstrap a fully branded dashboard from one API call — branding, theme palette, layout, modules, and feature flags. Hot-reload localized i18n bundles and read aggregate KPIs (balance, unread, counters) in a single round trip.',
    replaces: 'Custom dashboard frameworks, separate i18n services',
    href: 'https://developer.1platform.pro/',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><line x1="9" y1="10" x2="15" y2="10"/><line x1="9" y1="13" x2="13" y2="13"/></svg>',
    title: 'Support Center',
    description: 'Embed an in-app help center: list and create support tickets, append threaded replies between users and agents, and serve a public FAQ catalog grouped by category — all without leaving your dashboard.',
    replaces: 'Standalone help-desk tools, separate FAQ platforms',
    href: 'https://developer.1platform.pro/',
  },
];

const pillarSections = [
  {
    id: 'intelligence',
    title: 'Intelligence & Research',
    description: 'Extract keywords, connect Google Search Console, integrate analytics, and manage multiple websites — the foundation of every content strategy.',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>',
    solutions: intelligenceSolutions,
  },
  {
    id: 'content',
    title: 'Content Creation & Publishing',
    description: 'Generate articles, images, comments, profiles, and legal pages with AI — then publish directly to your CMS.',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
    solutions: contentSolutions,
  },
  {
    id: 'distribution',
    title: 'Distribution & Growth',
    description: 'Publish to CMS, get indexed by search engines, and build backlinks — the complete distribution pipeline, automated.',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>',
    solutions: distributionSolutions,
  },
  {
    id: 'payments',
    title: 'Payments & Invoicing',
    description: 'Accept payments online and in person, then generate certified electronic invoices automatically — monetize your content ecosystem.',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>',
    solutions: paymentsSolutions,
  },
  {
    id: 'automation',
    title: 'Automation & Operations',
    description: 'Deploy autonomous AI agents, route real-time webhooks, push notifications, embed support, and bootstrap a fully branded dashboard — the operational layer that keeps everything running.',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="3"/><path d="M12 8v3"/></svg>',
    solutions: automationSolutions,
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <!-- Breadcrumb -->
  <section class="section section--breadcrumb">
    <div class="container">
      <Breadcrumb items={breadcrumbs} />
    </div>
  </section>

  <!-- Hero -->
  <Hero
    headline="Every Solution. One Platform."
    subheadline="1Platform replaces 19+ fragmented tools with a unified platform that covers the entire lifecycle — from keyword intelligence to published, indexed, monetized content with automated invoicing."
    badge="19+ Solutions, 1 API"
    primaryCta={{ label: 'Get Started Free', href: 'https://app.1platform.pro' }}
    secondaryCta={{ label: 'View API Docs', href: 'https://developer.1platform.pro/' }}
  />

  <!-- Pillar Sections -->
  {pillarSections.map((pillar, pillarIndex) => (
    <section class:list={['section', { 'section--alt': pillarIndex % 2 === 0 }]} id={pillar.id}>
      <div class="container">
        <div class="pillar-header reveal">
          <div class="pillar-header__icon" aria-hidden="true" set:html={pillar.icon} />
          <h2>{pillar.title}</h2>
          <p>{pillar.description}</p>
        </div>
        <div class:list={[pillar.solutions.length <= 2 ? 'grid-2' : 'grid-3', 'stagger-grid']}>
          {pillar.solutions.map((solution) => (
            <SolutionCard
              icon={solution.icon}
              title={solution.title}
              description={solution.description}
              replaces={solution.replaces}
              href={solution.href}
            />
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Comparison Table -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header reveal">
        <h2>The 1Platform Advantage</h2>
        <p>See what changes when you unify your entire tool stack under one platform.</p>
      </div>
      <ComparisonTable />
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-banner">
    <div class="container">
      <div class="cta-banner__content reveal">
        <h2>Ready to Simplify Your Stack?</h2>
        <p>Start building with 1Platform today. One integration, 19+ capabilities, zero complexity.</p>
        <div class="cta-banner__actions">
          <a href="https://app.1platform.pro" class="btn btn--primary">Get Started Free</a>
          <a href="/pricing/" class="btn btn--ghost">View Pricing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section {
    padding-block: var(--space-20);
  }

  .section--breadcrumb {
    padding-block: var(--space-4) 0;
    padding-top: calc(var(--header-height) + var(--space-4));
  }

  .section--alt {
    background-color: var(--color-bg-alt, #ffffff);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  .section__header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .section__header h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    text-wrap: balance;
  }

  .section__header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  /* Pillar Headers */
  .pillar-header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .pillar-header__icon {
    width: 56px;
    height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--border-radius-xl);
    background: linear-gradient(135deg, var(--color-accent-glow), rgba(8, 145, 178, 0.08));
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .pillar-header h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    text-wrap: balance;
  }

  .pillar-header p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  /* Grids */
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    max-width: 800px;
    margin-inline: auto;
  }

  @media (max-width: 1024px) {
    .grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .grid-3,
    .grid-2 {
      grid-template-columns: 1fr;
    }

    .section {
      padding-block: var(--space-12);
    }

    .grid-2 {
      max-width: none;
    }
  }

  /* CTA Banner */
  .cta-banner {
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.06), rgba(8, 145, 178, 0.05));
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .cta-banner__content {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
  }

  .cta-banner__content h2 {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    text-wrap: balance;
  }

  .cta-banner__content p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .cta-banner__actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
