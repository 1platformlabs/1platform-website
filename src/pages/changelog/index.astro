---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';

const entries = (await getCollection('changelog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const renderedEntries = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await entry.render();
    return { entry, Content };
  })
);

const categoryColors: Record<string, string> = {
  'new-feature': 'var(--color-accent, #3b82f6)',
  'improvement': '#06b6d4',
  'bug-fix': '#f59e0b',
  'api-change': '#a855f7',
};
---

<BaseLayout
  title="Changelog | 1Platform"
  description="Track every update, new feature, and improvement to the 1Platform API and services."
>
  <section class="changelog section">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Changelog' },
      ]} />

      <header class="changelog__header">
        <h1>Changelog</h1>
        <p>
          Track every update to 1Platform.
          <a href="/changelog/feed.xml" class="changelog__rss-link">RSS Feed</a>
        </p>
      </header>

      <div class="changelog__timeline">
        {renderedEntries.map(({ entry, Content }) => (
          <article class="changelog__entry reveal">
            <div class="changelog__entry-meta">
              <time datetime={entry.data.date.toISOString()}>
                {entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              {entry.data.version && (
                <span class="changelog__version-badge">v{entry.data.version}</span>
              )}
              <span
                class="badge"
                style={`--badge-color: ${categoryColors[entry.data.category] || 'var(--color-accent)'}`}
              >
                {entry.data.category.replace(/-/g, ' ')}
              </span>
            </div>
            <h2>{entry.data.title}</h2>
            <div class="changelog__content prose">
              <Content />
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .changelog__header {
    margin-bottom: var(--space-12);
  }

  .changelog__header h1 {
    margin-bottom: var(--space-3);
  }

  .changelog__header p {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
  }

  .changelog__rss-link {
    color: var(--color-accent);
    font-size: var(--text-sm);
    margin-left: var(--space-2);
  }

  .changelog__rss-link:hover {
    text-decoration: underline;
  }

  .changelog__timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .changelog__entry {
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
  }

  .changelog__entry:last-child {
    border-bottom: none;
  }

  .changelog__entry-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }

  .changelog__version-badge {
    font-family: var(--font-mono, monospace);
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--border-radius);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-variant-numeric: tabular-nums;
  }

  .changelog__entry h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .changelog__content {
    font-size: var(--text-sm);
  }
</style>
