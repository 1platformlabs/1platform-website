---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import Icon from '@components/Icon.astro';
import ProcessSpine from '@components/ProcessSpine.astro';
import type { IconName } from '@components/icons';

const title = 'Manage Client Websites & Stores from One Dashboard | 1Platform';
const description = 'Run client stores and websites from one dashboard. Whitelabel branding, per-client billing, and a built-in content engine — for agencies and consultants.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: 'https://1platform.pro/for-agencies/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1platform.pro/' },
      { '@type': 'ListItem', position: 2, name: 'For Agencies' },
    ],
  },
];

const features: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'monitor',
    title: 'Multi-site management',
    description: 'Register, configure and operate multiple client sites from one account. Switch context in a click.',
  },
  {
    icon: 'content',
    title: 'Content engine included',
    description: 'AI articles, images, comments and legal pages across every client site — generated and published at scale.',
  },
  {
    icon: 'dashboard',
    title: 'Whitelabel optional',
    description: 'Surface every dashboard under your agency brand — or use 1Platform directly. Your call, per client.',
  },
  {
    icon: 'card',
    title: 'Payments & invoicing',
    description: 'Accept payments and issue compliant invoices for every client — without juggling separate services.',
  },
];

/** The sequence an agency actually runs, per client. */
const clientSteps = [
  { label: 'Create your agency account' },
  { label: 'Add a client site' },
  { label: 'Connect the client domain' },
  { label: 'Apply your branding' },
  { label: 'Generate content' },
  { label: 'Bill the client' },
];

const related: { icon: IconName; title: string; description: string; href: string }[] = [
  {
    icon: 'dashboard',
    title: 'Whitelabel Dashboard',
    description: 'Brand every client dashboard under your agency name.',
    href: '/solutions/whitelabel/',
  },
  {
    icon: 'content',
    title: 'AI Content Generation',
    description: 'Scale content production across every client site.',
    href: '/solutions/content/',
  },
  {
    icon: 'code',
    title: 'For Developers',
    description: 'Integrate 1Platform into your agency stack via REST API.',
    href: '/for-developers/',
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="container crumbs">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'For Agencies' },
    ]} />
  </div>

  <Hero
    headline="Manage client sites at scale"
    subheadline="Run every client store and website from one dashboard. Whitelabel optional, billing per client, content engine included — built for agencies and consultants."
    badge="For Agencies"
    primaryCta={{ label: 'Contact Sales', href: '/contact/?topic=agency' }}
    secondaryCta={{ label: 'Read API Docs', href: 'https://developer.1platform.pro/' }}
  />

  <!-- What you get -->
  <section class="section">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">What you get</p>
      </div>
      <h2 class="section__lead">A single control plane for every client site you operate</h2>

      <div class="features">
        {features.map((feature) => (
          <Card
            variant="bare"
            icon={feature.icon}
            title={feature.title}
            description={feature.description}
            class="reveal"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- The per-client sequence -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Per client</p>
      </div>
      <h2 class="section__lead">The same sequence, however many clients you run</h2>
      <ProcessSpine steps={clientSteps} label="Onboarding a client, step by step" />
    </div>
  </section>

  <!-- Talk to us -->
  <section class="section">
    <div class="container">
      <div class="panel reveal">
        <div class="panel__copy">
          <p class="eyebrow">Onboarding</p>
          <h2>Talk to our team</h2>
          <p>
            Tell us about your agency setup — how many sites you expect to run, how you bill
            your clients, and whether you need whitelabel — and we'll build the right
            onboarding plan with you.
          </p>
        </div>
        <div class="panel__actions">
          <a href="/contact/?topic=agency" class="btn btn--primary">Contact Sales</a>
          <a href="https://developer.1platform.pro/" class="btn btn--ghost">Read API Docs</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__rule">
        <p class="eyebrow">Related</p>
      </div>
      <h2 class="section__lead">Build your agency stack on top of 1Platform</h2>

      <ul class="related">
        {related.map((item) => (
          <li>
            <a href={item.href} class="related__link">
              <span class="related__icon"><Icon name={item.icon} size={20} /></span>
              <span class="related__text">
                <span class="related__title">{item.title}</span>
                <span class="related__desc">{item.description}</span>
              </span>
              <Icon name="arrow-right" size={16} class="related__arrow" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
  <!-- The closing CTA lives in the footer, on every page — see Footer.astro. -->
</BaseLayout>

<style>
  /* Breadcrumbs clear the fixed header; the hero then drops its own top
     offset so the two don't stack into a canyon of whitespace. */
  .crumbs {
    padding-top: calc(var(--header-height) + var(--space-8));
  }

  .crumbs + :global(.hero) {
    padding-top: var(--space-6);
  }

  .section__lead {
    max-width: 34rem;
    margin-bottom: var(--space-10);
  }

  /* ===== What you get ===== */
  .features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-10) var(--space-12);
  }

  /* ===== Contact panel ===== */
  .panel {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 4fr);
    gap: var(--space-10);
    align-items: end;
    padding: var(--space-10);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    background: var(--color-bg-alt);
  }

  .panel__copy h2 {
    font-size: var(--text-3xl);
    margin-block: var(--space-3) var(--space-4);
  }

  .panel__copy p {
    max-width: 38rem;
    margin: 0;
  }

  .panel__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ===== Related ===== */
  .related {
    display: grid;
    max-width: 52rem;
  }

  .related li {
    border-top: 1px solid var(--color-border);
  }

  .related li:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .related__link {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding-block: var(--space-5);
    color: var(--color-text);
  }

  .related__icon {
    display: inline-flex;
    color: var(--color-accent);
  }

  .related__text {
    display: grid;
    gap: var(--space-1);
    flex: 1;
    min-width: 0;
  }

  .related__title {
    font-weight: 600;
  }

  .related__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .related__link :global(.related__arrow) {
    color: var(--color-text-tertiary);
  }

  .related__link:hover {
    color: var(--color-accent);
  }

  .related__link:hover :global(.related__arrow) {
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .related__link :global(.related__arrow) {
      transition: transform var(--duration-fast) var(--ease-out-expo),
                  color var(--duration-fast) ease;
    }

    .related__link:hover :global(.related__arrow) {
      transform: translateX(3px);
    }
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .panel {
      grid-template-columns: 1fr;
      align-items: start;
      gap: var(--space-8);
      padding: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .features {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
